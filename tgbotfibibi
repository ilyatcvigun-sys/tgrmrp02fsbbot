async def adepartment(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Управление отделами: add/remove/rename/list"""
    user_id = update.effective_user.id
    if not has_permission(user_id, 'manage_ranks'):
        await update.message.reply_text("❌ С 5 ранга.")
        return
    
    if not context.args:
        await update.message.reply_text("❌ /adepartment add/remove/rename/list")
        return
    
    action = context.args[0].lower()
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    
    if action == 'add':
        if len(context.args) < 2:
            await update.message.reply_text("❌ /adepartment add Название")
            conn.close()
            return
        name = ' '.join(context.args[1:])
        try:
            c.execute('INSERT INTO departments (name) VALUES (?)', (name,))
            conn.commit()
            await update.message.reply_text(f"✅ Отдел '{name}' добавлен.")
        except:
            await update.message.reply_text("❌ Такой отдел уже есть.")
    
    elif action == 'remove':
        if len(context.args) < 2:
            await update.message.reply_text("❌ /adepartment remove Номер")
            conn.close()
            return
        try:
            num = int(context.args[1])
        except:
            await update.message.reply_text("❌ Укажите номер.")
            conn.close()
            return
        depts = get_departments()
        if 1 <= num <= len(depts):
            name = depts[num - 1]
            c.execute('DELETE FROM departments WHERE name = ?', (name,))
            conn.commit()
            await update.message.reply_text(f"✅ Отдел '{name}' удалён.")
        else:
            await update.message.reply_text("❌ Неверный номер.")
    
    elif action == 'rename':
        if len(context.args) < 3:
            await update.message.reply_text("❌ /adepartment rename Номер НовоеНазвание")
            conn.close()
            return
        try:
            num = int(context.args[1])
        except:
            await update.message.reply_text("❌ Укажите номер.")
            conn.close()
            return
        depts = get_departments()
        if 1 <= num <= len(depts):
            old_name = depts[num - 1]
            new_name = ' '.join(context.args[2:])
            c.execute('UPDATE users SET department = ? WHERE department = ?', (new_name, old_name))
            c.execute('UPDATE departments SET name = ? WHERE name = ?', (new_name, old_name))
            conn.commit()
            await update.message.reply_text(f"✅ '{old_name}' → '{new_name}'")
        else:
            await update.message.reply_text("❌ Неверный номер.")
    
    elif action == 'list':
        depts = get_departments()
        text = "📁 ОТДЕЛЫ:\n\n"
        for i, d in enumerate(depts, 1):
            text += f"{i}. {d}\n"
        await update.message.reply_text(text)
    
    else:
        await update.message.reply_text("❌ Действие: add, remove, rename, list")
    
    conn.close()

