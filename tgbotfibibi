    req = get_change_request(req_id)
    if not req:
        return
    user_data = get_user_data(req['user_id'])
    text = _format_request_card(req, user_data)
    kb = InlineKeyboardMarkup([[
        InlineKeyboardButton("✅ Одобрить", callback_data=f"rqst:appr:{req_id}"),
        InlineKeyboardButton("❌ Отказать", callback_data=f"rqst:rej:{req_id}"),
