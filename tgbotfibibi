def generate_unique_token() -> str:
    """Генерация уникального жетона"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    while True:
        token = f"52{''.join([str(random.randint(0, 9)) for _ in range(4)])}"
        c.execute('SELECT token FROM users WHERE token = ?', (token,))
        if not c.fetchone():
            conn.close()
            return token

