    idea = _idea_get(idea_id)
    if not idea or not idea.get('text'):
        await update.message.reply_text("❌ Идея не найдена.")
        return
    
    is_admin = has_permission(user_id, 'gban', 'aidea_info')
    if not is_admin and idea['user_id'] != user_id:
        await update.message.reply_text("❌ Вы можете смотреть только свои идеи.")
        return
    
    card = _format_idea_card(idea, for_admin=is_admin)
    kb = None
    # Если ещё ожидает и юзер — админ, добавим кнопки решения
    if is_admin and idea.get('status') == 'submitted':
        kb = _idea_kb_decision(idea_id)
    
    await update.message.reply_text(card, reply_markup=kb)


async def aidea_to_changelog(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Конвертирует одобренную/реализованную идею в черновик changelog.
    /aidea_to_changelog <idea_id>
    Полезно при подготовке очередного обновления.
    """
    user_id = update.effective_user.id
    if not has_permission(user_id, 'gban', 'aidea_to_changelog'):
        await update.message.reply_text("❌ Команда доступна со спецдоступом.")
        return
    if not context.args:
        await update.message.reply_text("❌ Использование: /aidea_to_changelog <idea_id>")
        return
    try:
        idea_id = int(context.args[0])
    except ValueError:
        await update.message.reply_text("❌ ID должен быть числом.")
        return
    
    idea = _idea_get(idea_id)
    if not idea or not idea.get('text'):
        await update.message.reply_text("❌ Идея не найдена.")
        return
    
    author = get_user_data(idea['user_id'])
    author_name = author['nick'] if author else f"id {idea['user_id']}"
    content = f"💡 {idea['text']}\n\n📌 Идея #{idea_id} от {author_name}"
    version = _changelog_next_version()
    cid = _changelog_save_draft(content, version=version, title=None, created_by=user_id)
    cl = _changelog_get(cid)
    
    await update.message.reply_text(
        _changelog_format(cl) +
        f"\n\n💡 Опубликовать: /achangelog_publish {cid}"
    )


async def weekly_ideas_poll_job(context: ContextTypes.DEFAULT_TYPE):
    """
    Еженедельный авто-опрос идей. Запускается из job_queue (например, четверг 18:00 МСК).
    Аналогичен ручному /aideas_start, но без аргументов.
    """
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        'INSERT INTO idea_polls (started_by, prompt, status, started_at) VALUES (NULL, NULL, "active", ?)',
        (now_msk_str(),),
    )
    poll_id = c.lastrowid
    c.execute('SELECT user_id FROM users WHERE bot_blocked = "Нет"')
    targets = [r[0] for r in c.fetchall()]
    conn.close()
    
    kb = _idea_kb_prompt(poll_id)
    sent = 0
    for uid in targets:
        try:
            await context.bot.send_message(chat_id=uid, text=DEFAULT_IDEA_PROMPT, reply_markup=kb)
            sent += 1
        except Exception as e:
            logger.debug(f"weekly_ideas_poll DM to {uid}: {e}")
        await asyncio.sleep(0.05)
    
    log_action(None, 'ideas_poll_started_auto', None, f"#{poll_id}: sent={sent}")
    # DM админам
    for admin_id in _idea_get_main_admins():
        try:
            await context.bot.send_message(
                chat_id=admin_id,
                text=f"💡 Автоматический опрос идей #{poll_id} запущен, доставлено: {sent}.",
            )
        except Exception:
            pass


async def changelog_startup_notify_job(context: ContextTypes.DEFAULT_TYPE):
    """
    Однократно при старте бота: если со времени последнего опубликованного changelog
    появились новые типы action — DM главному админу с предложением сделать новый.
    """
    since_at = _changelog_get_last_published_at()
    new_actions = _changelog_get_new_actions_since(since_at)
    if not new_actions:
        return
    
    # Главный админ — возьмём из MAIN_ADMIN_IDS
    admin_ids = MAIN_ADMIN_IDS if isinstance(MAIN_ADMIN_IDS, (list, set, tuple)) else [MAIN_ADMIN_IDS]
    if not admin_ids:
        return
    
    lines = [
        "📰 НАПОМИНАНИЕ ПРО CHANGELOG",
        "━━━━━━━━━━━━━━━━━",
        f"С момента последнего обновления ({since_at or 'никогда'}) появились новые типы активности.",
        "Возможно, стоит опубликовать новый changelog.",
        "",
    ]
    described = []
    for action, first_at, count in new_actions[:15]:
        feature = _ACTION_TO_FEATURE.get(action, f"`{action}` (новый тип)")
        described.append(f"  • {feature} (впервые {first_at})")
    if described:
        lines.append("🎯 Что замечено:")
        lines.extend(described)
        if len(new_actions) > 15:
            lines.append(f"  …и ещё {len(new_actions) - 15}")
    lines.append("")
    lines.append("💡 Команды:")
    lines.append("  /achangelog_draft — собрать полный черновик")
    lines.append("  /achangelog_add — создать changelog вручную")
    lines.append("  /achangelog_list — все обновления")
    
    text = "\n".join(lines)
    if len(text) > 4000:
        text = text[:3997] + "..."
    
    for admin_id in admin_ids:
        try:
            await context.bot.send_message(chat_id=admin_id, text=text)
        except Exception as e:
            logger.debug(f"changelog notify {admin_id}: {e}")


