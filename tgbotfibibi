async def resolve_tg_username(update: Update, context: ContextTypes.DEFAULT_TYPE, target: str) -> int:
    """Поиск пользователя по Telegram @username через API"""
    username = target.replace('@', '').strip()
    try:
        chat = await context.bot.get_chat(f"@{username}")
        return chat.id
    except Exception as e:
        logger.error(f"TG resolve error for @{username}: {e}")
    return None

def find_user_in_db(username: str) -> int:
    """Поиск в базе по нику или позывному"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT user_id FROM users WHERE game_nick = ? OR callsign = ?', (username, username))
    r = c.fetchone()
    if r:
        conn.close()
        return r[0]
    c.execute('SELECT user_id FROM users WHERE game_nick LIKE ? OR callsign LIKE ?', (f'{username}%', f'{username}%'))
    results = c.fetchall()
    conn.close()
    if len(results) == 1:
        return results[0][0]
    elif len(results) > 1:
        return -1
    return None

def extract_user_id(update: Update, context: ContextTypes.DEFAULT_TYPE, text: str = None):
    """Извлечение ID: reply → число → @/ссылка → поиск в БД"""
    if update.message and update.message.reply_to_message:
        return update.message.reply_to_message.from_user.id
    if text:
        text = text.strip()
        if text.isdigit():
            return int(text)
        username = text.replace('@', '').strip()
        if 't.me/' in username:
            username = username.split('t.me/')[-1].split()[0].strip()
        if text.startswith('@') or 't.me/' in text:
            return f"@{username}"
        if username:
            db_result = find_user_in_db(username)
            if db_result is not None:
                return db_result
            return f"@{username}"
    return None

async def get_target_id(update: Update, context: ContextTypes.DEFAULT_TYPE, target):
    """Обрабатывает строку @username через TG API"""
    if isinstance(target, int):
        return target
    if isinstance(target, str) and target.startswith('@'):
        return await resolve_tg_username(update, context, target)
    return None

