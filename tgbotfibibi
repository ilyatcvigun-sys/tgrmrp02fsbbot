# Обработка сообщений
async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text
    user_id = update.effective_user.id
    
    # Проверка глобального бана
    gban_status = check_gban(user_id)
    if gban_status['is_banned']:
        await update.message.reply_text("🚫 Вы в глобальном черном списке!")
        return
    
    if text == "📝 Регистрация":
        return await start_registration(update, context)
    elif text == "👤 Профиль":
        await show_profile(update, context)
    elif text == "🔍 Поиск":
        return await search_by_token(update, context)
    elif text == "📊 Статистика":
        await show_statistics(update, context)
    elif text == "🏅 Мои награды":
        await show_my_awards(update, context)
    elif text == "🎖 Выдать награду":
        return await award_user(update, context)
    elif text == "⚠️ Предупредить":
        return await warn_user(update, context)
    elif text == "📋 Управление рангами":
        return await manage_rank(update, context)
    elif text == "👥 Назначить отдел":
        return await assign_department(update, context)
    elif text == "🚫 Бан":
        return await ban_user_menu(update, context)
    else:
        await main_menu(update, context)

# Отмена операции
async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("❌ Операция отменена.")
    await main_menu(update, context)
    return ConversationHandler.END

def main():
    # Инициализация Excel
    init_excel()
    
    # Создание приложения
    application = Application.builder().token(BOT_TOKEN).build()
    
    # Обработчик регистрации
    reg_handler = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex('^📝 Регистрация$'), start_registration)],
        states={
            GAME_NICK: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_game_nick)],
            CALLSIGN: [MessageHandler(filters.TEXT & ~filters.COMMAND, complete_registration)]
        },
        fallbacks=[CommandHandler('cancel', cancel)]
    )
    
    # Обработчик поиска
    search_handler = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex('^🔍 Поиск$'), search_by_token)],
        states={
            SEARCH_TOKEN: [MessageHandler(filters.TEXT & ~filters.COMMAND, execute_search)]
        },
        fallbacks=[CommandHandler('cancel', cancel)]
    )
    
    # Обработчик рангов
    rank_handler = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex('^📋 Управление рангами$'), manage_rank)],
        states={
            RANK_ASSIGN_USER: [MessageHandler(filters.TEXT & ~filters.COMMAND, assign_rank)],
            RANK_ASSIGN_RANK: [MessageHandler(filters.TEXT & ~filters.COMMAND, complete_rank_assign)]
        },
        fallbacks=[CommandHandler('cancel', cancel)]
    )
    
    # Обработчик отделов
    dept_handler = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex('^👥 Назначить отдел$'), assign_department)],
        states={
            DEPARTMENT_ASSIGN: [MessageHandler(filters.TEXT & ~filters.COMMAND, complete_department_assign)]
        },
        fallbacks=[CommandHandler('cancel', cancel)]
    )
    
    # Обработчик наград
    award_handler = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex('^🎖 Выдать награду$'), award_user)],
        states={
            AWARD_USER: [MessageHandler(filters.TEXT & ~filters.COMMAND, select_award_type)],
            AWARD_TYPE: [MessageHandler(filters.TEXT & ~filters.COMMAND, select_specific_award)],
            AWARD_SPECIFIC: [MessageHandler(filters.TEXT & ~filters.COMMAND, complete_award)]
        },
        fallbacks=[CommandHandler('cancel', cancel)]
    )
    
    # Обработчик предупреждений
    warn_handler = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex('^⚠️ Предупредить$'), warn_user)],
        states={
            WARN_USER: [MessageHandler(filters.TEXT & ~filters.COMMAND, warn_reason)],
            WARN_REASON: [MessageHandler(filters.TEXT & ~filters.COMMAND, complete_warn)]
        },
        fallbacks=[CommandHandler('cancel', cancel)]
    )
    
    # Обработчик бана
    ban_handler = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex('^🚫 Бан$'), ban_user_menu)],
        states={
            BAN_USER: [MessageHandler(filters.TEXT & ~filters.COMMAND, ban_duration)],
            BAN_DURATION: [MessageHandler(filters.TEXT & ~filters.COMMAND, complete_ban)]
        },
        fallbacks=[CommandHandler('cancel', cancel)]
    )
    
    # Добавление обработчиков
    application.add_handler(reg_handler)
    application.add_handler(search_handler)
    application.add_handler(rank_handler)
    application.add_handler(dept_handler)
    application.add_handler(award_handler)
    application.add_handler(warn_handler)
    application.add_handler(ban_handler)
    
    # Команды
    application.add_handler(CommandHandler('start', main_menu))
    application.add_handler(CommandHandler('gban', gban_command))
    application.add_handler(CommandHandler('check_gban', check_gban_command))
    
    # Обработчик сообщений
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))
    
    # Обработка ошибок
    application.add_error_handler(lambda update, context: logger.error(f"Ошибка: {context.error}"))
    
    print("🤖 Бот конференции с Excel-базой запущен!")
    application.run_polling()

if __name__ == '__main__':
    main()
