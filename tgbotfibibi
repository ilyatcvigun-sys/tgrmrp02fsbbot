                faction: str, violation: str, evidence: str, command: str) -> int:
    """Сохранение жалобы"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('''INSERT INTO reports (reporter_id, reporter_nick, violator_nick, faction, 
                 violation, evidence, command, created_at) 
                 VALUES (?, ?, ?, ?, ?, ?, ?, ?)''',
              (reporter_id, reporter_nick, violator_nick, faction, violation, evidence, command,
               datetime.now().strftime("%Y-%m-%d %H:%M:%S")))
    report_id = c.lastrowid
    conn.commit()
    conn.close()
    return report_id

def update_report(report_id: int, status: str, moderator_id: int, verdict: str, comment: str = ""):
    """Обновление жалобы"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('''UPDATE reports 
                 SET status = ?, moderator_id = ?, verdict = ?, moderator_comment = ?, resolved_at = ? 
                 WHERE id = ?''',
              (status, moderator_id, verdict, comment,
               datetime.now().strftime("%Y-%m-%d %H:%M:%S"), report_id))
    conn.commit()
    conn.close()

def get_report(report_id: int) -> dict:
    """Получение жалобы"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT * FROM reports WHERE id = ?', (report_id,))
    row = c.fetchone()
    conn.close()
    if row:
        return {
            "id": row[0],
            "reporter_id": row[1],
            "reporter_nick": row[2],
            "violator_nick": row[3],
            "faction": row[4],
            "violation": row[5],
            "evidence": row[6],
            "command": row[7],
            "status": row[8],
            "moderator_id": row[9],
            "moderator_comment": row[10],
            "verdict": row[11],
            "created_at": row[12],
            "resolved_at": row[13]
        }
    return None

