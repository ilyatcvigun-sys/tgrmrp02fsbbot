# ============ ДУЭЛИ (Iris-style) ============
# Двое игроков, по 3 HP, ходят по очереди. На каждом ходу: «Выстрел» / «Прицелиться» / «Сдаться».
# Прицеливание повышает шанс попадания следующего выстрела (+15% за каждое, потолок 90%).
# Выстрел сбрасывает накопленный прицел. Поражение — снижение HP до 0 либо сдача либо тайм-аут.
# Никакого автоматического кика/бана — только запись поражения в статистику.

DUEL_BASE_HIT_CHANCE = 50          # шанс попадания без прицела (%)
DUEL_AIM_BONUS_PER_STEP = 15       # +15% за каждый прицел
DUEL_AIM_MAX = 3                   # больше 3 прицелов подряд не даёт эффекта (90% потолок)
DUEL_HP = 3                        # сколько HP у каждого
DUEL_PENDING_TIMEOUT_MIN = 5       # мин до автоотмены «висящего» вызова
DUEL_TURN_TIMEOUT_MIN = 5          # мин до тайм-аута неактивного хода


def _calc_hit_chance(aim_count: int) -> int:
    bonus = min(aim_count, DUEL_AIM_MAX) * DUEL_AIM_BONUS_PER_STEP
    return min(90, DUEL_BASE_HIT_CHANCE + bonus)


def _duel_create(p1_id: int, p2_id: int, chat_id: int) -> int:
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''INSERT INTO duels (p1_id, p2_id, chat_id, status, p1_hp, p2_hp, p1_aim, p2_aim, started_at)
           VALUES (?, ?, ?, 'pending', ?, ?, 0, 0, ?)''',
        (p1_id, p2_id, chat_id, DUEL_HP, DUEL_HP, now_msk_str()),
    )
    duel_id = c.lastrowid
    conn.commit()
    conn.close()
    return duel_id


def _duel_get(duel_id: int) -> dict:
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    c.execute('SELECT * FROM duels WHERE id = ?', (duel_id,))
    row = c.fetchone()
    conn.close()
    return dict(row) if row else None


def _duel_set_message(duel_id: int, message_id: int):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('UPDATE duels SET message_id = ? WHERE id = ?', (message_id, duel_id))
    conn.commit()
    conn.close()


def _duel_activate(duel_id: int, first_turn: int):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        "UPDATE duels SET status = 'active', current_turn = ? WHERE id = ? AND status = 'pending'",
        (first_turn, duel_id),
    )
    changed = c.rowcount > 0
    conn.commit()
    conn.close()
    return changed


def _duel_finish(duel_id: int, winner_id: int, loser_id: int, reason: str):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''UPDATE duels SET status = 'finished', winner_id = ?, loser_id = ?,
           end_reason = ?, finished_at = ? WHERE id = ?''',
        (winner_id, loser_id, reason, now_msk_str(), duel_id),
    )
    conn.commit()
    conn.close()


def _duel_cancel_pending(duel_id: int, reason: str = 'cancelled'):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''UPDATE duels SET status = 'cancelled', end_reason = ?, finished_at = ?
           WHERE id = ? AND status = 'pending' ''',
        (reason, now_msk_str(), duel_id),
    )
    changed = c.rowcount > 0
    conn.commit()
    conn.close()
    return changed


def _duel_apply_shot(duel_id: int, hit: bool, shooter_is_p1: bool):
    """Применяет результат выстрела к БД. Возвращает обновлённый dict дуэли."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    if shooter_is_p1:
        # Сбрасываем прицел стрелявшему; снимаем HP противнику если попал
        if hit:
            c.execute('UPDATE duels SET p1_aim = 0, p2_hp = MAX(0, p2_hp - 1) WHERE id = ?', (duel_id,))
        else:
            c.execute('UPDATE duels SET p1_aim = 0 WHERE id = ?', (duel_id,))
    else:
        if hit:
            c.execute('UPDATE duels SET p2_aim = 0, p1_hp = MAX(0, p1_hp - 1) WHERE id = ?', (duel_id,))
        else:
            c.execute('UPDATE duels SET p2_aim = 0 WHERE id = ?', (duel_id,))
    conn.commit()
    conn.close()
    return _duel_get(duel_id)


def _duel_apply_aim(duel_id: int, shooter_is_p1: bool):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    field = 'p1_aim' if shooter_is_p1 else 'p2_aim'
    c.execute(f'UPDATE duels SET {field} = {field} + 1 WHERE id = ?', (duel_id,))
    conn.commit()
    conn.close()
    return _duel_get(duel_id)


def _duel_switch_turn(duel_id: int, next_turn: int):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('UPDATE duels SET current_turn = ? WHERE id = ?', (next_turn, duel_id))
    conn.commit()
    conn.close()


def _duel_format_state(duel: dict, status_line: str = "") -> str:
    """Текст с актуальным HP, прицелом и подсказкой чей ход."""
    p1 = get_user_data(duel['p1_id'])
    p2 = get_user_data(duel['p2_id'])
    p1_name = p1['nick'] if p1 else f"id {duel['p1_id']}"
    p2_name = p2['nick'] if p2 else f"id {duel['p2_id']}"
    
    def hp_bar(hp): return "❤️" * hp + "🖤" * (DUEL_HP - hp)
    
    lines = [
        "🔫 ДУЭЛЬ",
        "━━━━━━━━━━━━━━━━━",
        f"🧍 {p1_name}: {hp_bar(duel['p1_hp'])}  🎯×{duel['p1_aim']}",
        f"🧍 {p2_name}: {hp_bar(duel['p2_hp'])}  🎯×{duel['p2_aim']}",
        "━━━━━━━━━━━━━━━━━",
    ]
    if status_line:
        lines.append(status_line)
        lines.append("━━━━━━━━━━━━━━━━━")
    if duel['status'] == 'active':
        cur = p1_name if duel['current_turn'] == duel['p1_id'] else p2_name
        aim = duel['p1_aim'] if duel['current_turn'] == duel['p1_id'] else duel['p2_aim']
        lines.append(f"➡️ Ход: {cur} (шанс попадания {_calc_hit_chance(aim)}%)")
    return "\n".join(lines)


