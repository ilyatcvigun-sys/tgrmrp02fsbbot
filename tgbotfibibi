        return ConversationHandler.END
    
    await update.message.reply_text("🔍 Введите жетон для поиска (формат: 52****):")
    return SEARCH_TOKEN

async def execute_search(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Выполнение поиска"""
    token = update.message.text.strip()
    
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('SELECT * FROM users WHERE token = ?', (token,))
    row = cursor.fetchone()
    conn.close()
    
    if row:
        rank_name = RANKS.get(row[5], RANKS[0])['name']
        await update.message.reply_text(
            f"🎫 Информация по жетону {token}:\n\n"
            f"🎮 Ник: {row[2]}\n"
            f"📻 Позывной: {row[3]}\n"
            f"⭐ Ранг: {rank_name}\n"
            f"📁 Отдел: {row[6]}\n"
            f"⚠️ Предупреждения: {row[7]}"
        )
    else:
        await update.message.reply_text("❌ Участник с таким жетоном не найден.")
    
    return ConversationHandler.END

