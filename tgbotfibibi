def _changelog_get_last_published_at() -> str:
    """Время публикации последнего changelog. Пусто если ещё не было."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        "SELECT published_at FROM changelogs WHERE status = 'published' "
        "ORDER BY published_at DESC LIMIT 1"
    )
    row = c.fetchone()
    conn.close()
    return row[0] if row and row[0] else ""


def _changelog_get_new_actions_since(since_at: str) -> list:
    """
    Возвращает action-типы, которые ВПЕРВЫЕ появились после since_at.
    Если since_at пустой — возвращает все типы action из БД.
    Каждый элемент: (action, first_seen_at, count_since)
    """
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    if since_at:
        # action, у которых MIN(created_at) > since_at
        c.execute(
            '''SELECT action, MIN(created_at) as first_at, COUNT(*) as cnt
               FROM audit_log
               GROUP BY action
               HAVING first_at > ?
               ORDER BY first_at''',
            (since_at,),
        )
    else:
        c.execute(
            '''SELECT action, MIN(created_at) as first_at, COUNT(*) as cnt
               FROM audit_log
               GROUP BY action
               ORDER BY first_at'''
        )
    rows = c.fetchall()
    conn.close()
    return rows


def _changelog_next_version() -> str:
    """Авто-версия по следующему опубликованному номеру."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM changelogs WHERE status = 'published'")
    n = c.fetchone()[0]
    conn.close()
    return f"v{n + 1}"


def _changelog_save_draft(content: str, version: str = None, title: str = None,
                           created_by: int = None) -> int:
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''INSERT INTO changelogs (version, title, content, status, created_by, created_at)
           VALUES (?, ?, ?, 'draft', ?, ?)''',
        (version, title, content, created_by, now_msk_str()),
    )
    cid = c.lastrowid
    conn.commit()
    conn.close()
    return cid


def _changelog_get(cid: int) -> dict:
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    c.execute('SELECT * FROM changelogs WHERE id = ?', (cid,))
    row = c.fetchone()
    conn.close()
    return dict(row) if row else None


def _changelog_format(cl: dict) -> str:
    """Единое оформление changelog: для просмотра, для черновика, для публикации."""
    head = f"📰 ОБНОВЛЕНИЕ"
    if cl.get('version'):
        head += f" {cl['version']}"
    head += f" #{cl['id']}"
    if cl['status'] == 'draft':
        head += " (черновик)"
    
    body = f"{head}\n"
    if cl.get('title'):
        body += f"📌 {cl['title']}\n"
    body += "━━━━━━━━━━━━━━━━━\n"
    body += cl['content'] + "\n"
    body += "━━━━━━━━━━━━━━━━━\n"
    if cl['status'] == 'published':
        body += f"📅 Опубликовано: {cl['published_at']}"
    else:
        body += f"📅 Черновик от: {cl['created_at']}"
    return body


async def achangelog_add(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Создать черновик changelog'а с указанным текстом.
    
    /achangelog_add <текст>
    
    Можно через несколько строк (бот возьмёт всё что после команды).
    Первая строка после команды может быть «v3 Заголовок» — тогда v3 будет версией,
    а остаток — заголовком; со следующей строки — содержимое.
    """
    user_id = update.effective_user.id
    if not has_permission(user_id, 'gban', 'achangelog_add'):
        await update.message.reply_text("❌ Команда доступна со спецдоступом или индивидуальным грантом.")
        return
    
    # Берём весь текст ПОСЛЕ команды (включая переносы)
    raw = update.message.text or ""
    # Убираем саму команду (со слэшем) — она в первом «слове»
    space_idx = raw.find(' ')
    nl_idx = raw.find('\n')
    cut = -1
    for idx in (space_idx, nl_idx):
        if idx >= 0 and (cut < 0 or idx < cut):
            cut = idx
    if cut < 0:
        await update.message.reply_text(
            "❌ Пустой текст.\n\n"
            "Использование:\n"
            "<code>/achangelog_add\nv3 Декабрьские фишки\n• Добавили кубы\n• Поправили дуэли</code>",
            parse_mode='HTML',
        )
        return
    
    text_after_cmd = raw[cut:].strip()
    if not text_after_cmd:
        await update.message.reply_text("❌ Пустой текст.")
        return
    
    lines = text_after_cmd.split('\n', 1)
    first_line = lines[0].strip()
    rest = lines[1] if len(lines) > 1 else ""
    
    # Проверим, начинается ли первая строка с «v<число>» — тогда это версия
    version = None
    title = None
    m = re.match(r'^(v\d+(?:\.\d+)?)\s*(.*)$', first_line, re.IGNORECASE)
    if m:
        version = m.group(1).lower()
        title = m.group(2).strip() or None
        content = rest.strip()
    else:
        content = text_after_cmd  # вся первая строка — часть контента
    
    if not content:
        content = title or "Изменения без описания"
        title = None
    
    if not version:
        version = _changelog_next_version()
    
    cid = _changelog_save_draft(content, version=version, title=title, created_by=user_id)
    cl = _changelog_get(cid)
    
    await update.message.reply_text(
        _changelog_format(cl) + 
        f"\n\n💡 Опубликовать: /achangelog_publish {cid}\n"
        f"💡 Удалить: /achangelog_delete {cid}"
    )


async def achangelog_draft(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Собрать черновик новых фишек, анализируя audit_log с момента последнего опубликованного changelog.
    """
    user_id = update.effective_user.id
    if not has_permission(user_id, 'gban', 'achangelog_draft'):
        await update.message.reply_text("❌ Команда доступна со спецдоступом или индивидуальным грантом.")
        return
    
    since_at = _changelog_get_last_published_at()
    new_actions = _changelog_get_new_actions_since(since_at)
    
    head = "📰 ЧЕРНОВИК ОБНОВЛЕНИЯ"
    if since_at:
        head += f"\n📅 С момента последнего: {since_at}"
    else:
        head += f"\n📅 За всё время (первый changelog)"
    
    if not new_actions:
        await update.message.reply_text(
            head + "\n━━━━━━━━━━━━━━━━━\n"
            "ℹ️ Новых типов активности не обнаружено.\n"
            "Если фича добавлена, но никто ей ещё не пользовался — её здесь не будет.\n"
            "Можете создать вручную через /achangelog_add."
        )
        return
    
    lines = [head, "━━━━━━━━━━━━━━━━━",
             "🆕 Впервые замеченные типы действий:"]
    
    described = []
    unknown = []
    for action, first_at, count in new_actions:
        if action in _ACTION_TO_FEATURE:
            described.append(f"  • {_ACTION_TO_FEATURE[action]}  _(впервые {first_at}, {count}×)_")
        else:
            unknown.append(f"  • `{action}`  _(впервые {first_at}, {count}×)_")
    
    if described:
        lines.append("\n🎯 Распознанные фичи:")
        lines.extend(described)
    if unknown:
        lines.append("\n❓ Нераспознанные action-типы (можно добавить в `_ACTION_TO_FEATURE`):")
        lines.extend(unknown)
    
    lines.append("\n━━━━━━━━━━━━━━━━━")
    lines.append("💡 Дальше отредактируйте текст и вызовите /achangelog_add с готовой версией.")
    lines.append("Например:")
    lines.append("`/achangelog_add v" + str(int(_changelog_next_version()[1:])) + " Новые фишки`")
    lines.append("`• ...`")
    
    text = "\n".join(lines)
    if len(text) > 4000:
        text = text[:3997] + "..."
    await update.message.reply_text(text)


async def achangelog_publish(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Опубликовать черновик: помечает как published, рассылает в конференцию.
    
    /achangelog_publish <id>    — конкретный
    /achangelog_publish          — последний черновик
    """
    user_id = update.effective_user.id
    if not has_permission(user_id, 'gban', 'achangelog_publish'):
        await update.message.reply_text("❌ Команда доступна со спецдоступом или индивидуальным грантом.")
        return
    
    cid = None
    if context.args:
        try:
            cid = int(context.args[0])
        except ValueError:
            await update.message.reply_text("❌ ID должен быть числом.")
            return
    
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    if cid:
        c.execute("SELECT id FROM changelogs WHERE id = ? AND status = 'draft'", (cid,))
    else:
        c.execute("SELECT id FROM changelogs WHERE status = 'draft' ORDER BY id DESC LIMIT 1")
    row = c.fetchone()
    if not row:
        conn.close()
        await update.message.reply_text(
            "❌ Подходящий черновик не найден. Создайте через /achangelog_add."
        )
        return
    cid = row[0]
    
    # Помечаем как опубликованный
    c.execute(
        "UPDATE changelogs SET status = 'published', published_at = ? WHERE id = ?",
        (now_msk_str(), cid),
    )
    conn.commit()
    conn.close()
    
    cl = _changelog_get(cid)
    text = _changelog_format(cl)
    
    # Шлём в конференцию
    published_message_id = None
    try:
        sent = await context.bot.send_message(chat_id=CONFERENCE_CHAT_ID, text=text)
        published_message_id = sent.message_id
    except Exception as e:
        logger.error(f"changelog publish to conference failed: {e}")
    
    if published_message_id:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute('UPDATE changelogs SET published_message_id = ? WHERE id = ?',
                  (published_message_id, cid))
        conn.commit()
        conn.close()
    
    log_action(user_id, 'changelog_published', None, f"#{cid}: {cl.get('version') or '—'}")
    
    await update.message.reply_text(
        f"✅ Changelog #{cid} опубликован" +
        (f" в конференции (msg_id={published_message_id})." if published_message_id
         else " (в БД), но не удалось отправить в конференцию — см. логи.")
    )


