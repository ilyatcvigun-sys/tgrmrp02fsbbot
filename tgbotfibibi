def init_database():
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    
    # Таблица жалоб
    c.execute('''CREATE TABLE IF NOT EXISTS reports (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        reporter_id INTEGER NOT NULL,
        reporter_nick TEXT,
        violator_nick TEXT NOT NULL,
        faction TEXT,
        violation TEXT NOT NULL,
        evidence TEXT,
        command TEXT,
        status TEXT DEFAULT 'pending',
        moderator_id INTEGER,
        moderator_comment TEXT,
        verdict TEXT,
        created_at TEXT DEFAULT '',
        resolved_at TEXT DEFAULT ''
    )''')
    
    # Таблица пользователей
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER UNIQUE NOT NULL,
        game_nick TEXT NOT NULL,
        callsign TEXT NOT NULL,
        token TEXT UNIQUE NOT NULL,
        rank INTEGER DEFAULT 0,
        department TEXT DEFAULT 'Не назначен',
        warns TEXT DEFAULT '0/0',
        ban_status TEXT DEFAULT 'Нет',
        ban_reason TEXT DEFAULT '',
        ban_date TEXT DEFAULT '',
        special_access TEXT DEFAULT 'Нет',
        bot_blocked TEXT DEFAULT 'Нет',
        created_at TEXT DEFAULT ''
    )''')
    
    # Таблица глобального бана
    c.execute('''CREATE TABLE IF NOT EXISTS gban (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER NOT NULL,
        nick TEXT,
        reason TEXT,
        date TEXT,
        banned_by INTEGER
    )''')
    
    # Таблица наград
    c.execute('''CREATE TABLE IF NOT EXISTS awards (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER NOT NULL,
        nick TEXT,
        award_name TEXT,
        award_type TEXT,
        date TEXT,
        issued_by INTEGER
    )''')
    
    # Таблица предупреждений
    c.execute('''CREATE TABLE IF NOT EXISTS warnings (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER NOT NULL,
        nick TEXT,
        warn_type TEXT,
        counter TEXT,
        reason TEXT,
        date TEXT,
        issued_by INTEGER
    )''')
    
    # Таблица департаментов
    c.execute('''CREATE TABLE IF NOT EXISTS departments (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT UNIQUE NOT NULL
    )''')

    c.execute('''
        CREATE TABLE IF NOT EXISTS polls (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            candidate_nick TEXT NOT NULL,
            description TEXT NOT NULL,
            additions TEXT DEFAULT '',
            creator_id INTEGER NOT NULL,
            creator_nick TEXT,
            status TEXT DEFAULT 'active',
            yes_count INTEGER DEFAULT 0,
            no_count INTEGER DEFAULT 0,
            abstain_count INTEGER DEFAULT 0,
            created_at TEXT DEFAULT '',
            closed_at TEXT DEFAULT ''
        )
    ''')
    
    c.execute('''
        CREATE TABLE IF NOT EXISTS poll_votes (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            poll_id INTEGER NOT NULL,
            user_id INTEGER NOT NULL,
            vote TEXT NOT NULL,
            reason TEXT DEFAULT '',
            voted_at TEXT DEFAULT '',
            UNIQUE(poll_id, user_id)
        )
    ''')
    
    # Заполняем начальные департаменты если таблица пуста
    c.execute('SELECT COUNT(*) FROM departments')
    if c.fetchone()[0] == 0:
        for dept in DEPARTMENTS_INITIAL:
            try:
                c.execute('INSERT INTO departments (name) VALUES (?)', (dept,))
            except:
                pass
    
    # Добавляем колонки если их нет
    try:
        c.execute('ALTER TABLE users ADD COLUMN special_access TEXT DEFAULT "Нет"')
    except:
        pass
    try:
        c.execute('ALTER TABLE users ADD COLUMN bot_blocked TEXT DEFAULT "Нет"')
    except:
        pass
    
    conn.commit()
    conn.close()

