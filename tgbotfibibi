def is_private_chat(update: Update) -> bool:
    return update.effective_chat.type == 'private'

def is_main_admin(user_id):
    return user_id in ADMIN_IDS

def has_permission(user_id, action):
    if is_main_admin(user_id):
        return True
    user_data = get_user_data(user_id)
    if not user_data:
        return False
    rank = user_data['rank']
    
    permissions = {
        "search": rank >= 4,
        "award": rank >= 3,
        "warn": rank >= 5,
        "manage_ranks": rank >= 5,
        "ban": rank >= 5,
        "kick": rank >= 5,
        "gban": rank >= 6
    }
    return permissions.get(action, False)

def extract_user_id(update: Update, context: ContextTypes.DEFAULT_TYPE, text: str = None):
    """Извлечение user_id"""
    if update.message and update.message.reply_to_message:
        return update.message.reply_to_message.from_user.id
    
    if text:
        text = text.strip()
        
        if text.isdigit():
            return int(text)
        
        username = text.replace('@', '').strip()
        
        if 't.me/' in username:
            username = username.split('t.me/')[-1].split()[0].strip()
        
        if username:
            user_id = find_user_in_db(username)
            if user_id and user_id != -1:
                return user_id
            
            return f"@{username}"
    
    return None

async def resolve_user_id(update: Update, context: ContextTypes.DEFAULT_TYPE, target) -> int:
    """Разрешает user_id через Telegram API"""
    if isinstance(target, int):
        return target
    
    if isinstance(target, str) and target.startswith('@'):
        username = target[1:]
        try:
            chat = await context.bot.get_chat(f"@{username}")
            return chat.id
        except Exception as e:
            logger.error(f"Resolve error: {e}")
            return None
    
    return None

def find_user_in_db(username):
    """Поиск пользователя в базе"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('SELECT user_id FROM users WHERE game_nick = ? OR callsign = ?', (username, username))
    result = cursor.fetchone()
    if result:
        conn.close()
        return result[0]
    
    cursor.execute('SELECT user_id FROM users WHERE game_nick LIKE ? OR callsign LIKE ?', 
                 (f'{username}%', f'{username}%'))
    results = cursor.fetchall()
    if len(results) == 1:
        conn.close()
        return results[0][0]
    elif len(results) > 1:
        conn.close()
        return -1
    
    conn.close()
    return None

