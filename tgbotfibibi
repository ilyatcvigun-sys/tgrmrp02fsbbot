def has_command_access(user_id: int, command_name: str) -> bool:
    """Есть ли у юзера явный грант на конкретную команду."""
    if not command_name:
        return False
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    try:
        c.execute(
            'SELECT 1 FROM command_grants WHERE user_id = ? AND command = ? LIMIT 1',
            (user_id, command_name),
        )
        return c.fetchone() is not None
    except sqlite3.OperationalError:
        # Таблица ещё не создана (старая БД до миграции) — гранта нет
        return False
    finally:
        conn.close()


def grant_command_access(user_id: int, command_name: str, granted_by: int) -> bool:
    """Выдать юзеру грант на команду. Возвращает True если добавили, False если уже был."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    try:
        c.execute(
            'INSERT INTO command_grants (user_id, command, granted_by, granted_at) VALUES (?, ?, ?, ?)',
            (user_id, command_name, granted_by, now_msk_str()),
        )
        conn.commit()
        return True
    except sqlite3.IntegrityError:
        return False
    finally:
        conn.close()


def revoke_command_access(user_id: int, command_name: str) -> bool:
    """Отозвать грант. True если что-то реально удалили."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        'DELETE FROM command_grants WHERE user_id = ? AND command = ?',
        (user_id, command_name),
    )
    deleted = c.rowcount > 0
    conn.commit()
    conn.close()
    return deleted


def list_user_grants(user_id: int) -> list:
    """Все команды, на которые есть грант у юзера. Возвращает список (command, granted_by, granted_at)."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    try:
        c.execute(
            'SELECT command, granted_by, granted_at FROM command_grants WHERE user_id = ? ORDER BY command',
            (user_id,),
        )
        rows = c.fetchall()
    except sqlite3.OperationalError:
        rows = []
    conn.close()
    return rows


