# Триггер-фразы (нормализуем: нижний регистр, без знаков препинания, lstrip/rstrip).
ARTICLE_TRIGGERS = {"моя статья", "моястатья", "статья моя"}

# КД между запросами одного юзера, в часах
ARTICLE_COOLDOWN_HOURS = 24


def _normalize_trigger(text: str) -> str:
    """Нижний регистр + убираем все знаки препинания/эмодзи на краях."""
    if not text:
        return ""
    t = text.strip().lower()
    # Убираем повторяющиеся пробелы и невидимые символы
    t = re.sub(r'\s+', ' ', t)
    # Убираем знаки препинания на краях
    t = t.strip(".,!?;:()[]{}«»\"'-—–…•· ")
    return t


def _get_last_article_at(user_id: int):
    """Возвращает datetime МСК последнего запроса юзера, либо None."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT last_article_at FROM users WHERE user_id = ?', (user_id,))
    row = c.fetchone()
    conn.close()
    if not row or not row[0]:
        return None
    try:
        return datetime.strptime(row[0], "%Y-%m-%d %H:%M:%S").replace(tzinfo=MSK)
    except Exception:
        return None


def _set_last_article_at(user_id: int):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('UPDATE users SET last_article_at = ? WHERE user_id = ?',
              (now_msk_str("%Y-%m-%d %H:%M:%S"), user_id))
    conn.commit()
    conn.close()


async def handle_my_article(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Реакция на фразу «моя статья» в ЛС бота или в конференции.
    КД 1 день, ~12% шанс «не нашлось». В остальных случаях — рандомная статья УК РФ.
    """
    if not update.message or not update.message.text:
        return
    
    user = update.effective_user
    if not user:
        return
    
    # Проверяем что юзер вообще зарегистрирован — иначе игнорируем
    user_data = get_user_data(user.id)
    if not user_data:
        return
    
    # Проверяем КД
    last_at = _get_last_article_at(user.id)
    if last_at is not None:
        elapsed = now_msk() - last_at
        cooldown = timedelta(hours=ARTICLE_COOLDOWN_HOURS)
        if elapsed < cooldown:
            remaining = cooldown - elapsed
            await update.message.reply_text(
                "⚖️ Картотека УК РФ\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"Сегодня ты уже получал статью.\n"
                f"⏳ Следующий запрос через: {format_duration(remaining)}"
            )
            return
    
    # Ставим КД сразу — независимо от исхода
    _set_last_article_at(user.id)
    
    # Шанс «не выдалась»
    if random.random() < 0.12:
        text = random.choice(UK_NO_ARTICLE_RESPONSES)
        await update.message.reply_text(
            "⚖️ Картотека УК РФ\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"👤 {user_data['nick']}\n"
            f"━━━━━━━━━━━━━━━━━\n"
            f"{text}"
        )
        return
    
    # Выдаём статью
    article = random.choice(UK_ARTICLES)
    
    # Логируем выдачу в article_history (для топа «преступник дня/недели»)
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute(
            'INSERT INTO article_history (user_id, article_num, article_name, given_at) VALUES (?, ?, ?, ?)',
            (user.id, article['num'], article['name'], now_msk_str()),
        )
        conn.commit()
        conn.close()
    except Exception as e:
        logger.debug(f"article_history insert failed: {e}")
    
    await update.message.reply_text(
        "⚖️ ТВОЯ СТАТЬЯ УК РФ\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"👤 {user_data['nick']}\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"📜 Статья {article['num']} УК РФ\n"
        f"⚖️ {article['name']}\n"
        f"💭 {article['joke']}\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"⏳ Следующая статья — через {ARTICLE_COOLDOWN_HOURS}ч."
    )


async def article_trigger_router(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Универсальный роутер для текстовых триггер-фраз ('моя статья').
    Регистрируется в group=2 (после tracker'ов), не блокирует другие хэндлеры.
    """
    if not update.message or not update.message.text:
        return
    normalized = _normalize_trigger(update.message.text)
    if normalized in ARTICLE_TRIGGERS:
        await handle_my_article(update, context)


async def duel_trigger_router(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Текстовый триггер дуэли — позволяет писать «дуэль @user», «дуэль <id>» или
    «дуэль» ответом на сообщение, без слэша. Эквивалент команды /aduel.
    Должен быть зарегистрирован в отдельной группе.
    """
    if not update.message or not update.message.text:
        return
    text = update.message.text.strip()
    # Срабатывает только когда «дуэль» — первое слово сообщения (регистр любой),
    # чтобы случайные «эта дуэль была эпичной» не запускали бой.
    parts = text.split()
    if not parts or parts[0].lower() != "дуэль":
        return
    
    # Подкладываем оставшиеся слова в context.args, чтобы aduel смогла извлечь цель.
    # Если их нет, aduel сама проверит reply_to_message.
    context.args = parts[1:]
    await aduel(update, context)


async def cube_trigger_router(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Текстовый триггер кубов в стиле Iris.
    Поддерживает:
      «кубы»                    — открытый вызов («Кто кубы»)
      «кубы @user» / «кубы 123» — закрытый вызов
      «кубы» (reply)            — закрытый вызов автору
      «кто кубы»                — синоним открытого вызова
      «кубы да»                 — принять активный вызов на себя
      «кубы нет»                — отклонить активный вызов на себя
      «кубы стата»              — топ статистики
      «кубы стата @user»        — статистика конкретного юзера
    Должен быть зарегистрирован в отдельной группе.
    """
    if not update.message or not update.message.text:
        return
    text = update.message.text.strip()
    parts = text.split()
    if not parts:
        return
    
    first = parts[0].lower()
    
    # «кто кубы» — синоним открытого вызова
    if first == "кто" and len(parts) >= 2 and parts[1].lower() == "кубы":
        context.args = []
        await acubes(update, context)
        return
    
    if first != "кубы":
        return
    
    # «кубы да» / «кубы нет» — принять/отклонить вызов на себя
    if len(parts) >= 2 and parts[1].lower() in ("да", "нет"):
        await _cube_text_decision(update, context, accept=(parts[1].lower() == "да"))
        return
    
    # «кубы стата» / «кубы стата @user» → статистика
    if len(parts) >= 2 and parts[1].lower() in ("стата", "статистика"):
        context.args = parts[2:]
        await acubes_stats(update, context)
        return
    
    # Остальные варианты: open («кубы»), closed («кубы @user»), reply
    context.args = parts[1:]
    await acubes(update, context)


async def _cube_text_decision(update: Update, context: ContextTypes.DEFAULT_TYPE, accept: bool):
    """Принять или отклонить вызов в кубы текстом «кубы да» / «кубы нет»."""
    user_id = update.effective_user.id
    if not get_user_data(user_id):
        return  # тихо — фраза могла быть случайной
    
    chat_id = update.effective_chat.id
    
    # Ищем активный pending-вызов в этом чате, где user — соперник
    # (для закрытого: p2_id == user; для открытого: p2_id IS NULL и любой может принять)
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''SELECT id, p1_id, p2_id, is_open FROM cube_games
           WHERE chat_id = ? AND status = 'pending'
             AND (p2_id = ? OR (is_open = 1 AND p2_id IS NULL))
             AND p1_id != ?
           ORDER BY id DESC LIMIT 1''',
        (chat_id, user_id, user_id),
    )
    row = c.fetchone()
    conn.close()
    if not row:
        return  # нет вызова — молчим (фраза могла быть случайной)
    cube_id, p1_id, p2_id, is_open = row
    
    if accept:
        # Открытый вызов — атомарно занимаем место p2
        if is_open and p2_id is None:
            if not _cube_set_opponent(cube_id, user_id):
                return  # кто-то опередил
        cube = _cube_get(cube_id)
        if not cube or cube['status'] != 'pending':
            return
        # Запускаем бросок
        await _run_cube_battle(context, cube_id)
        return
    
    # Отказ: только для закрытого вызова на этого юзера
    if not is_open:
        _cube_cancel_pending(cube_id, reason='rejected')
        cube = _cube_get(cube_id)
        p1 = get_user_data(cube['p1_id'])
        p2 = get_user_data(cube['p2_id'])
        n1 = p1['nick'] if p1 else f"id {cube['p1_id']}"
        n2 = p2['nick'] if p2 else f"id {cube['p2_id']}"
        try:
            await context.bot.edit_message_text(
                chat_id=cube['chat_id'],
                message_id=cube['message_id'],
                text=f"🐔 {n2} отказался играть с {n1}.",
            )
        except Exception:
            pass


async def areloadarticles(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Перезагружает базу статей УК РФ из uk_articles.json без рестарта бота.
    Полезно когда вы дописали статью в JSON и хотите её сразу подхватить.
    Доступ: главный админ или спецдопуск.
    """
    user_id = update.effective_user.id
    if not (is_main_admin(user_id) or has_special_access(user_id)):
        await update.message.reply_text("❌ Команда доступна главному админу или со спецдопуском.")
        return
    
    global UK_ARTICLES
    before = len(UK_ARTICLES)
    UK_ARTICLES = _load_uk_articles()
    after = len(UK_ARTICLES)
    
    await update.message.reply_text(
        "📚 ПЕРЕЗАГРУЗКА БАЗЫ СТАТЕЙ\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"📊 Было: {before} статей\n"
        f"📊 Стало: {after} статей\n"
        + (f"➕ Прибавилось: {after - before}\n" if after > before
           else f"➖ Убавилось: {before - after}\n" if after < before
           else "✅ Без изменений.\n")
        + "━━━━━━━━━━━━━━━━━\n"
        + ("⚠️ Используется fallback — JSON не найден или повреждён, см. логи."
           if after <= len(_UK_ARTICLES_FALLBACK)
           else "✅ Загружено из uk_articles.json")
    )


