async def report_evidence_media(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Получили медиа на шаге доказательств — добавляем file_id в список и
    остаёмся в том же state, чтобы юзер мог отправить ещё.
    """
    msg = update.message
    media = context.user_data.setdefault('report_media', [])
    
    kind = None
    file_id = None
    caption = msg.caption or ""
    if msg.photo:
        kind, file_id = 'photo', msg.photo[-1].file_id  # самое крупное превью
    elif msg.video:
        kind, file_id = 'video', msg.video.file_id
    elif msg.document:
        kind, file_id = 'document', msg.document.file_id
    elif msg.voice:
        kind, file_id = 'voice', msg.voice.file_id
    elif msg.video_note:
        kind, file_id = 'video_note', msg.video_note.file_id
    elif msg.audio:
        kind, file_id = 'audio', msg.audio.file_id
    elif msg.animation:
        kind, file_id = 'animation', msg.animation.file_id
    
    if not kind:
        return REPORT_EVIDENCE  # неизвестный медиа-тип — игнорируем
    
    media.append({'type': kind, 'file_id': file_id, 'caption': caption})
    await msg.reply_text(
        f"✅ Прикреплено ({kind}). Всего вложений: {len(media)}.\n"
        f"Можете прислать ещё, либо отправьте текстовое сообщение со ссылками\n"
        f"или слово «готово»/«нет» чтобы перейти к следующему шагу."
    )
    return REPORT_EVIDENCE


