async def aregister(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Регистрация пользователя (6+ ранг). 
    Использование:
      /aregister @user Ник Позывной
      reply на сообщение + /aregister Ник Позывной
    """
    user_id = update.effective_user.id
    if not has_permission(user_id, 'gban', 'aregister'):
        await update.message.reply_text("❌ Только генералы.")
        return
    
    # Определяем, есть ли reply
    is_reply = bool(update.message and update.message.reply_to_message)
    
    if is_reply:
        target_id = update.message.reply_to_message.from_user.id
        rest_args = list(context.args or [])
    else:
        if not context.args or len(context.args) < 3:
            await update.message.reply_text("❌ /aregister @user Ник Позывной")
            return
        target_id = extract_user_id(update, context, context.args[0])
        if isinstance(target_id, str) and target_id.startswith('@'):
            target_id = await get_target_id(update, context, target_id)
        if not await validate_target(update, target_id):
            return
        rest_args = list(context.args[1:])
    
    if len(rest_args) < 2:
        await update.message.reply_text("❌ Укажите Ник и Позывной.\nПример: /aregister @user Ник Позывной")
        return
    
    if get_user_data(target_id):
        await update.message.reply_text("❌ Уже зарегистрирован.")
        return
    
    game_nick = rest_args[0]
    callsign = rest_args[1]
    
    # Подхватываем tg_username, если возможно
    tg_uname = ""
    try:
        if is_reply and update.message.reply_to_message.from_user.username:
            tg_uname = update.message.reply_to_message.from_user.username
        elif not is_reply and context.args[0].startswith('@'):
            tg_uname = context.args[0].lstrip('@')
    except Exception:
        pass
    
    token = add_user(target_id, game_nick, callsign, tg_username=tg_uname)
    
    if token:
        await update.message.reply_text(f"✅ Зарегистрирован!\n🎮 {game_nick}\n📻 {callsign}\n🎫 {token}")
        await notify_user(context, target_id,
                         f"✅ Вас зарегистрировал {get_admin_nick(user_id)}!\n🎮 {game_nick}\n📻 {callsign}\n🎫 {token}")
    else:
        await update.message.reply_text("❌ Ошибка.")

