def has_permission(user_id: int, action: str, command_name: str = None) -> bool:
    """
    Проверка доступа. Порядок:
      1) Главный админ — всегда да.
      2) Спецдопуск — всегда да.
      3) Явный грант на конкретную команду (если передан command_name) — да.
      4) Ранг 7 — всегда да.
      5) Иначе — проверка action по таблице прав.
    """
    if is_main_admin(user_id):
        return True
    if has_special_access(user_id):
        return True
    if command_name and has_command_access(user_id, command_name):
        return True
    ud = get_user_data(user_id)
    if not ud:
        return False
    rank = ud['rank']
    if rank >= 7:
        return True
    permissions = {
        "search": rank >= 4,
        "award": rank >= 3,
        "warn": rank >= 5,
        "manage_ranks": rank >= 5,
        "ban": rank >= 5,
        "kick": rank >= 5,
    }
    return permissions.get(action, False)

def find_user_by_tg_username(username: str) -> int:
    """Поиск по сохранённому в БД tg_username (без @, регистронезависимо)"""
    username = username.lstrip('@').strip().lower()
    if not username:
        return None
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    try:
        c.execute('SELECT user_id FROM users WHERE LOWER(tg_username) = ?', (username,))
        r = c.fetchone()
        return r[0] if r else None
    except sqlite3.OperationalError:
        # Колонки нет (старая БД) — игнор, перейдём к другим методам
        return None
    finally:
        conn.close()

def find_user_in_db(username: str) -> int:
    """Поиск в базе по нику или позывному (точное совпадение, потом частичное)"""
    username = username.strip()
    if not username:
        return None
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    # 1) Точное совпадение
    c.execute('SELECT user_id FROM users WHERE game_nick = ? OR callsign = ?', (username, username))
    r = c.fetchone()
    if r:
        conn.close()
        return r[0]
    # 2) Частичное совпадение (по началу)
    c.execute(
        'SELECT user_id FROM users WHERE game_nick LIKE ? OR callsign LIKE ?',
        (f'{username}%', f'{username}%')
    )
    results = c.fetchall()
    conn.close()
    if len(results) == 1:
        return results[0][0]
    elif len(results) > 1:
        return -1  # неоднозначно
    return None

async def resolve_tg_username_api(context: ContextTypes.DEFAULT_TYPE, username: str) -> int:
    """Поиск через Telegram API (работает только для публичных юзеров / тех, кто писал боту)"""
    username = username.lstrip('@').strip()
    if not username:
        return None
    try:
        chat = await context.bot.get_chat(f"@{username}")
        return chat.id
    except Exception as e:
        logger.info(f"TG API resolve failed for @{username}: {e}")
    return None

def update_tg_username(user_id: int, tg_username: str):
    """Сохраняет/обновляет @username в БД (для будущего поиска по @)"""
    if not tg_username:
        return
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    try:
        c.execute('UPDATE users SET tg_username = ? WHERE user_id = ?', (tg_username, user_id))
        conn.commit()
    except sqlite3.OperationalError:
        pass
    finally:
        conn.close()


# ============ ОБРАТНАЯ СОВМЕСТИМОСТЬ ============
# Старые функции extract_user_id и get_target_id оставлены, но внутри теперь
# используется улучшенная логика поиска (через tg_username в БД).

def extract_user_id(update: Update, context: ContextTypes.DEFAULT_TYPE, text: str = None):
    """
    Извлечение ID. Возвращает:
      - int (user_id) — если нашли точно
      - -1 — если найдено несколько кандидатов (нужно уточнить)
      - "@username" — если строка похожа на @-форму и в БД не нашли (нужно через get_target_id → API)
      - None — нет цели / пустой ввод
    
    Порядок:
      1) reply → ID
      2) числовой ID
      3) @username / t.me/ → tg_username в БД → если нет, возвращаем "@name" (для API-резолва)
      4) голое имя → tg_username в БД → ник/позывной в БД
    """
    # 1) Reply
    if update.message and update.message.reply_to_message:
        return update.message.reply_to_message.from_user.id
    
    if not text:
        return None
    text = text.strip()
    if not text:
        return None
    
    # 2) Числовой ID (поддержка отрицательных не нужна для user_id, но не мешает)
    if text.lstrip('-').isdigit():
        return int(text)
    
    # Извлекаем имя
    name = text
    if 't.me/' in name:
        name = name.split('t.me/')[-1].split('/')[0].split('?')[0].strip()
    is_at_form = text.startswith('@') or 't.me/' in text
    name = name.lstrip('@').strip()
    if not name:
        return None
    
    # 3) @-форма: сначала наша БД (tg_username), потом возвращаем маркер для API
    if is_at_form:
        db_id = find_user_by_tg_username(name)
        if db_id:
            return db_id
        # Может быть, после @ написан игровой ник
        nick_id = find_user_in_db(name)
        if nick_id is not None and nick_id != -1:
            return nick_id
        # Не нашли локально — пусть попробует TG API
        return f"@{name}"
    
    # 4) Голое имя: tg_username → ник/позывной
    db_id = find_user_by_tg_username(name)
    if db_id:
        return db_id
    return find_user_in_db(name)  # может вернуть int, -1 или None

async def get_target_id(update: Update, context: ContextTypes.DEFAULT_TYPE, target):
    """
    Финальный резолв. Принимает:
      - int → возвращает его же (включая -1 — это маркер "неоднозначно")
      - "@username" → пытается через TG API
      - что-то иное → None
    """
    if isinstance(target, int):
        return target
    if isinstance(target, str) and target.startswith('@'):
        return await resolve_tg_username_api(context, target)
    return None

async def validate_target(update: Update, target_id) -> bool:
    """
    Проверяет результат extract_user_id/get_target_id и отвечает пользователю при ошибке.
    Возвращает True если target_id валиден (можно работать дальше),
    False если была отправлена ошибка (команда должна выйти).
    """
    if target_id is None:
        await update.message.reply_text(
            "❌ Пользователь не найден.\n"
            "Укажите @username, ID, ник или позывной, либо ответьте на сообщение."
        )
        return False
    if target_id == -1:
        await update.message.reply_text(
            "❌ Найдено несколько пользователей с похожим именем.\n"
            "Уточните: используйте полный ник, числовой ID или @username."
        )
        return False
    if isinstance(target_id, str):
        # Сюда не должны попадать — значит TG API не нашёл и сохранилось @name
        await update.message.reply_text(
            "❌ Не удалось найти пользователя по @username.\n"
            "Возможно, юзер ещё не писал ни боту, ни в группу. "
            "Попросите его написать /start в личку боту, или ответьте на его сообщение."
        )
        return False
    return True

