def _can_manage_grants(user_id: int) -> bool:
    """Кто может выдавать/отзывать гранты на команды.
    Намеренно жёстко: только главный админ и юзеры со спецдопуском,
    чтобы нельзя было через грант поднять чужие права."""
    return is_main_admin(user_id) or has_special_access(user_id)


async def agrant(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Выдать пользователю индивидуальный доступ к команде(ам).
    
    Использование:
      /agrant <user> <command> [command2 ...]
      (ответом на сообщение) /agrant <command> [command2 ...]
    
    Примеры:
      /agrant @ivan atag atagdept
      /agrant 123456789 awarn
    """
    user_id = update.effective_user.id
    if not _can_manage_grants(user_id):
        await update.message.reply_text("❌ Управление грантами доступно только главному админу или со спецдопуском.")
        return
    
    args = list(context.args or [])
    is_reply = bool(update.message and update.message.reply_to_message)
    
    if is_reply:
        target_id = update.message.reply_to_message.from_user.id
        commands_to_grant = args
    else:
        if len(args) < 2:
            await update.message.reply_text(
                "📥 ВЫДАЧА ДОСТУПА К КОМАНДЕ\n"
                "━━━━━━━━━━━━━━━━━\n"
                "Использование:\n"
                "• /agrant <user> <command> [command2 ...]\n"
                "• Ответом на сообщение: /agrant <command> [...]\n\n"
                "Список доступных для гранта команд — /agrantcmds"
            )
            return
        target_id = extract_user_id(update, context, args[0])
        if isinstance(target_id, str) and target_id.startswith('@'):
            target_id = await get_target_id(update, context, target_id)
        if target_id is None:
            await update.message.reply_text("❌ Пользователь не найден.")
            return
        if target_id == -1:
            await update.message.reply_text("❌ Несколько совпадений. Уточните @username или ID.")
            return
        commands_to_grant = args[1:]
    
    if not commands_to_grant:
        await update.message.reply_text("❌ Укажите хотя бы одну команду для выдачи доступа.")
        return
    
    target_data = get_user_data(target_id)
    if not target_data:
        await update.message.reply_text("❌ Пользователь не зарегистрирован в боте.")
        return
    
    granted, already, invalid = [], [], []
    for cmd in commands_to_grant:
        cmd = cmd.lstrip('/').strip()
        if cmd not in GRANTABLE_COMMANDS:
            invalid.append(cmd)
            continue
        if grant_command_access(target_id, cmd, user_id):
            granted.append(cmd)
            log_action(user_id, 'grant', target_id, f"/{cmd}")
        else:
            already.append(cmd)
    
    issuer_name = get_admin_nick(user_id)
    parts = [
        "✅ ВЫДАЧА ДОСТУПА",
        "━━━━━━━━━━━━━━━━━",
        f"👤 Кому: {target_data['nick']} (🆔 {target_id})",
        f"👮 Выдал: {issuer_name}",
    ]
    if granted:
        parts.append("\n📥 Выдано: " + ", ".join(f"/{c}" for c in granted))
    if already:
        parts.append("ℹ️ Уже было: " + ", ".join(f"/{c}" for c in already))
    if invalid:
        parts.append("❌ Нельзя выдать (нет в списке): " + ", ".join(f"/{c}" for c in invalid))
    
    await update.message.reply_text("\n".join(parts))
    
    if granted:
        await notify_user(
            context, target_id,
            "🔑 Вам выданы индивидуальные доступы к командам:\n"
            + "\n".join(f"• /{c}" for c in granted)
            + f"\n\n👮 Выдал: {issuer_name}",
        )


