def extract_user_id(update: Update, context: ContextTypes.DEFAULT_TYPE, text: str):
    """
    Извлекает user_id из разных форматов:
    - Числовой ID: 123456789
    - @username: @username
    - Ссылка: https://t.me/username
    - Ответ на сообщение
    """
    text = text.strip()
    
    # Числовой ID
    if text.isdigit():
        return int(text)
    
    # @username
    if text.startswith('@'):
        username = text[1:]
        user_id = find_user_by_username(username)
        if user_id:
            return user_id
        return None
    
    # Ссылка https://t.me/username
    if 't.me/' in text:
        username = text.split('t.me/')[-1].split()[0].strip()
        if username:
            user_id = find_user_by_username(username)
            if user_id:
                return user_id
        return None
    
    # Ответ на сообщение
    if update.message and update.message.reply_to_message:
        return update.message.reply_to_message.from_user.id
    
    return None

def find_user_by_username(username):
    """Поиск пользователя по username"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('''
        SELECT user_id FROM users 
        WHERE game_nick LIKE ? OR callsign LIKE ?
    ''', (f'%{username}%', f'%{username}%'))
    
    results = cursor.fetchall()
    conn.close()
    
    if len(results) == 1:
        return results[0][0]
    elif len(results) > 1:
        return -1
    return None

def find_users_by_username(username):
    """Поиск всех пользователей по username"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('''
        SELECT user_id, game_nick, callsign, token, rank 
        FROM users 
        WHERE game_nick LIKE ? OR callsign LIKE ?
    ''', (f'%{username}%', f'%{username}%'))
    
    results = cursor.fetchall()
    conn.close()
    return results

