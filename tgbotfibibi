async def abroadcast(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    if not is_main_admin(user_id):
        await update.message.reply_text("❌ Только главный администратор.")
        return
    
    if not context.args:
        await update.message.reply_text("❌ /abroadcast Текст")
        return
    
    message = ' '.join(context.args)
    
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('SELECT user_id FROM users WHERE ban_status = "Нет"')
    users = cursor.fetchall()
    conn.close()
    
    await update.message.reply_text(f"📤 Рассылка на {len(users)} чел...")
    
    sent = 0
    failed = 0
    for u in users:
        try:
            await context.bot.send_message(chat_id=u[0], text=f"📢 {message}")
            sent += 1
        except:
            failed += 1
    
    await update.message.reply_text(f"✅ Отправлено: {sent}\n❌ Ошибок: {failed}")

