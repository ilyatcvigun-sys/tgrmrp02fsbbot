async def complete_department_assign(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        parts = update.message.text.split()
        if len(parts) != 2:
            await update.message.reply_text("❌ Неверный формат. Используйте: ID номер_отдела")
            return ConversationHandler.END
        
        target_id = int(parts[0])
        dept_num = int(parts[1]) - 1
        
        if dept_num < 0 or dept_num >= len(DEPARTMENTS):
