async def _resolve_target_for_admin(update: Update, context: ContextTypes.DEFAULT_TYPE, usage_hint: str):
    """
    Общая логика разрешения цели для админ-команд.
    Возвращает int (user_id) либо None — в этом случае ответ уже отправлен пользователю.
    """
    target_id = extract_user_id(update, context)
    if not target_id and context.args:
        target_id = extract_user_id(update, context, context.args[0])
    if not target_id:
        await update.message.reply_text(f"❌ Использование: {usage_hint}")
        return None
    if target_id == -1:
        await update.message.reply_text(
            "❌ Найдено несколько пользователей с похожим именем.\n"
            "Уточните: полный ник, числовой ID или @username."
        )
        return None
    if isinstance(target_id, str) and target_id.startswith('@'):
        target_id = await get_target_id(update, context, target_id)
    if not target_id:
        await update.message.reply_text(
            "❌ Пользователь не найден.\n"
            "Возможно, он ещё не писал боту. Попросите его написать /start в ЛС либо ответьте на его сообщение."
        )
        return None
    return target_id


