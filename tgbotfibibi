async def avote(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Голосование"""
    user_id = update.effective_user.id; user_data = get_user_data(user_id)
    if not user_data: await update.message.reply_text("❌ Не зарегистрированы."); return
    if len(context.args) < 2: await update.message.reply_text("❌ /avote ID да/нет/воздерж"); return
    
    try: poll_id = int(context.args[0])
    except: await update.message.reply_text("❌ Укажите ID."); return
    
    vote = context.args[1].lower()
    vote_map = {'да': ('yes', '✅'), 'нет': ('no', '❌'), 'воздерж': ('abstain', '⚪')}
    if vote not in vote_map: await update.message.reply_text("❌ да/нет/воздерж."); return
    
    vote_en, vote_emoji = vote_map[vote]
    reason = ' '.join(context.args[2:]) if len(context.args) > 2 else ""
    if vote == 'нет' and not reason: await update.message.reply_text("❌ Укажите причину."); return
    
    success, message = vote_in_poll(poll_id, user_id, vote_en, reason)
    
    if success:
        poll = get_poll_by_id(poll_id); voter_nick = user_data['nick']
        await update.message.reply_text(f"✅ Принят!\n📊 Да:{poll['yes']} Нет:{poll['no']} Возд:{poll['abstain']}")
        
        # В конфу и 5+ в ЛС
        try:
            await context.bot.send_message(chat_id=CONFERENCE_CHAT_ID,
                text=f"🗳 #{poll_id} | {voter_nick}: {vote_emoji} {vote.upper()}\n📊 Да:{poll['yes']} Нет:{poll['no']} Возд:{poll['abstain']}",
                message_thread_id=POLL_TOPIC_ID)
        except: pass
        
        conn = sqlite3.connect(DB_FILE); c = conn.cursor()
        c.execute('SELECT user_id FROM users WHERE rank >= 5 AND bot_blocked = "Нет"'); mods = c.fetchall(); conn.close()
        for m in mods:
            if m[0] != user_id:
                try: await context.bot.send_message(chat_id=m[0], text=f"🗳 #{poll_id} | {voter_nick}: {vote_emoji} {vote.upper()}")
                except: pass
    else: await update.message.reply_text(f"❌ {message}")


