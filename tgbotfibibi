def _format_audit_row(row: tuple, focus: str = 'all') -> str:
    """
    Форматирует строку audit_log для вывода.
    focus: 'all' (показывать и actor, и target), 'on' (action над target — показываем actor),
           'by' (action от actor — показываем target).
    """
    _id, actor_id, action, target_id, details, created_at = row
    emoji, label = _ACTION_LABELS.get(action, ('•', action))
    
    parts = [f"🕐 {created_at}", f"{emoji} {label}"]
    if focus in ('all', 'by') and target_id:
        td = get_user_data(target_id)
        tn = td['nick'] if td else f"id {target_id}"
        parts.append(f"→ {tn}")
    if focus in ('all', 'on') and actor_id:
        ad = get_user_data(actor_id)
        an = ad['nick'] if ad else f"id {actor_id}"
        parts.append(f"от {an}")
    elif focus in ('all', 'on') and actor_id is None:
        parts.append("от системы")
    line = " | ".join(parts)
    if details:
        line += f"\n   📝 {details}"
    return line


async def aaudit(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Журнал действий администрации.
    
    /aaudit                — последние 30 действий по всем
    /aaudit @user          — действия НАД юзером и ОТ юзера
    /aaudit by @user       — только действия ОТ юзера (что он сделал)
    /aaudit on @user       — только действия НАД юзером (что с ним сделали)
    """
    user_id = update.effective_user.id
    if not has_permission(user_id, 'warn', 'aaudit'):
        await update.message.reply_text("❌ Команда доступна с 5 ранга.")
        return
    
    args = list(context.args or [])
    mode = 'all'  # 'all' | 'by' | 'on'
    target_arg = None
    
    if args:
        if args[0].lower() in ('by', 'on'):
            mode = args[0].lower()
            target_arg = args[1] if len(args) > 1 else None
        else:
            target_arg = args[0]
            mode = 'either'  # покажем по любой стороне
    
    target_id = None
    if target_arg:
        target_id = extract_user_id(update, context, target_arg)
        if isinstance(target_id, str) and target_id.startswith('@'):
            target_id = await get_target_id(update, context, target_id)
        if target_id is None or target_id == -1:
            await update.message.reply_text("❌ Пользователь не найден или несколько совпадений.")
            return
    
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    if target_id is None:
        c.execute('SELECT id, actor_id, action, target_id, details, created_at FROM audit_log ORDER BY id DESC LIMIT 30')
    elif mode == 'by':
        c.execute('SELECT id, actor_id, action, target_id, details, created_at FROM audit_log WHERE actor_id = ? ORDER BY id DESC LIMIT 50', (target_id,))
    elif mode == 'on':
        c.execute('SELECT id, actor_id, action, target_id, details, created_at FROM audit_log WHERE target_id = ? ORDER BY id DESC LIMIT 50', (target_id,))
    else:  # either
        c.execute(
            '''SELECT id, actor_id, action, target_id, details, created_at FROM audit_log
               WHERE actor_id = ? OR target_id = ?
               ORDER BY id DESC LIMIT 50''',
            (target_id, target_id),
        )
    rows = c.fetchall()
    conn.close()
    
    if not rows:
        await update.message.reply_text(
            "📜 ЖУРНАЛ ДЕЙСТВИЙ\n"
            "━━━━━━━━━━━━━━━━━\n"
            "Записей не найдено."
        )
        return
    
    # Подберём header
    if target_id is None:
        header = "📜 ЖУРНАЛ ДЕЙСТВИЙ — последние"
    else:
        td = get_user_data(target_id)
        tn = td['nick'] if td else f"id {target_id}"
        if mode == 'by':
            header = f"📜 ДЕЙСТВИЯ ОТ {tn}"
        elif mode == 'on':
            header = f"📜 ДЕЙСТВИЯ НАД {tn}"
        else:
            header = f"📜 ЖУРНАЛ ПО {tn}"
    
    focus = 'all'
    if mode == 'by':
        focus = 'by'
    elif mode == 'on':
        focus = 'on'
    
    lines = [header, "━━━━━━━━━━━━━━━━━"]
    for row in rows:
        lines.append(_format_audit_row(row, focus=focus))
    lines.append("━━━━━━━━━━━━━━━━━")
    lines.append(f"Записей: {len(rows)}")
    text = "\n".join(lines)
    if len(text) > 4000:
        text = text[:3997] + "..."
    await update.message.reply_text(text)


