# ============ РАБОТА С БАЗОЙ ДАННЫХ ============

def init_database():
    """Инициализация базы данных"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    # Таблица пользователей
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER UNIQUE NOT NULL,
            game_nick TEXT NOT NULL,
            callsign TEXT NOT NULL,
            token TEXT UNIQUE NOT NULL,
            rank INTEGER DEFAULT 0,
            department TEXT DEFAULT 'Не назначен',
            warns TEXT DEFAULT '0/0',
            ban_status TEXT DEFAULT 'Нет',
            ban_reason TEXT DEFAULT '',
            ban_date TEXT DEFAULT '',
            created_at TEXT DEFAULT ''
        )
    ''')
    
    # Таблица глобального бана
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS gban (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            nick TEXT,
            reason TEXT,
            date TEXT,
            banned_by INTEGER
        )
    ''')
    
    # Таблица наград
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS awards (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            nick TEXT,
            award_name TEXT,
            award_type TEXT,
            date TEXT,
            issued_by INTEGER
        )
    ''')
    
    # Таблица предупреждений
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS warnings (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            nick TEXT,
            warn_type TEXT,
            counter TEXT,
            reason TEXT,
            date TEXT,
            issued_by INTEGER
        )
    ''')
    
    conn.commit()
    conn.close()

def generate_unique_token():
    """Генерация уникального жетона"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    while True:
        random_digits = ''.join([str(random.randint(0, 9)) for _ in range(4)])
        token = f"52{random_digits}"
        
        cursor.execute('SELECT token FROM users WHERE token = ?', (token,))
        if not cursor.fetchone():
            conn.close()
            return token

def add_user(user_id, game_nick, callsign):
    """Добавление пользователя"""
    token = generate_unique_token()
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('''
        INSERT INTO users (user_id, game_nick, callsign, token, created_at)
        VALUES (?, ?, ?, ?, ?)
    ''', (user_id, game_nick, callsign, token, datetime.now().strftime("%Y-%m-%d %H:%M:%S")))
    
    conn.commit()
    conn.close()
    return token

def get_user_data(user_id):
    """Получение данных пользователя"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('SELECT * FROM users WHERE user_id = ?', (user_id,))
    row = cursor.fetchone()
    conn.close()
    
    if row:
        return {
            "user_id": row[1],
            "nick": row[2],
            "callsign": row[3],
            "token": row[4],
            "rank": row[5],
            "department": row[6],
            "warns": row[7],
            "ban_status": row[8],
            "ban_reason": row[9],
            "ban_date": row[10],
            "reg_date": row[11]
        }
    return None

def update_user_rank(user_id, new_rank):
    """Обновление ранга"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('UPDATE users SET rank = ? WHERE user_id = ?', (new_rank, user_id))
    conn.commit()
    success = cursor.rowcount > 0
    conn.close()
    return success

def update_user_department(user_id, department):
    """Обновление отдела"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('UPDATE users SET department = ? WHERE user_id = ?', (department, user_id))
    conn.commit()
    success = cursor.rowcount > 0
    conn.close()
    return success

def add_warning(user_id, issuer_id, reason):
    """Добавление предупреждения"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('SELECT warns, game_nick FROM users WHERE user_id = ?', (user_id,))
    row = cursor.fetchone()
    
    if not row:
        conn.close()
        return False, "Пользователь не найден"
    
    current_warns = row[0]
    user_nick = row[1]
    parts = current_warns.split('/')
    
    if len(parts) == 2:
        verbal = int(parts[0])
        written = int(parts[1])
    else:
        verbal = 0
        written = 0
    
    if verbal < 2:
        verbal += 1
        warn_type = "Устное"
    elif written < 3:
        written += 1
        warn_type = "Письменное"
    else:
        conn.close()
        return False, "Достигнут лимит предупреждений"
    
    new_warns = f"{verbal}/{written}"
    
    cursor.execute('UPDATE users SET warns = ? WHERE user_id = ?', (new_warns, user_id))
    
    cursor.execute('''
        INSERT INTO warnings (user_id, nick, warn_type, counter, reason, date, issued_by)
        VALUES (?, ?, ?, ?, ?, ?, ?)
    ''', (user_id, user_nick, warn_type, new_warns, reason, datetime.now().strftime("%Y-%m-%d %H:%M:%S"), issuer_id))
    
    conn.commit()
    conn.close()
    return True, f"Выдано {warn_type.lower()} предупреждение ({new_warns})"

def add_gban(user_id, reason, banned_by):
    """Добавление в глобальный бан"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    user_data = get_user_data(user_id)
    user_nick = user_data['nick'] if user_data else f"User {user_id}"
    
    cursor.execute('''
        INSERT INTO gban (user_id, nick, reason, date, banned_by)
        VALUES (?, ?, ?, ?, ?)
    ''', (user_id, user_nick, reason, datetime.now().strftime("%Y-%m-%d %H:%M:%S"), banned_by))
    
    conn.commit()
    conn.close()
    return True

def check_gban(user_id):
    """Проверка глобального бана"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('SELECT * FROM gban WHERE user_id = ?', (user_id,))
    row = cursor.fetchone()
    conn.close()
    
    if row:
        return {
            "is_banned": True,
            "nick": row[2],
            "reason": row[3],
            "date": row[4],
            "banned_by": row[5]
        }
    return {"is_banned": False}

