# ============ КУБЫ (Iris-style) ============
# Двое игроков бросают анимированные Telegram-кубики (sendDice), побеждает у кого больше точек.
# Поддержка двух режимов: закрытый вызов конкретного юзера и открытый «Кто кубы» (любой принимает).
# При ничьей предлагается переиграть (текстовая фраза «кубы да» / кнопка / просто новый вызов).
# Без автокика — как и дуэли, только запись в статистику.

CUBE_PENDING_TIMEOUT_MIN = 30        # как в Iris — 30 минут на принятие
CUBE_ROLL_DELAY_SEC = 4              # сколько ждать анимацию кубика, прежде чем объявить итог


def _cube_create(p1_id: int, chat_id: int, p2_id: int = None, is_open: bool = False) -> int:
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''INSERT INTO cube_games (p1_id, p2_id, chat_id, is_open, status, started_at)
           VALUES (?, ?, ?, ?, 'pending', ?)''',
        (p1_id, p2_id, chat_id, 1 if is_open else 0, now_msk_str()),
    )
    cube_id = c.lastrowid
    conn.commit()
    conn.close()
    return cube_id


def _cube_get(cube_id: int) -> dict:
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    c.execute('SELECT * FROM cube_games WHERE id = ?', (cube_id,))
    row = c.fetchone()
    conn.close()
    return dict(row) if row else None


def _cube_set_message(cube_id: int, message_id: int):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('UPDATE cube_games SET message_id = ? WHERE id = ?', (message_id, cube_id))
    conn.commit()
    conn.close()


def _cube_set_opponent(cube_id: int, p2_id: int) -> bool:
    """Атомарно подставить p2_id для открытого вызова. False — кто-то опередил."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''UPDATE cube_games SET p2_id = ?
           WHERE id = ? AND status = 'pending' AND (p2_id IS NULL OR p2_id = ?)''',
        (p2_id, cube_id, p2_id),
    )
    ok = c.rowcount > 0
    conn.commit()
    conn.close()
    return ok


def _cube_cancel_pending(cube_id: int, reason: str = 'cancelled') -> bool:
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''UPDATE cube_games SET status = 'cancelled', end_reason = ?, finished_at = ?
           WHERE id = ? AND status = 'pending' ''',
        (reason, now_msk_str(), cube_id),
    )
    ok = c.rowcount > 0
    conn.commit()
    conn.close()
    return ok


def _cube_finish(cube_id: int, p1_roll: int, p2_roll: int,
                 winner_id: int, loser_id: int, reason: str):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''UPDATE cube_games SET status = 'finished',
           p1_roll = ?, p2_roll = ?, winner_id = ?, loser_id = ?,
           end_reason = ?, finished_at = ? WHERE id = ?''',
        (p1_roll, p2_roll, winner_id, loser_id, reason, now_msk_str(), cube_id),
    )
    conn.commit()
    conn.close()


def _cube_kb_pending(cube_id: int, is_open: bool) -> InlineKeyboardMarkup:
    if is_open:
        # Открытый вызов: любой может принять. Инициатор может отменить.
        return InlineKeyboardMarkup([
            [InlineKeyboardButton("🎲 Принять (любой)", callback_data=f"cube:accept:{cube_id}")],
            [InlineKeyboardButton("↩️ Отменить вызов", callback_data=f"cube:cancel:{cube_id}")],
        ])
    # Закрытый вызов: принять может только вызванный. Кнопки в стиле Iris.
    return InlineKeyboardMarkup([
        [
            InlineKeyboardButton("🎲 Принять", callback_data=f"cube:accept:{cube_id}"),
            InlineKeyboardButton("🐔 Отказ", callback_data=f"cube:reject:{cube_id}"),
        ],
    ])


async def acubes(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Вызвать на кубы.
    
    /acubes               — открытый вызов («Кто кубы») — принять может любой
    /acubes @user         — закрытый вызов конкретному игроку
    (reply) /acubes       — закрытый вызов автору сообщения
    """
    user_id = update.effective_user.id
    user_data = get_user_data(user_id)
    if not user_data:
        await update.message.reply_text("❌ Вы не зарегистрированы. Нажмите /start.")
        return
    
    # Определяем цель: reply > args > пусто (открытый вызов)
    target_id = extract_user_id(update, context)
    if not target_id and context.args:
        target_id = extract_user_id(update, context, context.args[0])
    if isinstance(target_id, str) and target_id.startswith('@'):
        target_id = await get_target_id(update, context, target_id)
    if target_id == -1:
        await update.message.reply_text("❌ Несколько пользователей с таким ником, уточните по ID.")
        return
    
    is_open = target_id is None
    if not is_open:
        if target_id == user_id:
            await update.message.reply_text("❌ С собой играть не интересно.")
            return
        opp_data = get_user_data(target_id)
        if not opp_data:
            await update.message.reply_text("❌ Соперник не зарегистрирован в боте.")
            return
    
    # Защита от двойных вызовов от того же юзера
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        "SELECT id FROM cube_games WHERE p1_id = ? AND status = 'pending' LIMIT 1",
        (user_id,),
    )
    existing = c.fetchone()
    conn.close()
    if existing:
        await update.message.reply_text(
            f"❌ У вас уже есть активный вызов в кубы (#{existing[0]}). Отмените его или дождитесь принятия."
        )
        return
    
    chat_id = update.effective_chat.id
    cube_id = _cube_create(user_id, chat_id, p2_id=target_id, is_open=is_open)
    
    if is_open:
        text = (
            f"🎲 {user_data['nick']} ищет соперника для игры в кубики!\n\n"
            "💬 Чтобы принять вызов, нажмите кнопку ниже или введите \"кубы да\".\n"
            f"На принятие решения есть {CUBE_PENDING_TIMEOUT_MIN} минут"
        )
    else:
        text = (
            f"🎲 {opp_data['nick']}, минуточку внимания!\n"
            f"{user_data['nick']} приглашает Вас сыграть в кубики\n\n"
            "💬 Чтобы принять вызов, введите \"кубы да\", или отменить \"кубы нет\"\n"
            f"На принятие решения у вас есть {CUBE_PENDING_TIMEOUT_MIN} минут"
        )
    sent = await update.message.reply_text(text, reply_markup=_cube_kb_pending(cube_id, is_open))
    _cube_set_message(cube_id, sent.message_id)
    
    if context.job_queue:
        context.job_queue.run_once(
            _cube_pending_timeout_job,
            when=CUBE_PENDING_TIMEOUT_MIN * 60,
            data={'cube_id': cube_id},
            name=f"cube_pending_{cube_id}",
        )


async def _cube_pending_timeout_job(context: ContextTypes.DEFAULT_TYPE):
    data = context.job.data or {}
    cube_id = data.get('cube_id')
    if not cube_id:
        return
    cube = _cube_get(cube_id)
    if not cube or cube['status'] != 'pending':
        return
    _cube_cancel_pending(cube_id, reason='timeout')
    p1 = get_user_data(cube['p1_id'])
    n1 = p1['nick'] if p1 else f"id {cube['p1_id']}"
    try:
        await context.bot.edit_message_text(
            chat_id=cube['chat_id'],
            message_id=cube['message_id'],
            text=f"⏱ Время вышло. Никто не принял вызов {n1} на игру в кубики.",
        )
    except Exception:
        pass


async def _run_cube_battle(context: ContextTypes.DEFAULT_TYPE, cube_id: int):
    """
    Запускает фазу бросков в стиле Iris:
    
      1. Редактируем исходное сообщение → "🎲 Первый бросок кубика совершает X"
      2. Шлём анимированный кубик от лица бота
      3. После анимации дописываем в исходное сообщение строку "🎲 Второй бросок совершает Y"
      4. Шлём второй анимированный кубик
      5. После анимации финализируем исходное сообщение текстом с победителем
    """
    cube = _cube_get(cube_id)
    if not cube or cube['status'] != 'pending':
        return
    p1 = get_user_data(cube['p1_id'])
    p2 = get_user_data(cube['p2_id'])
    n1 = p1['nick'] if p1 else f"id {cube['p1_id']}"
    n2 = p2['nick'] if p2 else f"id {cube['p2_id']}"
    chat_id = cube['chat_id']
    
    # === Этап 1: сообщение про первый бросок ===
    stage1_text = f"🎲 Первый бросок кубика совершает {n1}"
    try:
        await context.bot.edit_message_text(
            chat_id=chat_id,
            message_id=cube['message_id'],
            text=stage1_text,
        )
    except Exception:
        pass
    
    # === Этап 2: сам кубик ===
    try:
        msg1 = await context.bot.send_dice(chat_id=chat_id, emoji="🎲")
        roll1 = msg1.dice.value
    except Exception as e:
        logger.error(f"cube send_dice p1 error: {e}")
        return
    
    # Ждём анимацию первого кубика
    await asyncio.sleep(CUBE_ROLL_DELAY_SEC)
    
    # === Этап 3: добавляем строку про второй бросок ===
    stage2_text = (
        f"🎲 Первый бросок кубика совершает {n1}\n"
        f"🎲 Второй бросок кубика совершает {n2}"
    )
    try:
        await context.bot.edit_message_text(
            chat_id=chat_id,
            message_id=cube['message_id'],
            text=stage2_text,
        )
    except Exception:
        pass
    
    # === Этап 4: второй кубик ===
    try:
        msg2 = await context.bot.send_dice(chat_id=chat_id, emoji="🎲")
        roll2 = msg2.dice.value
    except Exception as e:
        logger.error(f"cube send_dice p2 error: {e}")
        return
    
    # Ждём анимацию второго
    await asyncio.sleep(CUBE_ROLL_DELAY_SEC)
    
    # === Этап 5: финал ===
    if roll1 > roll2:
        winner_id, loser_id = cube['p1_id'], cube['p2_id']
        win_name, los_name = n1, n2
        win_roll, los_roll = roll1, roll2
        reason = 'roll'
    elif roll2 > roll1:
        winner_id, loser_id = cube['p2_id'], cube['p1_id']
        win_name, los_name = n2, n1
        win_roll, los_roll = roll2, roll1
        reason = 'roll'
    else:
        winner_id, loser_id = None, None
        reason = 'draw'
    
    _cube_finish(cube_id, roll1, roll2, winner_id, loser_id, reason)
    
    if reason == 'draw':
        final_text = (
            f"🎲 Первый бросок кубика совершает {n1}\n"
            f"🎲 Игроки бросили кубики на доску. И у нас ничья!\n"
            f"🤝 {roll1} : {roll2}"
        )
    else:
        final_text = (
            f"🎲 Первый бросок кубика совершает {n1}\n"
            "🎲 Игроки бросили кубики на доску. И у нас есть победитель!\n\n"
            f"{win_roll} Победа: {win_name}\n"
            f"{los_roll} Поражение: {los_name}"
        )
    try:
        await context.bot.edit_message_text(
            chat_id=chat_id,
            message_id=cube['message_id'],
            text=final_text,
        )
    except Exception:
        pass
    
    if reason == 'roll':
        log_action(None, 'cube_finished', loser_id, f"#{cube_id}: win={winner_id} roll={roll1}vs{roll2}")
    else:
        log_action(None, 'cube_finished', None, f"#{cube_id}: draw {roll1}vs{roll2}")


async def cube_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработка кнопок в кубах. callback_data='cube:<action>:<id>'."""
    query = update.callback_query
    parts = (query.data or "").split(":")
    if len(parts) != 3:
        await query.answer()
        return
    action = parts[1]
    try:
        cube_id = int(parts[2])
    except ValueError:
        await query.answer()
        return
    
    cube = _cube_get(cube_id)
    if not cube:
        await query.answer("Игра не найдена.", show_alert=True)
        return
    
    user_id = query.from_user.id
    
    if action == 'accept':
        if cube['status'] != 'pending':
            await query.answer("Уже не актуально.", show_alert=True)
            return
        # Инициатор не может принять собственный вызов
        if user_id == cube['p1_id']:
            await query.answer("Нельзя принимать собственный вызов.", show_alert=True)
            return
        # Закрытый вызов: только указанный соперник
        if not cube['is_open']:
            if user_id != cube['p2_id']:
                await query.answer("Принять может только тот, кого вызвали.", show_alert=True)
                return
        else:
            # Открытый: проверяем регистрацию + ставим p2_id атомарно
            if not get_user_data(user_id):
                await query.answer("Вы не зарегистрированы в боте.", show_alert=True)
                return
            if not _cube_set_opponent(cube_id, user_id):
                await query.answer("Уже кто-то принял раньше.", show_alert=True)
                return
            cube = _cube_get(cube_id)
        
        await query.answer("Принято! Кидаем кубы 🎲")
        # Сразу запускаем бросок
        await _run_cube_battle(context, cube_id)
        return
    
    if action == 'reject':
        if cube['status'] != 'pending':
            await query.answer("Уже не актуально.", show_alert=True)
            return
        if cube['is_open']:
            await query.answer("Это открытый вызов — отказываться от него не нужно, просто не нажимайте.", show_alert=True)
            return
        if user_id != cube['p2_id']:
