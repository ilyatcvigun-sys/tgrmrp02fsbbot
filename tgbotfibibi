async def aduel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Вызвать пользователя на дуэль.
    
    /aduel @user        — в любом чате
    (ответом на смс) /aduel  — целью становится автор сообщения
    """
    user_id = update.effective_user.id
    user_data = get_user_data(user_id)
    if not user_data:
        await update.message.reply_text("❌ Вы не зарегистрированы. Нажмите /start.")
        return
    
    # Кого вызываем
    target_id = extract_user_id(update, context)
    if not target_id and context.args:
        target_id = extract_user_id(update, context, context.args[0])
    if isinstance(target_id, str) and target_id.startswith('@'):
        target_id = await get_target_id(update, context, target_id)
    if target_id is None or target_id == -1:
        await update.message.reply_text("❌ Использование: /aduel <@user|ID> или ответом на сообщение.")
        return
    if target_id == user_id:
        await update.message.reply_text("❌ С собой стреляться не стоит.")
        return
    
    opp_data = get_user_data(target_id)
    if not opp_data:
        await update.message.reply_text("❌ Соперник не зарегистрирован в боте.")
        return
    
    # Уже есть активная дуэль у одного из участников?
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''SELECT id FROM duels
           WHERE status IN ('pending', 'active')
             AND (p1_id IN (?, ?) OR p2_id IN (?, ?))
           LIMIT 1''',
        (user_id, target_id, user_id, target_id),
    )
    existing = c.fetchone()
    conn.close()
    if existing:
        await update.message.reply_text(f"❌ У одного из участников уже идёт дуэль (#{existing[0]}). Дождитесь окончания.")
        return
    
    chat_id = update.effective_chat.id
    duel_id = _duel_create(user_id, target_id, chat_id)
    
    text = (
        "🔫 ВЫЗОВ НА ДУЭЛЬ\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"⚔️ {user_data['nick']} вызывает {opp_data['nick']} на дуэль!\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"❤️ HP каждого: {DUEL_HP}\n"
        f"🎯 Прицеливание даёт +{DUEL_AIM_BONUS_PER_STEP}% к попаданию следующего выстрела.\n"
        f"⏱ На принятие — {DUEL_PENDING_TIMEOUT_MIN} минут."
    )
    sent = await update.message.reply_text(text, reply_markup=_duel_kb_pending(duel_id))
    _duel_set_message(duel_id, sent.message_id)
    
    # Тайм-аут автоотмены для pending
    if context.job_queue:
        context.job_queue.run_once(
            _duel_pending_timeout_job,
            when=DUEL_PENDING_TIMEOUT_MIN * 60,
            data={'duel_id': duel_id},
            name=f"duel_pending_{duel_id}",
        )


async def _duel_pending_timeout_job(context: ContextTypes.DEFAULT_TYPE):
    """Срабатывает через DUEL_PENDING_TIMEOUT_MIN мин — отменяет дуэль, если не приняли."""
    data = context.job.data or {}
    duel_id = data.get('duel_id')
    if not duel_id:
        return
    duel = _duel_get(duel_id)
    if not duel or duel['status'] != 'pending':
        return
    _duel_cancel_pending(duel_id, reason='timeout')
    p1 = get_user_data(duel['p1_id'])
    p2 = get_user_data(duel['p2_id'])
    n1 = p1['nick'] if p1 else f"id {duel['p1_id']}"
    n2 = p2['nick'] if p2 else f"id {duel['p2_id']}"
    try:
        await context.bot.edit_message_text(
            chat_id=duel['chat_id'],
            message_id=duel['message_id'],
            text=(
                "🔫 ДУЭЛЬ\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"⏱ {n2} не ответил вовремя — вызов от {n1} аннулирован."
            ),
        )
    except Exception:
        pass


async def _duel_turn_timeout_job(context: ContextTypes.DEFAULT_TYPE):
    """Срабатывает через DUEL_TURN_TIMEOUT_MIN мин — если активная дуэль с тем же current_turn,
       значит игрок бездействовал — поражение."""
    data = context.job.data or {}
    duel_id = data.get('duel_id')
    expected_turn = data.get('expected_turn')
    if not duel_id:
        return
    duel = _duel_get(duel_id)
    if not duel or duel['status'] != 'active' or duel['current_turn'] != expected_turn:
        return  # уже сделал ход
    # Бездействовавший проигрывает
    loser_id = duel['current_turn']
    winner_id = duel['p2_id'] if loser_id == duel['p1_id'] else duel['p1_id']
    _duel_finish(duel_id, winner_id, loser_id, 'timeout')
    winner = get_user_data(winner_id)
    loser = get_user_data(loser_id)
    wn = winner['nick'] if winner else f"id {winner_id}"
    ln = loser['nick'] if loser else f"id {loser_id}"
    final = _duel_format_state(_duel_get(duel_id),
                                status_line=f"⏱ {ln} бездействовал слишком долго.\n🏆 Победа: {wn} (тайм-аут).")
    try:
        await context.bot.edit_message_text(
            chat_id=duel['chat_id'],
            message_id=duel['message_id'],
            text=final,
        )
    except Exception:
        pass
    log_action(None, 'duel_finished', loser_id, f"#{duel_id}: win={winner_id} reason=timeout")


def _schedule_turn_timeout(context: ContextTypes.DEFAULT_TYPE, duel_id: int, turn_user_id: int):
    """Запланировать тайм-аут хода. Если в течение DUEL_TURN_TIMEOUT_MIN мин ход не сменится — поражение."""
    if not context.job_queue:
        return
    context.job_queue.run_once(
        _duel_turn_timeout_job,
        when=DUEL_TURN_TIMEOUT_MIN * 60,
        data={'duel_id': duel_id, 'expected_turn': turn_user_id},
        name=f"duel_turn_{duel_id}_{turn_user_id}_{int(now_msk().timestamp())}",
    )


async def duel_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработка всех кнопок дуэли. callback_data='duel:<action>:<id>'."""
    query = update.callback_query
    parts = (query.data or "").split(":")
    if len(parts) != 3:
        await query.answer()
        return
    action = parts[1]
    try:
        duel_id = int(parts[2])
    except ValueError:
        await query.answer()
        return
    
    duel = _duel_get(duel_id)
    if not duel:
        await query.answer("Дуэль не найдена.", show_alert=True)
        return
    
    user_id = query.from_user.id
    
    # ===== Принять / отказаться / отменить (pending) =====
    if action == 'accept':
        if duel['status'] != 'pending':
            await query.answer("Уже не актуально.", show_alert=True)
            return
        if user_id != duel['p2_id']:
            await query.answer("Принять может только тот, кого вызвали.", show_alert=True)
            return
        # Случайно выбираем кто стреляет первым
        first = random.choice([duel['p1_id'], duel['p2_id']])
        if not _duel_activate(duel_id, first):
            await query.answer("Дуэль уже не в статусе ожидания.", show_alert=True)
            return
        duel = _duel_get(duel_id)
        await query.answer("Принято! Удачи 🔫")
        first_data = get_user_data(first)
        first_name = first_data['nick'] if first_data else f"id {first}"
        try:
            await query.edit_message_text(
                _duel_format_state(duel, status_line=f"⚔️ Дуэль началась! Первым стреляет {first_name}."),
                reply_markup=_duel_kb_active(duel_id),
            )
        except Exception:
            pass
        _schedule_turn_timeout(context, duel_id, first)
        return
    
    if action == 'reject':
        if duel['status'] != 'pending':
            await query.answer("Уже не актуально.", show_alert=True)
            return
        if user_id != duel['p2_id']:
            await query.answer("Отклонить может только тот, кого вызвали.", show_alert=True)
            return
        _duel_cancel_pending(duel_id, reason='rejected')
        p1 = get_user_data(duel['p1_id'])
        p2 = get_user_data(duel['p2_id'])
        n1 = p1['nick'] if p1 else f"id {duel['p1_id']}"
        n2 = p2['nick'] if p2 else f"id {duel['p2_id']}"
        await query.answer()
        try:
            await query.edit_message_text(
                "🔫 ДУЭЛЬ\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"❌ {n2} отказался от вызова {n1}."
            )
        except Exception:
            pass
        return
    
    if action == 'cancel':
        if duel['status'] != 'pending':
            await query.answer("Уже не актуально.", show_alert=True)
            return
        if user_id != duel['p1_id']:
            await query.answer("Отменить может только вызывающий.", show_alert=True)
            return
        _duel_cancel_pending(duel_id, reason='cancelled')
        p1 = get_user_data(duel['p1_id'])
        n1 = p1['nick'] if p1 else f"id {duel['p1_id']}"
        await query.answer()
        try:
            await query.edit_message_text(
                "🔫 ДУЭЛЬ\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"↩️ {n1} отменил вызов."
            )
        except Exception:
            pass
        return
    
    # ===== Игровые действия (active) =====
    if duel['status'] != 'active':
        await query.answer("Дуэль уже завершена.", show_alert=True)
        return
    
    # Проверка что юзер — участник и ход его
    if user_id not in (duel['p1_id'], duel['p2_id']):
        await query.answer("Вы не участник этой дуэли.", show_alert=True)
        return
    if user_id != duel['current_turn']:
        await query.answer("Не ваш ход.", show_alert=True)
        return
    
    shooter_is_p1 = (user_id == duel['p1_id'])
    opponent_id = duel['p2_id'] if shooter_is_p1 else duel['p1_id']
    aim = duel['p1_aim'] if shooter_is_p1 else duel['p2_aim']
    
    if action == 'aim':
        await query.answer("🎯 Прицелился!")
        duel = _duel_apply_aim(duel_id, shooter_is_p1)
        # Ход переходит к сопернику (как в Iris — прицел тратит ход)
        _duel_switch_turn(duel_id, opponent_id)
        duel = _duel_get(duel_id)
        shooter = get_user_data(user_id)
        sn = shooter['nick'] if shooter else f"id {user_id}"
        try:
            await query.edit_message_text(
                _duel_format_state(duel, status_line=f"🎯 {sn} прицелился (точность следующего выстрела повышена)."),
                reply_markup=_duel_kb_active(duel_id),
            )
        except Exception:
            pass
        _schedule_turn_timeout(context, duel_id, opponent_id)
        return
    
    if action == 'surrender':
        await query.answer("Сдача принята.")
        winner_id = opponent_id
        loser_id = user_id
        _duel_finish(duel_id, winner_id, loser_id, 'surrender')
        winner = get_user_data(winner_id)
        loser = get_user_data(loser_id)
        wn = winner['nick'] if winner else f"id {winner_id}"
        ln = loser['nick'] if loser else f"id {loser_id}"
        try:
            await query.edit_message_text(
                _duel_format_state(_duel_get(duel_id),
                                    status_line=f"🏃 {ln} сдался.\n🏆 Победа: {wn}.")
            )
        except Exception:
            pass
        log_action(None, 'duel_finished', loser_id, f"#{duel_id}: win={winner_id} reason=surrender")
        return
    
    if action == 'shoot':
        chance = _calc_hit_chance(aim)
        hit = random.randint(1, 100) <= chance
        duel = _duel_apply_shot(duel_id, hit, shooter_is_p1)
        
        shooter = get_user_data(user_id)
        opp = get_user_data(opponent_id)
        sn = shooter['nick'] if shooter else f"id {user_id}"
        on = opp['nick'] if opp else f"id {opponent_id}"
        
        if hit:
            shot_line = f"💥 {sn} стреляет в {on} — ПОПАДАНИЕ! (-1 HP, был шанс {chance}%)"
        else:
            shot_line = f"💨 {sn} стреляет в {on} — промах. (шанс был {chance}%)"
        
        # Проверка финала
        opp_hp = duel['p2_hp'] if shooter_is_p1 else duel['p1_hp']
        if opp_hp <= 0:
            winner_id = user_id
            loser_id = opponent_id
            _duel_finish(duel_id, winner_id, loser_id, 'shot')
            await query.answer("🎯 Победа!")
            try:
                await query.edit_message_text(
                    _duel_format_state(_duel_get(duel_id),
                                        status_line=f"{shot_line}\n🏆 Победа: {sn}!")
                )
            except Exception:
                pass
            log_action(None, 'duel_finished', loser_id, f"#{duel_id}: win={winner_id} reason=shot")
            return
        
        # Передаём ход сопернику
        await query.answer()
        _duel_switch_turn(duel_id, opponent_id)
        duel = _duel_get(duel_id)
        try:
            await query.edit_message_text(
                _duel_format_state(duel, status_line=shot_line),
                reply_markup=_duel_kb_active(duel_id),
            )
        except Exception:
            pass
        _schedule_turn_timeout(context, duel_id, opponent_id)
        return


