    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    try:
        c.execute('''INSERT INTO users (user_id, game_nick, callsign, token, created_at, tg_username) 
                     VALUES (?, ?, ?, ?, ?, ?)''',
                  (user_id, game_nick, callsign, token,
                   now_msk_str("%Y-%m-%d %H:%M:%S"),
