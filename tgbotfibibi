async def gban_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Глобальный бан"""
    user_id = update.effective_user.id
    user_data = get_user_data(user_id)
    
    if not user_data or user_data['rank'] < 6:
        await update.message.reply_text("❌ Только генералы могут использовать глобальный бан.")
        return
    
    if not context.args:
        await update.message.reply_text(
            "❌ Использование: /gban ID/@user/ссылка причина\n"
            "Или ответьте на сообщение: /gban причина"
        )
        return
    
    target_text = context.args[0]
    reason = ' '.join(context.args[1:]) if len(context.args) > 1 else "Без причины"
    
    target_id = extract_user_id(update, context, target_text)
    
    if target_id is None:
        await update.message.reply_text("❌ Пользователь не найден.")
        return
    
    if target_id == -1:
        username = target_text.replace('@', '').replace('https://t.me/', '')
        users = find_users_by_username(username)
        text = "Найдено несколько:\n\n"
        for u in users:
            rank_name = RANKS.get(u[4], RANKS[0])['name']
            text += f"🆔 {u[0]} | {u[1]} | {u[2]} | {rank_name}\n"
        text += "\nУточните: /gban ID причина"
        await update.message.reply_text(text)
        return
    
    add_gban(target_id, reason, user_id)
    target_data = get_user_data(target_id)
    target_name = target_data['callsign'] if target_data else f"User {target_id}"
    
    await update.message.reply_text(
        f"🚫 Глобальный бан!\n\n"
        f"👤 {target_name}\n"
        f"🆔 {target_id}\n"
        f"📝 {reason}\n"
        f"👮 Забанил: {user_data['callsign']}"
    )

