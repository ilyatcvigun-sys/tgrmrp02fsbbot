        try:
            await query.edit_message_text(
                f"🐔 {n2} отказался играть с {n1}."
            )
        except Exception:
            pass
        return
    
    if action == 'cancel':
        if cube['status'] != 'pending':
            await query.answer("Уже не актуально.", show_alert=True)
            return
        if user_id != cube['p1_id']:
            await query.answer("Отменить может только вызывающий.", show_alert=True)
            return
        _cube_cancel_pending(cube_id, reason='cancelled')
        p1 = get_user_data(cube['p1_id'])
        n1 = p1['nick'] if p1 else f"id {cube['p1_id']}"
        await query.answer()
        try:
            await query.edit_message_text(
                f"↩️ {n1} отменил вызов на игру в кубики."
            )
        except Exception:
            pass
        return


