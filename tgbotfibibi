async def analyze_mood_with_ai(messages: list) -> dict:
    """Анализ настроения через OpenRouter"""
    if not messages:
        return {"mood_text": "Нет данных", "mood_score": 0}
    
    combined_text = "\n".join(messages[-100:])
    if len(combined_text) < 10:
        return {"mood_text": "Недостаточно данных", "mood_score": 0}
    
    try:
        client = openai.OpenAI(base_url="https://openrouter.ai/api/v1", api_key=OPENROUTER_API_KEY)
        completion = client.chat.completions.create(
            model=OPENROUTER_MODEL,
            messages=[
                {
                    "role": "system",
                    "content": (
                        "Ты анализатор настроения русскоязычного чата. "
                        "Проанализируй сообщения и верни ТОЛЬКО JSON в формате:\n"
                        '{"mood_score": число 1-100, "mood_label": "Позитивное/Нейтральное/Негативное", '
                        '"summary": "краткий вывод 1 предложение на русском"}'
                    )
                },
                {"role": "user", "content": f"Оцени настроение чата:\n{combined_text}"}
            ],
            temperature=0.3,
            max_tokens=150,
        )
        result = json.loads(completion.choices[0].message.content)
        return result
    except Exception as e:
        logger.error(f"AI mood error: {e}")
        return {"mood_text": "Ошибка анализа", "mood_score": 0}

