async def welcome_new_member(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработка изменения статуса участника:
       - присоединился → приветствие + проверка ЧС
       - кикнут админом (стал 'kicked') → авто-отключение от бота + сообщение в конфу
       - сам вышел ('left') → ничего не трогаем, может ещё вернётся
    """
    chat_member_update = update.chat_member
    old_status = chat_member_update.old_chat_member.status
    new_status = chat_member_update.new_chat_member.status
    user = chat_member_update.new_chat_member.user
    chat = update.effective_chat

    # --- Случай: пользователя кикнули/забанили в чате ---
    if new_status == 'kicked' and old_status not in ('kicked',):
        # Делаем только если это наша целевая конфа
        if CONFERENCE_CHAT_ID and chat.id == CONFERENCE_CHAT_ID:
            user_data = get_user_data(user.id)
            actor = chat_member_update.from_user  # КТО кикнул
            actor_name = "—"
            if actor:
                actor_data = get_user_data(actor.id)
                actor_name = actor_data['nick'] if actor_data else (actor.full_name or f"id {actor.id}")
            disconnect_user_from_bot(user.id)
            log_action(actor.id if actor else None, 'auto_disconnect_kick', user.id, 'кикнут из конференции')
            if user_data:
                try:
                    await context.bot.send_message(
                        chat_id=CONFERENCE_CHAT_ID,
                        text=(
                            "👢 ПОЛЬЗОВАТЕЛЬ ИСКЛЮЧЁН ИЗ КОНФЕРЕНЦИИ\n"
                            "━━━━━━━━━━━━━━━━━\n"
                            f"👤 {user_data['nick']} ({user_data['callsign']})\n"
                            f"🆔 {user.id}\n"
                            f"👮 Кто исключил: {actor_name}\n"
