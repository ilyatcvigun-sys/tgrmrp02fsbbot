def is_user_blocked(user_id: int) -> bool:
    """Проверка блокировки от бота. Сначала смотрим в кэш, потом в БД (на случай рассинхрона)."""
    if user_id in blocked_users:
        return True
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT bot_blocked FROM users WHERE user_id = ?', (user_id,))
    row = c.fetchone()
    conn.close()
    if row and row[0] == 'Да':
        blocked_users.add(user_id)
        return True
    return False


def disconnect_user_from_bot(user_id: int) -> bool:
    """
    Полное отключение пользователя от бота:
      - bot_blocked='Да'
      - rank=0
      - department='Не назначен'
      - кладём в кэш blocked_users
    Возвращает True если запись существовала и обновлена, False если юзера нет в БД.
    Используется и /ablock, и автоматикой при кике из конфы.
    """
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT 1 FROM users WHERE user_id = ?', (user_id,))
    if not c.fetchone():
        conn.close()
        return False
    c.execute(
        '''UPDATE users
           SET bot_blocked = 'Да', rank = 0, department = 'Не назначен'
           WHERE user_id = ?''',
        (user_id,),
    )
    conn.commit()
    conn.close()
    blocked_users.add(user_id)
    return True

