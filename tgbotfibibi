def create_change_request(user_id: int, req_type: str, current_value: str, requested_value: str) -> int:
    """Создать заявку. Возвращает id."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''INSERT INTO change_requests
           (user_id, request_type, current_value, requested_value, created_at)
           VALUES (?, ?, ?, ?, ?)''',
        (user_id, req_type, str(current_value), str(requested_value), now_msk_str()),
    )
    req_id = c.lastrowid
    conn.commit()
    conn.close()
    return req_id


def get_change_request(req_id: int) -> dict:
    """Получить заявку по id."""
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    c.execute('SELECT * FROM change_requests WHERE id = ?', (req_id,))
    row = c.fetchone()
    conn.close()
    if not row:
        return None
    return {
        "id": row["id"],
        "user_id": row["user_id"],
        "request_type": row["request_type"],
        "current_value": row["current_value"],
        "requested_value": row["requested_value"],
        "status": row["status"],
        "reviewer_id": row["reviewer_id"],
        "reviewer_comment": row["reviewer_comment"],
        "created_at": row["created_at"],
        "decided_at": row["decided_at"],
    }


def update_change_request_status(req_id: int, status: str, reviewer_id: int, comment: str = "") -> bool:
    """
    Атомарно меняет статус заявки с pending на approved/rejected.
    Возвращает True если изменили (т.е. заявка действительно была в pending), иначе False.
    Это защищает от race condition двух модераторов.
    """
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''UPDATE change_requests
           SET status = ?, reviewer_id = ?, reviewer_comment = ?, decided_at = ?
           WHERE id = ? AND status = 'pending' ''',
        (status, reviewer_id, comment, now_msk_str(), req_id),
    )
    changed = c.rowcount > 0
    conn.commit()
    conn.close()
    return changed


def get_pending_change_requests() -> list:
    """Все pending-заявки. Возвращает список dict."""
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    c.execute("SELECT * FROM change_requests WHERE status = 'pending' ORDER BY id DESC")
    rows = c.fetchall()
    conn.close()
    return [dict(r) for r in rows]


