def is_private_chat(update: Update) -> bool:
    return update.effective_chat.type == 'private'

def extract_user_id(update: Update, context: ContextTypes.DEFAULT_TYPE, text: str = None):
    """
    Извлечение user_id. Приоритет:
    1. Ответ на сообщение (reply)
    2. Текст: ID, @username, ссылка
    """
    # 1. Ответ на сообщение
    if update.message and update.message.reply_to_message:
        return update.message.reply_to_message.from_user.id
    
    # 2. Текст
    if text:
        text = text.strip()
        
        # Числовой ID
        if text.isdigit():
            return int(text)
        
        # Убираем @ если есть
        username = text.replace('@', '').strip()
        
        # Ссылка https://t.me/username
        if 't.me/' in username:
            username = username.split('t.me/')[-1].split()[0].strip()
        
        # Ищем в базе
        if username:
            conn = sqlite3.connect(DB_FILE)
            cursor = conn.cursor()
            
            # Точное совпадение
            cursor.execute('SELECT user_id FROM users WHERE game_nick = ? OR callsign = ?', (username, username))
            result = cursor.fetchone()
            
            if result:
                conn.close()
                return result[0]
            
            # Частичное совпадение
            cursor.execute('SELECT user_id FROM users WHERE game_nick LIKE ? OR callsign LIKE ?', 
                         (f'%{username}%', f'%{username}%'))
            results = cursor.fetchall()
            conn.close()
            
            if len(results) == 1:
                return results[0][0]
            elif len(results) > 1:
                return -1
    
    return None

def find_users_by_nickname(nickname):
    """Поиск пользователей по нику/позывному"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('''
        SELECT user_id, game_nick, callsign, token, rank, department 
        FROM users 
        WHERE game_nick LIKE ? OR callsign LIKE ?
        ORDER BY rank DESC
    ''', (f'%{nickname}%', f'%{nickname}%'))
    results = cursor.fetchall()
    conn.close()
    return results

