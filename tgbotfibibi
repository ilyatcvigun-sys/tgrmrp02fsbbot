def parse_duration(s: str):
    """
    Парсит длительность вида '30m', '2h', '7d', '1w'. Возвращает timedelta или None.
    Регистр игнорируется. Без суффикса — None (юзер не передал длительность).
    """
    if not s:
        return None
    m = re.match(r'^(\d+)([mhdw])$', s.strip().lower())
    if not m:
        return None
    n = int(m.group(1))
    unit = m.group(2)
    if unit == 'm':
        return timedelta(minutes=n)
    if unit == 'h':
        return timedelta(hours=n)
    if unit == 'd':
        return timedelta(days=n)
    if unit == 'w':
        return timedelta(weeks=n)
    return None


def format_duration(td: timedelta) -> str:
    """Человекочитаемое представление длительности: '7 д', '3 ч', '30 мин', '2 нед'."""
    total = int(td.total_seconds())
    if total <= 0:
        return "0 сек"
    weeks, rem = divmod(total, 604800)
    days, rem = divmod(rem, 86400)
    hours, rem = divmod(rem, 3600)
    mins, _ = divmod(rem, 60)
    parts = []
    if weeks:
        parts.append(f"{weeks} нед")
    if days:
        parts.append(f"{days} д")
    if hours:
        parts.append(f"{hours} ч")
    if mins and not (weeks or days):
        parts.append(f"{mins} мин")
    return " ".join(parts) or "<1 мин"


async def auto_unban_job(context: ContextTypes.DEFAULT_TYPE):
    """
    Каждые 5 минут: разбанивает пользователей, у которых истёк banned_until.
    Снимает ban_status в БД, размбанит в TG, пишет в audit_log, шлёт уведомление.
    """
    now_str = now_msk_str("%Y-%m-%d %H:%M:%S")
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''SELECT user_id, game_nick FROM users
           WHERE ban_status = 'Да'
             AND banned_until IS NOT NULL AND banned_until != ''
             AND banned_until <= ?''',
        (now_str,),
    )
    rows = c.fetchall()
    if not rows:
        conn.close()
        return
    logger.info(f"auto_unban_job: unbanning {len(rows)} users")
    for uid, _nick in rows:
        c.execute(
            'UPDATE users SET ban_status = "Нет", ban_reason = "", ban_date = "", banned_until = NULL WHERE user_id = ?',
            (uid,),
        )
    conn.commit()
    conn.close()
    
    # Снимаем бан в Telegram + аудит + уведомление
    for uid, nick in rows:
        log_action(None, 'unban', uid, "истёк срок временного бана")
        if CONFERENCE_CHAT_ID:
            try:
                await context.bot.unban_chat_member(CONFERENCE_CHAT_ID, uid, only_if_banned=True)
            except Exception as e:
