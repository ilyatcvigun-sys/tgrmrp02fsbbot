async def expire_warnings_job(context: ContextTypes.DEFAULT_TYPE):
    """
    Раз в час: находит активные варны, у которых истёк expires_at, и помечает их как EXPIRED.
    При этом понижает счётчик users.warns на соответствующий тип (verbal/written).
    Старые варны без expires_at (NULL) — никогда не истекают, остаются как были.
    """
    now_str = now_msk_str("%Y-%m-%d %H:%M:%S")
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''SELECT id, user_id, warn_type FROM warnings
           WHERE counter != "0/0" AND counter != "EXPIRED"
             AND expires_at IS NOT NULL AND expires_at != ''
             AND expires_at <= ?''',
        (now_str,),
    )
    expired = c.fetchall()
    if not expired:
        conn.close()
        return
    
    logger.info(f"expire_warnings_job: expiring {len(expired)} warnings")
    affected_users = {}  # user_id → (verbal_dec, written_dec)
    for warn_id, uid, wtype in expired:
        v_dec, w_dec = affected_users.get(uid, (0, 0))
        if wtype == "Устное":
            v_dec += 1
        elif wtype == "Письменное":
            w_dec += 1
        affected_users[uid] = (v_dec, w_dec)
        c.execute('UPDATE warnings SET counter = "EXPIRED" WHERE id = ?', (warn_id,))
    
    # Понижаем счётчик у каждого юзера
    for uid, (v_dec, w_dec) in affected_users.items():
        c.execute('SELECT warns FROM users WHERE user_id = ?', (uid,))
        row = c.fetchone()
        if not row:
            continue
        parts = (row[0] or "0/0").split('/')
        verbal = max(0, int(parts[0]) - v_dec) if len(parts) == 2 and parts[0].isdigit() else 0
        written = max(0, int(parts[1]) - w_dec) if len(parts) == 2 and parts[1].isdigit() else 0
        new_warns = f"{verbal}/{written}"
        c.execute('UPDATE users SET warns = ? WHERE user_id = ?', (new_warns, uid))
    conn.commit()
    conn.close()
    
    # Запишем в аудит-лог и уведомим юзеров (без давления — короткое сообщение)
    for warn_id, uid, wtype in expired:
        log_action(None, 'warn_expired', uid, f"{wtype} (warn_id={warn_id})")
    for uid in affected_users:
        try:
            await context.bot.send_message(
                chat_id=uid,
                text="⏳ Срок одного из ваших предупреждений истёк — счётчик понижен.",
            )
        except Exception:
            pass
        await asyncio.sleep(0.05)

