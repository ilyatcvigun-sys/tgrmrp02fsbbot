async def aideas(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Список идей. Юзер видит только свои; админ — все.
    /aideas              — все ожидающие
    /aideas all          — все (любой статус)
    /aideas approved     — принятые
    /aideas rejected     — отклонённые
    /aideas implemented  — взятые в работу
    """
    user_id = update.effective_user.id
    if not get_user_data(user_id):
        await update.message.reply_text("❌ Вы не зарегистрированы.")
        return
    
    is_admin = has_permission(user_id, 'gban', 'aideas')
    flt = (context.args[0].lower() if context.args else 'submitted').strip()
    
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    base = "SELECT * FROM ideas WHERE text IS NOT NULL"
    params = []
    if flt != 'all':
        base += " AND status = ?"
        params.append(flt)
    if not is_admin:
        base += " AND user_id = ?"
        params.append(user_id)
    base += " ORDER BY id DESC LIMIT 30"
    c.execute(base, params)
    rows = [dict(r) for r in c.fetchall()]
    conn.close()
    
    if not rows:
        await update.message.reply_text("ℹ️ Идей не найдено.")
        return
    
    label_map = {
        'submitted': '⏳ ожидают',
        'approved': '✅ принятые',
        'rejected': '❌ отклонённые',
        'implemented': '🚧 в работе',
        'all': 'всех статусов',
    }
    title = f"💡 ИДЕИ ({label_map.get(flt, flt)})"
    if not is_admin:
        title += " — только ваши"
    
    lines = [title, "━━━━━━━━━━━━━━━━━"]
    for r in rows:
        author = get_user_data(r['user_id'])
        a_name = author['nick'] if author else f"id {r['user_id']}"
        status = r.get('status') or '—'
        emoji = {'submitted': '⏳', 'approved': '✅', 'rejected': '❌', 'implemented': '🚧'}.get(status, '•')
        preview = (r.get('text') or '').replace('\n', ' ')[:60]
        if len((r.get('text') or '')) > 60:
            preview += '…'
        lines.append(f"{emoji} #{r['id']} {a_name}: {preview}")
    lines.append("━━━━━━━━━━━━━━━━━")
    lines.append("Детально: /aidea_info <id>")
    
    text = "\n".join(lines)
    if len(text) > 4000:
        text = text[:3997] + "..."
    await update.message.reply_text(text)


