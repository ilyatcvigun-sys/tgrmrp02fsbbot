# os.environ['TZ'] без time.tzset() не действует, и в Docker системное время — UTC.
# Поэтому работаем явно через zoneinfo: все datetime.now(MSK).
try:
    from zoneinfo import ZoneInfo  # Python 3.9+
    MSK = ZoneInfo("Europe/Moscow")
except Exception:
    # Фолбэк на pytz, если zoneinfo недоступен
    try:
        import pytz
        MSK = pytz.timezone("Europe/Moscow")
    except Exception:
        # Последний фолбэк: фиксированный UTC+3 (без DST, но Москва и так UTC+3 круглый год)
        from datetime import timezone
        MSK = timezone(timedelta(hours=3), name="MSK")


def now_msk() -> datetime:
    """Текущее время в МСК (timezone-aware)."""
    return datetime.now(MSK)


def now_msk_str(fmt: str = "%Y-%m-%d %H:%M:%S") -> str:
    """Текущее время в МСК, отформатированное строкой."""
    return now_msk().strftime(fmt)

