# ============ ИГРА ЗА СНЯТИЕ ПРЕДУПРЕЖДЕНИЯ ============
# Камень-ножницы-бумага, best-of-3. Победа — снимается одно (самое свежее активное) предупреждение.
# КД 14 дней независимо от исхода — ставится в момент СТАРТА игры, чтобы нельзя было повторять,
# пока не повезёт.

WARN_GAME_COOLDOWN_DAYS = 14
_WG_LABELS = {'R': '✊ Камень', 'P': '✋ Бумага', 'S': '✌ Ножницы'}


def _wg_round_result(user_choice: str, bot_choice: str) -> str:
    """Возвращает 'win' | 'loss' | 'draw'."""
    if user_choice == bot_choice:
        return 'draw'
    beats = {'R': 'S', 'P': 'R', 'S': 'P'}  # ключ бьёт значение
    return 'win' if beats.get(user_choice) == bot_choice else 'loss'


def _wg_picker_keyboard() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup([[
        InlineKeyboardButton("✊", callback_data="wgame:R"),
        InlineKeyboardButton("✋", callback_data="wgame:P"),
        InlineKeyboardButton("✌", callback_data="wgame:S"),
    ]])


def _wg_count_active_warns(user_id: int) -> int:
    """Сколько у юзера активных предупреждений (не снятых и не истёкших)."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        'SELECT COUNT(*) FROM warnings WHERE user_id = ? AND counter != "0/0" AND counter != "EXPIRED"',
        (user_id,),
    )
    n = c.fetchone()[0]
    conn.close()
    return n


def _wg_get_cooldown_remaining(user_id: int):
    """Возвращает timedelta до окончания КД, либо None если КД нет/прошло."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT last_warn_game_at FROM users WHERE user_id = ?', (user_id,))
    row = c.fetchone()
    conn.close()
    if not row or not row[0]:
        return None
    try:
        last = datetime.strptime(row[0], "%Y-%m-%d %H:%M:%S").replace(tzinfo=MSK)
    except Exception:
        return None
    next_avail = last + timedelta(days=WARN_GAME_COOLDOWN_DAYS)
    now = now_msk()
    if next_avail <= now:
        return None
    return next_avail - now


def _wg_set_cooldown(user_id: int):
    """Ставим КД с момента вызова."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('UPDATE users SET last_warn_game_at = ? WHERE user_id = ?', (now_msk_str("%Y-%m-%d %H:%M:%S"), user_id))
    conn.commit()
    conn.close()


def _wg_remove_one_warn(user_id: int) -> str:
    """
    Снимаем ОДНО самое свежее активное предупреждение. Возвращает текст с описанием
    что было снято, либо пустую строку если не нашли.
    """
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''SELECT id, warn_type FROM warnings
           WHERE user_id = ? AND counter != "0/0" AND counter != "EXPIRED"
           ORDER BY id DESC LIMIT 1''',
        (user_id,),
    )
    row = c.fetchone()
    if not row:
        conn.close()
        return ""
    warn_id, wtype = row
    c.execute('UPDATE warnings SET counter = "0/0" WHERE id = ?', (warn_id,))
    
    # Понижаем счётчик users.warns строго по типу
    c.execute('SELECT warns FROM users WHERE user_id = ?', (user_id,))
    parts = (c.fetchone()[0] or "0/0").split('/')
    verbal = int(parts[0]) if len(parts) == 2 and parts[0].isdigit() else 0
    written = int(parts[1]) if len(parts) == 2 and parts[1].isdigit() else 0
    if wtype == "Устное":
        verbal = max(0, verbal - 1)
    elif wtype == "Письменное":
        written = max(0, written - 1)
    c.execute('UPDATE users SET warns = ? WHERE user_id = ?', (f"{verbal}/{written}", user_id))
    conn.commit()
    conn.close()
    return f"{wtype} (warn_id={warn_id})"


async def aunwarngame(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Сыграть с ботом за снятие одного предупреждения.
    Камень-ножницы-бумага до 2 побед. КД 14 дней независимо от исхода.
    """
    if not is_private_chat(update):
        await update.message.reply_text("❌ Команду нужно выполнять в личных сообщениях бота.")
        return
    
    user_id = update.effective_user.id
    user_data = get_user_data(user_id)
    if not user_data:
        await update.message.reply_text("❌ Вы не зарегистрированы. Нажмите /start.")
        return
    if is_user_blocked(user_id):
        return  # gate в любом случае отрежет, но на всякий
    
    # Есть ли что снимать?
    active = _wg_count_active_warns(user_id)
    if active == 0:
        await update.message.reply_text(
            "🎮 ИГРА ЗА СНЯТИЕ ПРЕДУПРЕЖДЕНИЯ\n"
            "━━━━━━━━━━━━━━━━━\n"
            "ℹ️ У вас нет активных предупреждений — снимать нечего."
