async def warn_game_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработка хода в КНБ-игре. callback_data='wgame:R|P|S'."""
    query = update.callback_query
    await query.answer()
    user_id = query.from_user.id
    
    state = context.user_data.get('warngame')
    if not state:
        try:
            await query.edit_message_text(
                "🎮 Сессия игры истекла.\n"
                "Если КД ещё активно — повторите позже. Иначе запустите снова: /aunwarngame"
            )
        except Exception:
            pass
        return
    
    data = (query.data or "").split(":")
    if len(data) != 2 or data[1] not in ('R', 'P', 'S'):
        return
    user_choice = data[1]
    bot_choice = random.choice(['R', 'P', 'S'])
    result = _wg_round_result(user_choice, bot_choice)
    
    state['round'] += 1
    line = f"Раунд {state['round']}: {_WG_LABELS[user_choice]} vs {_WG_LABELS[bot_choice]} → "
    if result == 'win':
        state['wins'] += 1
        line += "✅ ваша победа"
    elif result == 'loss':
        state['losses'] += 1
        line += "❌ победа бота"
    else:
        line += "🤝 ничья"
    state['log'].append(line)
    
    # Проверяем финал: 2 победы или 3 раунда сыграно
    finished = state['wins'] >= 2 or state['losses'] >= 2 or state['round'] >= 3
    
    if not finished:
        text = (
            "🎮 КАМЕНЬ-НОЖНИЦЫ-БУМАГА\n"
            "━━━━━━━━━━━━━━━━━\n"
            + "\n".join(state['log'])
            + f"\n━━━━━━━━━━━━━━━━━\n"
            f"📊 Счёт: вы {state['wins']} — {state['losses']} бот\n\n"
            f"Раунд {state['round'] + 1}. Ваш ход:"
        )
        try:
            await query.edit_message_text(text, reply_markup=_wg_picker_keyboard())
        except Exception:
            pass
        return
    
    # === Финал ===
    user_won = state['wins'] > state['losses']
    context.user_data.pop('warngame', None)  # очищаем сессию
    
    if user_won:
        removed = _wg_remove_one_warn(user_id)
        if removed:
            log_action(user_id, 'warn_game_win', user_id, removed)
            final = (
                "🎮 РЕЗУЛЬТАТ\n"
                "━━━━━━━━━━━━━━━━━\n"
                + "\n".join(state['log'])
                + f"\n━━━━━━━━━━━━━━━━━\n"
                f"📊 Счёт: вы {state['wins']} — {state['losses']} бот\n"
                f"🏆 Победа! Снято одно предупреждение.\n"
                f"⏳ Следующая игра — через {WARN_GAME_COOLDOWN_DAYS} дней."
            )
        else:
            # Маловероятно — пока игра шла, варн истёк/был снят
            final = (
                "🎮 РЕЗУЛЬТАТ\n"
                "━━━━━━━━━━━━━━━━━\n"
                + "\n".join(state['log'])
                + f"\n━━━━━━━━━━━━━━━━━\n"
                f"🏆 Победа! Но к моменту окончания игры активных предупреждений не осталось — ничего не снято."
            )
    else:
        log_action(user_id, 'warn_game_loss', user_id, "")
        final = (
            "🎮 РЕЗУЛЬТАТ\n"
            "━━━━━━━━━━━━━━━━━\n"
            + "\n".join(state['log'])
            + f"\n━━━━━━━━━━━━━━━━━\n"
            f"📊 Счёт: вы {state['wins']} — {state['losses']} бот\n"
            f"😔 Поражение. Предупреждения остаются.\n"
            f"⏳ Попробовать снова можно через {WARN_GAME_COOLDOWN_DAYS} дней."
