async def aban(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Бан пользователя — постоянный или временный.
    
    Использование:
      /aban @user [длительность] [причина...]
      (ответом на сообщение) /aban [длительность] [причина...]
    
    Длительность опциональна: 30m, 2h, 7d, 1w (минуты/часы/дни/недели).
    Без длительности — бессрочный бан.
    
    Примеры:
      /aban @ivan спам
      /aban @ivan 7d флуд в чате
      (ответом) /aban 2h оскорбления
    """
    user_id = update.effective_user.id
    if not has_permission(user_id, 'ban', 'aban'):
        await update.message.reply_text("❌ Команда доступна с 5 ранга.")
        return
    
    args = list(context.args or [])
    target_id = extract_user_id(update, context)
    
    if target_id:
        # reply есть — все args потенциально (длительность? + причина)
        pass
    else:
        if not args:
            await update.message.reply_text(
                "❌ Использование: /aban <@user|ID> [длительность] [причина]\n"
                "Длительность: 30m, 2h, 7d, 1w (опц.)"
            )
            return
        target_id = extract_user_id(update, context, args[0])
        args = args[1:]
    
    if isinstance(target_id, str) and target_id.startswith('@'):
        target_id = await get_target_id(update, context, target_id)
    if target_id is None:
        await update.message.reply_text("❌ Пользователь не найден.")
        return
    if target_id == -1:
        await update.message.reply_text("❌ Несколько совпадений. Уточните @username или ID.")
        return
    
    # Первый оставшийся аргумент может быть длительностью
    duration_td = None
    if args:
        d = parse_duration(args[0])
        if d is not None:
            duration_td = d
            args = args[1:]
    reason = ' '.join(args).strip() if args else "Без причины"
    
    banned_until_str = None
    duration_label = "бессрочно"
    if duration_td is not None:
        banned_until_dt = now_msk() + duration_td
        banned_until_str = banned_until_dt.strftime("%Y-%m-%d %H:%M:%S")
        duration_label = format_duration(duration_td) + f" (до {banned_until_str})"
    
    target_data = get_user_data(target_id)
    target_name = target_data['callsign'] if target_data else f"User {target_id}"
    target_nick = target_data['nick'] if target_data else f"User {target_id}"
    
    await send_action_message(update, context, target_id, "ban", reason)
    
    if await ban_user_in_chat(update, context, target_id):
        # Пишем в БД статус и срок
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute(
            '''UPDATE users SET ban_status = "Да", ban_reason = ?, ban_date = ?, banned_until = ?
               WHERE user_id = ?''',
            (reason, now_msk_str(), banned_until_str, target_id),
        )
        conn.commit()
        conn.close()
        
        log_action(user_id, 'ban', target_id, f"{duration_label} — {reason}")
        
        issuer_name = get_admin_nick(user_id)
        body = (
            "🚫 БАН\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"👤 {target_nick} ({target_name})\n"
            f"📝 Причина: {reason}\n"
            f"⏰ Срок: {duration_label}\n"
            f"👮 Забанил: {issuer_name}"
        )
        await update.message.reply_text(body)
        
        await notify_user(
            context, target_id,
            f"🚫 Вы забанены\n"
            f"📝 Причина: {reason}\n"
            f"⏰ Срок: {duration_label}\n"
            f"👮 Забанил: {issuer_name}",
        )
    else:
        await update.message.reply_text("❌ Не удалось забанить.")

