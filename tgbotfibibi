def create_poll(candidate_nick: str, description: str, creator_id: int) -> int:
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    creator_data = get_user_data(creator_id)
    creator_nick = creator_data['nick'] if creator_data else f"User {creator_id}"
    c.execute('''INSERT INTO polls (candidate_nick, description, creator_id, creator_nick, created_at)
                 VALUES (?, ?, ?, ?, ?)''',
              (candidate_nick, description, creator_id, creator_nick, datetime.now().strftime("%Y-%m-%d %H:%M:%S")))
    poll_id = c.lastrowid
    conn.commit(); conn.close()
    return poll_id

def add_poll_addition(poll_id: int, user_id: int, addition: str):
    conn = sqlite3.connect(DB_FILE); c = conn.cursor()
    c.execute('SELECT additions, candidate_nick FROM polls WHERE id = ?', (poll_id,))
    row = c.fetchone()
    current = row[0] if row and row[0] else ""
    candidate = row[1] if row else "?"
    user_data = get_user_data(user_id)
    user_nick = user_data['nick'] if user_data else f"User {user_id}"
    new_addition = f"\n📝 {user_nick}: {addition}"
    c.execute('UPDATE polls SET additions = ? WHERE id = ?', (current + new_addition, poll_id))
    conn.commit(); conn.close()
    return candidate

def vote_in_poll(poll_id: int, user_id: int, vote: str, reason: str = "") -> tuple:
    conn = sqlite3.connect(DB_FILE); c = conn.cursor()
    c.execute('SELECT id FROM poll_votes WHERE poll_id = ? AND user_id = ?', (poll_id, user_id))
    if c.fetchone(): conn.close(); return False, "Вы уже проголосовали."
    c.execute('SELECT status FROM polls WHERE id = ?', (poll_id,))
    row = c.fetchone()
    if not row or row[0] != 'active': conn.close(); return False, "Голосование неактивно."
    c.execute('''INSERT INTO poll_votes (poll_id, user_id, vote, reason, voted_at)
                 VALUES (?, ?, ?, ?, ?)''',
              (poll_id, user_id, vote, reason, datetime.now().strftime("%Y-%m-%d %H:%M:%S")))
    if vote == 'yes': c.execute('UPDATE polls SET yes_count = yes_count + 1 WHERE id = ?', (poll_id,))
    elif vote == 'no': c.execute('UPDATE polls SET no_count = no_count + 1 WHERE id = ?', (poll_id,))
    elif vote == 'abstain': c.execute('UPDATE polls SET abstain_count = abstain_count + 1 WHERE id = ?', (poll_id,))
    conn.commit(); conn.close()
    return True, f"Голос '{vote}' принят."

def get_active_polls() -> list:
    conn = sqlite3.connect(DB_FILE); c = conn.cursor()
    c.execute('SELECT * FROM polls WHERE status = "active" ORDER BY id DESC'); polls = c.fetchall(); conn.close()
    return polls

def get_poll_by_id(poll_id: int) -> dict:
    conn = sqlite3.connect(DB_FILE); c = conn.cursor()
    c.execute('SELECT * FROM polls WHERE id = ?', (poll_id,)); row = c.fetchone(); conn.close()
    if row:
        return {"id": row[0], "candidate": row[1], "description": row[2], "additions": row[3],
                "creator_id": row[4], "creator_nick": row[5], "status": row[6],
                "yes": row[7], "no": row[8], "abstain": row[9],
                "created_at": row[10], "closed_at": row[11]}
    return None

def close_poll(poll_id: int) -> dict:
    conn = sqlite3.connect(DB_FILE); c = conn.cursor()
    c.execute('UPDATE polls SET status = "closed", closed_at = ? WHERE id = ?',
              (datetime.now().strftime("%Y-%m-%d %H:%M:%S"), poll_id))
    c.execute('SELECT * FROM polls WHERE id = ?', (poll_id,)); row = c.fetchone()
    conn.commit(); conn.close()
    if row:
        return {"id": row[0], "candidate": row[1], "yes": row[7], "no": row[8], "abstain": row[9]}
    return None

def get_poll_votes(poll_id: int) -> list:
    conn = sqlite3.connect(DB_FILE); c = conn.cursor()
    c.execute('SELECT * FROM poll_votes WHERE poll_id = ? ORDER BY id DESC', (poll_id,))
    votes = c.fetchall(); conn.close()
    return votes

