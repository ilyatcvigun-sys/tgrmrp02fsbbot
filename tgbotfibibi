        await update.message.reply_text(
            "🎮 ИГРА ЗА СНЯТИЕ ПРЕДУПРЕЖДЕНИЯ\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"⏳ Слишком рано: до следующей попытки {format_duration(remaining)}.\n"
            f"Откат — {WARN_GAME_COOLDOWN_DAYS} дней с момента последней игры."
        )
        return
    
    # Ставим КД СРАЗУ при старте, чтобы нельзя было «передумать»
    _wg_set_cooldown(user_id)
    log_action(user_id, 'warn_game_start', user_id,
               f"активных предупреждений: {active}")
    
    # Состояние игры — в user_data
    context.user_data['warngame'] = {'wins': 0, 'losses': 0, 'round': 0, 'log': []}
    
    await update.message.reply_text(
