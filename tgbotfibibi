def get_statistics():
    """Получение статистики"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('SELECT COUNT(*) FROM users')
    total = cursor.fetchone()[0]
    
    cursor.execute('SELECT COUNT(*) FROM users WHERE ban_status = "Нет"')
    active = cursor.fetchone()[0]
    
    cursor.execute('SELECT COUNT(*) FROM users WHERE rank = 6')
    generals = cursor.fetchone()[0]
    
    conn.close()
    
    return {
        "total": total,
        "active": active,
        "banned": total - active,
        "generals": generals
    }

def get_user_awards(user_id):
    """Получение наград пользователя"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('SELECT award_name, award_type, date FROM awards WHERE user_id = ? ORDER BY id DESC LIMIT 10', (user_id,))
    awards = cursor.fetchall()
    conn.close()
    
    return awards

def get_user_permissions(user_id):
    """Получение прав пользователя"""
    user_data = get_user_data(user_id)
    if not user_data:
        return RANKS[0]
    return RANKS.get(user_data['rank'], RANKS[0])

