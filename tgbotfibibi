async def _apply_request_decision(context: ContextTypes.DEFAULT_TYPE, query, req_id: int,
                                   reviewer_id: int, new_status: str, comment: str = ""):
    """
    Применяет решение по заявке (общая логика для callback и команды).
    query — может быть None для системных снятий, иначе редактируем сообщение модератора.
    """
    if not update_change_request_status(req_id, new_status, reviewer_id, comment):
        # Кто-то опередил
        req2 = get_change_request(req_id)
        if query:
            existing_reviewer = get_admin_nick(req2['reviewer_id']) if req2 and req2['reviewer_id'] else "—"
            status_label = "✅ ОДОБРЕНО" if req2 and req2['status'] == 'approved' else "❌ ОТКАЗАНО"
            try:
                await query.edit_message_text(
                    f"{query.message.text}\n\n"
                    "━━━━━━━━━━━━━━━━━\n"
                    f"⚠️ Уже обработано: {status_label}\n"
                    f"👮 {existing_reviewer}"
                )
            except Exception:
                pass
        return False
    
    req = get_change_request(req_id)
    target_id = req['user_id']
    target_data = get_user_data(target_id)
    reviewer_name = get_admin_nick(reviewer_id)
    
    applied_text = ""
    if new_status == 'approved':
        if req['request_type'] == 'rank':
            try:
                new_rank_int = int(req['requested_value'])
                if update_user_rank(target_id, new_rank_int):
                    applied_text = f"⭐ Новый ранг: {RANKS.get(new_rank_int, RANKS[0])['name']}"
                    log_action(reviewer_id, 'rank_change', target_id, f"{req['current_value']} → {new_rank_int} (заявка #{req_id})")
            except ValueError:
                applied_text = "⚠️ Не удалось применить ранг (некорректное значение)."
        elif req['request_type'] == 'dept':
            if update_user_department(target_id, req['requested_value']):
                applied_text = f"📁 Новый отдел: {req['requested_value']}"
                log_action(reviewer_id, 'dept_change', target_id, f"{req['current_value']} → {req['requested_value']} (заявка #{req_id})")
    log_action(reviewer_id, 'request_' + new_status, target_id,
               f"#{req_id} {req['request_type']}" + (f" — {comment}" if comment else ""))
    
    # Обновляем сообщение у модератора (если есть query)
    status_label = "✅ ОДОБРЕНО" if new_status == 'approved' else "❌ ОТКАЗАНО"
    extra = applied_text or ""
    if new_status == 'rejected' and comment:
        extra = (extra + "\n" if extra else "") + f"📝 Причина: {comment}"
    if query:
        try:
            await query.edit_message_text(
                f"{query.message.text}\n\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"{status_label}\n"
                f"👮 Модератор: {reviewer_name}\n"
                f"📅 {now_msk_str()}\n"
                + extra
            )
        except Exception as e:
            logger.debug(f"request decision edit failed: {e}")
    
    # Уведомление юзеру
    if req['request_type'] == 'rank':
        try:
            cur_lbl = RANKS[int(req['current_value'])]['name']
            new_lbl = RANKS[int(req['requested_value'])]['name']
        except Exception:
            cur_lbl, new_lbl = req['current_value'], req['requested_value']
        what = f"⭐ Ранг: {cur_lbl} → {new_lbl}"
    else:
        what = f"📁 Отдел: {req['current_value']} → {req['requested_value']}"
    
    if new_status == 'approved':
        user_msg = (
            f"✅ ЗАЯВКА #{req_id} ОДОБРЕНА\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"{what}\n"
            f"👮 Решение: {reviewer_name}"
        )
    else:
        user_msg = (
            f"❌ ЗАЯВКА #{req_id} ОТКЛОНЕНА\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"{what}\n"
            f"👮 Решение: {reviewer_name}"
        )
        if comment:
            user_msg += f"\n📝 Причина: {comment}"
    await notify_user(context, target_id, user_msg)
    return True


async def request_decision_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обрабатывает 'rqst:appr:<id>' и 'rqst:rej:<id>' — одним кликом."""
    query = update.callback_query
    await query.answer()
    reviewer_id = query.from_user.id

    if not has_permission(reviewer_id, 'warn'):
        try:
            await query.edit_message_text("❌ Решения по заявкам — только с 5 ранга.")
        except Exception:
            pass
        return

    parts = (query.data or "").split(":")
    if len(parts) != 3:
        return
    action = parts[1]
    try:
        req_id = int(parts[2])
    except ValueError:
        return

    req = get_change_request(req_id)
    if not req:
        await query.edit_message_text("❌ Заявка не найдена.")
        return

    if req['user_id'] == reviewer_id:
        await query.answer("Нельзя обрабатывать свою же заявку.", show_alert=True)
        return

    if req['status'] != 'pending':
        existing_reviewer = get_admin_nick(req['reviewer_id']) if req['reviewer_id'] else "—"
        status_label = "✅ ОДОБРЕНО" if req['status'] == 'approved' else "❌ ОТКАЗАНО"
        try:
            await query.edit_message_text(
                f"{query.message.text}\n\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"⚠️ Уже обработано: {status_label}\n"
                f"👮 {existing_reviewer}\n"
                f"📅 {req['decided_at']}"
            )
        except Exception:
            pass
        return

    new_status = 'approved' if action == 'appr' else 'rejected'
    await _apply_request_decision(context, query, req_id, reviewer_id, new_status, "")


