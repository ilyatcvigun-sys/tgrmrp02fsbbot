async def weekly_rank_check(context: ContextTypes.DEFAULT_TYPE):
    """Еженедельная проверка рангов и отделов (воскресенье 8:00 МСК)"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        "SELECT user_id, game_nick, rank, department "
        "FROM users WHERE ban_status = 'Нет' AND bot_blocked = 'Нет'"
    )
    users = c.fetchall()
    conn.close()

    sent = 0
    for u in users:
        user_id, nick, rank, dept = u
        text = _weekly_main_text(nick, rank or 0, dept or "Не назначен")
        kb = _weekly_main_keyboard()
        try:
            await context.bot.send_message(chat_id=user_id, text=text, reply_markup=kb)
            sent += 1
            await asyncio.sleep(0.3)  # троттлинг чтобы не упереться в флуд-лимит
        except Exception as e:
            logger.debug(f"weekly_rank_check send to {user_id} failed: {e}")

    if CONFERENCE_CHAT_ID:
        try:
            await context.bot.send_message(
                chat_id=CONFERENCE_CHAT_ID,
                text=f"📢 Отправлена еженедельная проверка ({sent} получателей).",
            )
        except Exception:
            pass


# ----------- Callback-хэндлер для главного меню еженедельной проверки -----------

async def weekly_check_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обрабатывает все нажатия с префиксом 'wkc:'."""
    query = update.callback_query
    await query.answer()
    data = query.data or ""
    user_id = query.from_user.id
    user_data = get_user_data(user_id)
    if not user_data:
        try:
            await query.edit_message_text("❌ Вы не зарегистрированы в боте.")
        except Exception:
            pass
        return

    # === Главные действия ===
    if data == "wkc:ok":
        await query.edit_message_text(
            "✅ Подтверждено\n"
            "━━━━━━━━━━━━━━━━━\n"
            "Ваш ранг и отдел оставлены без изменений.\n"
            "Спасибо за подтверждение!"
        )
        return

    if data == "wkc:back":
        await query.edit_message_text(
            _weekly_main_text(user_data['nick'], user_data['rank'] or 0, user_data['department']),
            reply_markup=_weekly_main_keyboard(),
        )
        return

    if data == "wkc:rank":
        await query.edit_message_text(
            "🔄 ВЫБЕРИТЕ ЖЕЛАЕМЫЙ РАНГ\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"⭐ Сейчас: {RANKS.get(user_data['rank'] or 0, RANKS[0])['name']}\n\n"
            "После выбора заявка уйдёт администрации (5+).",
            reply_markup=_rank_picker_keyboard(),
        )
        return

    if data == "wkc:dept":
        await query.edit_message_text(
            "🔄 ВЫБЕРИТЕ ЖЕЛАЕМЫЙ ОТДЕЛ\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"📁 Сейчас: {user_data['department']}\n\n"
            "После выбора заявка уйдёт администрации (5+).",
            reply_markup=_dept_picker_keyboard(),
        )
        return

    # === Выбор конкретного ранга ===
    if data.startswith("wkc:rank:"):
        try:
            new_rank = int(data.split(":")[2])
        except (ValueError, IndexError):
            await query.edit_message_text("❌ Некорректный выбор.")
            return
        if new_rank not in RANKS or new_rank >= 7:
            await query.edit_message_text("❌ Этот ранг недоступен для выбора.")
            return
        current_rank = user_data['rank'] or 0
        if new_rank == current_rank:
            await query.edit_message_text(
                f"ℹ️ У вас уже этот ранг: {RANKS[current_rank]['name']}\n"
                "Заявка не создана."
            )
            return
        req_id = create_change_request(user_id, 'rank', str(current_rank), str(new_rank))
        await query.edit_message_text(
            f"✅ ЗАЯВКА #{req_id} ОТПРАВЛЕНА\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"⭐ Сейчас: {RANKS[current_rank]['name']}\n"
            f"⭐ Запрошен: {RANKS[new_rank]['name']}\n"
            "━━━━━━━━━━━━━━━━━\n"
            "Ожидайте решения 5+."
        )
        await _broadcast_request_to_mods(context, req_id)
        return

    # === Выбор конкретного отдела ===
    if data.startswith("wkc:dept:"):
        try:
            idx = int(data.split(":")[2])
        except (ValueError, IndexError):
            await query.edit_message_text("❌ Некорректный выбор.")
            return
        depts = get_departments()
        if idx < 0 or idx >= len(depts):
            await query.edit_message_text("❌ Этот отдел больше недоступен.")
            return
        new_dept = depts[idx]
        current_dept = user_data['department'] or "Не назначен"
        if new_dept == current_dept:
            await query.edit_message_text(
                f"ℹ️ Вы уже в этом отделе:\n📁 {current_dept}\nЗаявка не создана."
            )
            return
        req_id = create_change_request(user_id, 'dept', current_dept, new_dept)
        await query.edit_message_text(
            f"✅ ЗАЯВКА #{req_id} ОТПРАВЛЕНА\n"
            "━━━━━━━━━━━━━━━━━\n"
            f"📁 Сейчас: {current_dept}\n"
            f"📁 Запрошен: {new_dept}\n"
            "━━━━━━━━━━━━━━━━━\n"
            "Ожидайте решения 5+."
        )
        await _broadcast_request_to_mods(context, req_id)
        return

    # Неизвестный wkc-callback
    await query.edit_message_text("❌ Неизвестное действие.")


