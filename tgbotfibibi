def reopen_report(report_id: int, reopened_by: int) -> dict:
    """
    Возвращает жалобу обратно в pending для перепроверки.
    - Сохраняет снимок предыдущего вердикта в reports.previous_verdicts (JSON-список).
    - Инкрементирует reopened_count.
    - Возвращает старые данные (для audit_log).
    """
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    c.execute(
        '''SELECT status, moderator_id, verdict, moderator_comment, resolved_at,
                  reopened_count, previous_verdicts
           FROM reports WHERE id = ?''',
        (report_id,),
    )
    row = c.fetchone()
    if not row:
        conn.close()
        return None
    snapshot = {
        'status': row['status'],
        'moderator_id': row['moderator_id'],
        'verdict': row['verdict'],
        'comment': row['moderator_comment'],
        'resolved_at': row['resolved_at'],
    }
    # Достраиваем previous_verdicts: парсим уже хранящийся JSON, дописываем снимок
    try:
        history = json.loads(row['previous_verdicts']) if row['previous_verdicts'] else []
    except Exception:
        history = []
    history.append({
        'moderator_id': snapshot['moderator_id'],
        'verdict': snapshot['verdict'],
        'comment': snapshot['comment'],
        'resolved_at': snapshot['resolved_at'],
        'reopened_by': reopened_by,
        'reopened_at': now_msk_str(),
    })
    new_count = (row['reopened_count'] or 0) + 1
    c.execute(
        '''UPDATE reports
           SET status = 'pending',
               moderator_id = NULL,
               verdict = NULL,
               moderator_comment = NULL,
               resolved_at = '',
               reopened_count = ?,
               previous_verdicts = ?
           WHERE id = ?''',
        (new_count, json.dumps(history, ensure_ascii=False), report_id),
    )
    conn.commit()
    conn.close()
    return snapshot

def delete_report(report_id: int) -> dict:
    """Физически удаляет запись и возвращает её снимок для audit_log."""
    report = get_report(report_id)
    if not report:
        return None
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('DELETE FROM reports WHERE id = ?', (report_id,))
    conn.commit()
    conn.close()
    return report

def get_report(report_id: int) -> dict:
    """Получение жалобы"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT * FROM reports WHERE id = ?', (report_id,))
    row = c.fetchone()
    conn.close()
    if row:
        # Парсим media_files (если столбец есть и не пустой)
        media = []
        if len(row) >= 15 and row[14]:
            try:
                media = json.loads(row[14])
            except Exception:
                media = []
        # Парсим previous_verdicts
        prev_verdicts = []
        if len(row) >= 17 and row[16]:
            try:
                prev_verdicts = json.loads(row[16])
            except Exception:
                prev_verdicts = []
        reopened_count = (row[15] if len(row) >= 16 and row[15] is not None else 0)
        return {
            "id": row[0],
            "reporter_id": row[1],
            "reporter_nick": row[2],
            "violator_nick": row[3],
            "faction": row[4],
            "violation": row[5],
            "evidence": row[6],
            "command": row[7],
            "status": row[8],
            "moderator_id": row[9],
            "moderator_comment": row[10],
            "verdict": row[11],
            "created_at": row[12],
            "resolved_at": row[13],
            "media_files": media,
            "reopened_count": reopened_count,
            "previous_verdicts": prev_verdicts,
        }
    return None


async def forward_report_media(context: ContextTypes.DEFAULT_TYPE, chat_id: int, media_files: list):
    """
    Отправляет прикреплённые к жалобе медиа в указанный чат.
    Каждый файл отправляется в правильный метод (photo/video/document/voice/etc).
    """
    if not media_files:
        return
    for m in media_files:
        kind = m.get('type', '')
        fid = m.get('file_id', '')
        cap = m.get('caption') or None
        if not fid:
            continue
        try:
            if kind == 'photo':
                await context.bot.send_photo(chat_id, fid, caption=cap)
            elif kind == 'video':
                await context.bot.send_video(chat_id, fid, caption=cap)
            elif kind == 'document':
                await context.bot.send_document(chat_id, fid, caption=cap)
            elif kind == 'voice':
                await context.bot.send_voice(chat_id, fid, caption=cap)
            elif kind == 'video_note':
                await context.bot.send_video_note(chat_id, fid)
            elif kind == 'audio':
                await context.bot.send_audio(chat_id, fid, caption=cap)
            elif kind == 'animation':
                await context.bot.send_animation(chat_id, fid, caption=cap)
        except Exception as e:
            logger.debug(f"forward_report_media: {kind} {fid} → chat {chat_id}: {e}")
        await asyncio.sleep(0.05)

