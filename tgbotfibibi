async def adepartment(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Управление отделами: add/remove/rename/list"""
    user_id = update.effective_user.id
    if not has_permission(user_id, 'manage_ranks', 'adepartment'):
        await update.message.reply_text("❌ С 5 ранга.")
        return
    
    if not context.args:
        await update.message.reply_text(
            "📁 УПРАВЛЕНИЕ ОТДЕЛАМИ\n"
            "━━━━━━━━━━━━━━━━━\n"
            "/adepartment list — список отделов\n"
            "/adepartment find <номер|название> — участники отдела\n"
            "/adepartment add <название>\n"
            "/adepartment remove <номер>\n"
            "/adepartment rename <номер> <новое название>"
        )
        return
    
    action = context.args[0].lower()
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    
    if action == 'add':
        if len(context.args) < 2:
            await update.message.reply_text("❌ /adepartment add Название")
            conn.close()
            return
        name = ' '.join(context.args[1:])
        try:
            c.execute('INSERT INTO departments (name) VALUES (?)', (name,))
            conn.commit()
            await update.message.reply_text(f"✅ Отдел '{name}' добавлен.")
        except:
            await update.message.reply_text("❌ Такой отдел уже есть.")
    
    elif action == 'remove':
        if len(context.args) < 2:
            await update.message.reply_text("❌ /adepartment remove Номер")
            conn.close()
            return
        try:
            num = int(context.args[1])
        except:
            await update.message.reply_text("❌ Укажите номер.")
            conn.close()
            return
        depts = get_departments()
        if 1 <= num <= len(depts):
            name = depts[num - 1]
            c.execute('DELETE FROM departments WHERE name = ?', (name,))
            conn.commit()
            await update.message.reply_text(f"✅ Отдел '{name}' удалён.")
        else:
            await update.message.reply_text("❌ Неверный номер.")
    
    elif action == 'rename':
        if len(context.args) < 3:
            await update.message.reply_text("❌ /adepartment rename Номер НовоеНазвание")
            conn.close()
            return
        try:
            num = int(context.args[1])
        except:
            await update.message.reply_text("❌ Укажите номер.")
            conn.close()
            return
        depts = get_departments()
        if 1 <= num <= len(depts):
            old_name = depts[num - 1]
            new_name = ' '.join(context.args[2:])
            c.execute('UPDATE users SET department = ? WHERE department = ?', (new_name, old_name))
            c.execute('UPDATE departments SET name = ? WHERE name = ?', (new_name, old_name))
            conn.commit()
            await update.message.reply_text(f"✅ '{old_name}' → '{new_name}'")
        else:
            await update.message.reply_text("❌ Неверный номер.")
    
    elif action == 'list':
        depts = get_departments()
        text = "📁 ОТДЕЛЫ:\n━━━━━━━━━━━━━━━━━\n"
        for i, d in enumerate(depts, 1):
            text += f"{i}. {d}\n"
        await update.message.reply_text(text)
    
    elif action == 'find':
        if len(context.args) < 2:
            await update.message.reply_text(
                "❌ Использование: /adepartment find <номер|название>\n"
                "Пример: /adepartment find 3\n"
                "Пример: /adepartment find куратор"
            )
            conn.close()
            return
        
        arg = ' '.join(context.args[1:]).strip()
        depts = get_departments()
        target_dept = None
        
        # 1) Пробуем как номер
        if arg.isdigit():
            num = int(arg)
            if 1 <= num <= len(depts):
                target_dept = depts[num - 1]
        
        # 2) Иначе поиск по подстроке (регистронезависимо)
        if not target_dept:
            lower = arg.lower()
            matches = [d for d in depts if lower in d.lower()]
            if len(matches) == 1:
                target_dept = matches[0]
            elif len(matches) > 1:
                await update.message.reply_text(
                    f"❌ Найдено несколько отделов по запросу «{arg}»:\n\n"
                    + "\n".join(f"• {d}" for d in matches)
                    + "\n\nУточните название или используйте номер."
                )
                conn.close()
                return
            else:
                await update.message.reply_text(f"❌ Отдел по запросу «{arg}» не найден.")
                conn.close()
                return
        
        # Тянем участников: сортируем по рангу убыванию, потом по нику
        c.execute(
            '''SELECT user_id, game_nick, callsign, rank, ban_status
               FROM users WHERE department = ?
               ORDER BY rank DESC, game_nick''',
            (target_dept,),
        )
        members = c.fetchall()
        
        if not members:
            await update.message.reply_text(
                "📁 ОТДЕЛ\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"📁 {target_dept}\n"
                "━━━━━━━━━━━━━━━━━\n"
                "В отделе никого нет."
            )
            conn.close()
            return
        
        active = [m for m in members if (m[4] or 'Нет') == 'Нет']
        lines = [
            f"📁 УЧАСТНИКИ ОТДЕЛА",
            "━━━━━━━━━━━━━━━━━",
            f"📁 {target_dept}",
            f"👥 Всего: {len(members)} | ✅ Активных: {len(active)}",
            "━━━━━━━━━━━━━━━━━",
        ]
        for m in members[:50]:
            uid, nick, callsign, rk, ban_status = m
            ban_mark = "  🚫" if (ban_status or 'Нет') != 'Нет' else ""
            lines.append(
                f"👤 {nick} | 📻 {callsign}{ban_mark}\n"
                f"   ⭐ {RANKS.get(rk or 0, RANKS[0])['name']}\n"
                f"   🆔 {uid}"
            )
        if len(members) > 50:
            lines.append(f"\n…и ещё {len(members) - 50}.")
        await update.message.reply_text("\n".join(lines))
    
    else:
        await update.message.reply_text("❌ Действие: add, remove, rename, list, find")
    
    conn.close()

