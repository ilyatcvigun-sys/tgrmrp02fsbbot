async def aunwarn(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    if not has_permission(user_id, 'warn'):
        await update.message.reply_text("❌ С 5 ранга.")
        return
    target_id = extract_user_id(update, context)
    if not target_id and context.args:
        target_id = extract_user_id(update, context, context.args[0])
    if not target_id:
        await update.message.reply_text("❌ /aunwarn @user")
        return
    if isinstance(target_id, str):
        resolved = await resolve_user_id(update, context, target_id)
        if resolved:
            target_id = resolved
        else:
            await update.message.reply_text("❌ Не удалось найти.")
            return
    target_data = get_user_data(target_id)
    if not target_data:
        await update.message.reply_text("❌ Пользователь не найден.")
        return
    current_warns = target_data['warns']
    if current_warns == "0/0":
        await update.message.reply_text(f"❌ У {target_data['callsign']} нет предов.")
        return
    parts = current_warns.split('/')
    verbal = int(parts[0]) if len(parts) == 2 else 0
    written = int(parts[1]) if len(parts) == 2 else 0
    if written > 0:
        written -= 1
        removed_type = "письменное"
        # Удаляем последнее письменное из таблицы
        conn = sqlite3.connect(DB_FILE)
        cursor = conn.cursor()
        cursor.execute('DELETE FROM warnings WHERE user_id = ? AND warn_type = "Письменное" AND id = (SELECT id FROM warnings WHERE user_id = ? AND warn_type = "Письменное" ORDER BY id DESC LIMIT 1)', (target_id, target_id))
        conn.commit()
    elif verbal > 0:
        verbal -= 1
        removed_type = "устное"
        conn = sqlite3.connect(DB_FILE)
        cursor = conn.cursor()
        cursor.execute('DELETE FROM warnings WHERE user_id = ? AND warn_type = "Устное" AND id = (SELECT id FROM warnings WHERE user_id = ? AND warn_type = "Устное" ORDER BY id DESC LIMIT 1)', (target_id, target_id))
        conn.commit()
    else:
        await update.message.reply_text("❌ Ошибка.")
        return
    new_warns = f"{verbal}/{written}"
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('UPDATE users SET warns = ? WHERE user_id = ?', (new_warns, target_id))
    conn.commit()
    conn.close()
    await update.message.reply_text(f"✅ Снят {removed_type} пред\n👤 {target_data['callsign']}\n⚠️ Было: {current_warns} → Стало: {new_warns}")
    try:
        issuer_data = get_user_data(user_id)
        issuer_name = issuer_data['nick'] if issuer_data else "Администратор"
        await context.bot.send_message(chat_id=target_id, text=f"✅ С вас снят пред\n⚠️ Было: {current_warns} → Стало: {new_warns}\n👮 Снял: {issuer_name}")
    except:
        pass

