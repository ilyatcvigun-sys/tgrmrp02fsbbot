def is_private_chat(update: Update) -> bool:
    return update.effective_chat.type == 'private'

def extract_user_id(update: Update, context: ContextTypes.DEFAULT_TYPE, text: str):
    """Извлечение user_id из разных форматов: ID, @username, ссылка, ответ"""
    text = text.strip()
    
    # Числовой ID
    if text.isdigit():
        return int(text)
    
    # @username
    if text.startswith('@'):
        username = text[1:]
        result = find_user_by_username(username)
        if result:
            return result
        return None
    
    # Ссылка https://t.me/username
    if 't.me/' in text:
        username = text.split('t.me/')[-1].split()[0].strip().replace('@', '')
        if username:
            result = find_user_by_username(username)
            if result:
                return result
        return None
    
    # Ответ на сообщение
    if update.message and update.message.reply_to_message:
        return update.message.reply_to_message.from_user.id
    
    return None

def find_user_by_username(username):
    """Поиск одного пользователя по username/нику/позывному"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('''
        SELECT user_id FROM users 
        WHERE game_nick LIKE ? OR callsign LIKE ?
    ''', (f'%{username}%', f'%{username}%'))
    
    results = cursor.fetchall()
    conn.close()
    
    if len(results) == 1:
        return results[0][0]
    elif len(results) > 1:
        return -1  # Несколько пользователей
    return None

def find_users_by_username(username):
    """Поиск всех пользователей по username"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('''
        SELECT user_id, game_nick, callsign, token, rank 
        FROM users 
        WHERE game_nick LIKE ? OR callsign LIKE ?
    ''', (f'%{username}%', f'%{username}%'))
    
    results = cursor.fetchall()
    conn.close()
    return results

