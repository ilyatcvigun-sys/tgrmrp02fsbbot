async def gban_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    user_data = get_user_data(user_id)
    if not user_data or user_data['rank'] < 6:
        await update.message.reply_text("❌ Только генералы.")
        return
    
    if not context.args:
        await update.message.reply_text("❌ /gban @user причина\nИли ответьте на сообщение: /gban причина")
        return
    
    # Если ответ на сообщение
    target_id = extract_user_id(update, context)
    
    if target_id:
        reason = ' '.join(context.args) if context.args else "Без причины"
    else:
        target_id = extract_user_id(update, context, context.args[0])
        reason = ' '.join(context.args[1:]) if len(context.args) > 1 else "Без причины"
    
    if target_id is None:
        await update.message.reply_text("❌ Не найден.")
        return
    if target_id == -1:
        username = context.args[0].replace('@', '')
        users = find_users_by_nickname(username)
        text = "🔍 Найдено несколько:\n\n"
        for u in users:
            text += f"🆔 {u[0]} | {u[1]} | {u[2]}\n"
        text += "\nУточните: /gban ID причина"
        await update.message.reply_text(text)
        return
    
    add_gban(target_id, reason, user_id)
    target_data = get_user_data(target_id)
    target_name = target_data['callsign'] if target_data else f"User {target_id}"
    await update.message.reply_text(f"🚫 БАН!\n👤 {target_name}\n📝 {reason}")

