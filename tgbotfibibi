# Добавление предупреждения
def add_warning_excel(user_id, issuer_id, reason):
    try:
        wb = openpyxl.load_workbook(EXCEL_FILE)
        ws = wb["Пользователи"]
        ws_warns = wb["Предупреждения"]
        
        for row in ws.iter_rows(min_row=2):
            if row[1].value == user_id:
                current_warns = str(row[7].value)
                warn_parts = current_warns.split('/')
                
                if len(warn_parts) != 2:
                    current_verbal = 0
                    current_written = 0
                else:
                    try:
                        current_verbal = int(warn_parts[0])
                        current_written = int(warn_parts[1])
                    except ValueError:
                        current_verbal = 0
                        current_written = 0
                
                # Проверка лимитов
                if current_verbal < 2:
                    current_verbal += 1
                    warn_type = "Устное"
                elif current_written < 3:
                    current_written += 1
                    warn_type = "Письменное"
                else:
                    wb.close()
                    return False, "Достигнут лимит предупреждений"
                
                new_warns = f"{current_verbal}/{current_written}"
                row[7].value = new_warns
                
                # Запись в лист предупреждений
                user_nick = row[2].value
                ws_warns.append([ws_warns.max_row, user_id, user_nick, warn_type,
                               new_warns, reason, datetime.now().strftime("%Y-%m-%d %H:%M:%S"), issuer_id])
                
                wb.save(EXCEL_FILE)
                wb.close()
                return True, f"Выдано {warn_type.lower()} предупреждение ({new_warns})"
        
        wb.close()
        return False, "Пользователь не найден"
    except Exception as e:
        logger.error(f"Ошибка добавления предупреждения: {e}")
        return False, f"Ошибка: {str(e)}"

