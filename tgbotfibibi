# ============ ОБРАБОТЧИК КНОПОК В ЛС ============

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text
    user_id = update.effective_user.id
    
    gban = check_gban(user_id)
    if gban['is_banned']:
        await update.message.reply_text("🚫 Вы в ЧС!")
        return
    
    if text == "📝 Регистрация":
        return await start_registration(update, context)
    elif text == "👤 Информация":
        await ainfo(update, context)
    elif text == "🔍 Проверить ЧС":
        await check_gban_command(update, context)
    elif text == "ℹ️ Помощь":
        await ahelp(update, context)
    elif text == "📋 Список участников":
        await auserlist(update, context)
    elif text == "📝 Подать жалобу":
        return await areport_start(update, context)

