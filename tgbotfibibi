async def block_gate(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Gate: блокирует ВСЮ обработку апдейтов от юзеров, отключённых от бота (bot_blocked='Да'),
    но только в личке. В группе мы продолжаем модерировать их штатно — это другая история.
    Регистрируется в group=-2 (раньше всех остальных). Использует ApplicationHandlerStop,
    чтобы прервать дальнейший пайплайн.
    """
    user = update.effective_user
    chat = update.effective_chat
    if not user or not chat:
        return
    if chat.type != 'private':
        return
    if user.id in blocked_users:
        # Молча игнорируем. Один раз можно отправить напоминание, но мы намеренно не шумим,
        # чтобы не давать заблокированному способа триггерить ответ.
        logger.info(f"block_gate: dropping update from blocked user {user.id}")
        raise ApplicationHandlerStop


async def track_username(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Тихо сохраняет @username отправителя в БД при ЛЮБОМ апдейте.
    Это позволяет потом резолвить @username локально, без запросов в Telegram API.
    Хендлер регистрируется в group=-1 (выполняется первым) и НЕ блокирует обработку:
    он не возвращает ничего, остальные хендлеры в group=0 и выше всё равно сработают.
    """
    try:
        user = update.effective_user
        if user and user.username and user.id:
            update_tg_username(user.id, user.username)
    except Exception as e:
        logger.debug(f"track_username error: {e}")

async def track_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Сбор сообщений из конференции для анализа настроения"""
    if not update.message or not update.message.text:
        return
    if update.effective_chat.id != CONFERENCE_CHAT_ID:
        # Лог-намёк, если CONFERENCE_CHAT_ID настроен не на ту конфу
        logger.debug(
            f"track_message: ignoring chat {update.effective_chat.id} (expected {CONFERENCE_CHAT_ID})"
        )
        return
    text = update.message.text.strip()
    # Пропускаем команды бота — они шумят и портят анализ
    if text.startswith('/'):
        return
    # Ограничиваем длину одного сообщения, чтобы один длинный пост не съел всю выборку
    if len(text) > 500:
        text = text[:500] + "…"
    # Дедуп подряд идущих одинаковых
    if chat_messages and chat_messages[-1] == text:
        return
    chat_messages.append(text)
    if len(chat_messages) > 100:
        chat_messages.pop(0)
    logger.debug(f"track_message: buffer={len(chat_messages)}/100")


