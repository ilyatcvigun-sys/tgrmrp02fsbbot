# ============ ИДЕИ / ПРЕДЛОЖЕНИЯ ПО УЛУЧШЕНИЮ БОТА ============
# По образцу weekly_rank_check: запускается опрос → юзеры получают DM с кнопками
# «Есть идеи» / «Нет идей». «Есть идеи» переводит юзера в режим ожидания текста
# в ЛС. После получения идеи бот шлёт её главному админу с кнопками решения.

DEFAULT_IDEA_PROMPT = (
    "💡 ПРЕДЛОЖЕНИЯ ПО УЛУЧШЕНИЮ БОТА\n"
    "━━━━━━━━━━━━━━━━━\n"
    "Ваше мнение очень важно для нас)\n"
"
)


def _idea_get_main_admins() -> list:
    """Куда слать DM-уведомления про идеи. Возвращает список user_id."""
    if isinstance(MAIN_ADMIN_IDS, (list, set, tuple)):
        return list(MAIN_ADMIN_IDS)
    return [MAIN_ADMIN_IDS] if MAIN_ADMIN_IDS else []


def _idea_kb_prompt(poll_id: int) -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup([[
        InlineKeyboardButton("💡 Есть идеи", callback_data=f"idea:yes:{poll_id}"),
        InlineKeyboardButton("✋ Нет идей", callback_data=f"idea:no:{poll_id}"),
    ]])


def _idea_kb_decision(idea_id: int) -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup([
        [
            InlineKeyboardButton("✅ Принять", callback_data=f"idea:approve:{idea_id}"),
            InlineKeyboardButton("❌ Отклонить", callback_data=f"idea:reject:{idea_id}"),
        ],
        [InlineKeyboardButton("🚧 В работу", callback_data=f"idea:implement:{idea_id}")],
    ])


def _idea_get(idea_id: int) -> dict:
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    c.execute('SELECT * FROM ideas WHERE id = ?', (idea_id,))
    row = c.fetchone()
    conn.close()
    return dict(row) if row else None


def _idea_create_response(poll_id: int, user_id: int, response: str) -> int:
    """
    Записывает/обновляет ответ юзера на опрос. Один user на один poll даёт один ответ —
    если ответ был, обновляем; иначе создаём.
    Возвращает id записи.
    """
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        'SELECT id FROM ideas WHERE poll_id = ? AND user_id = ? AND text IS NULL LIMIT 1',
        (poll_id, user_id),
    )
    row = c.fetchone()
    if row:
        idea_id = row[0]
        c.execute('UPDATE ideas SET response = ?, created_at = ? WHERE id = ?',
                  (response, now_msk_str(), idea_id))
    else:
        c.execute(
            '''INSERT INTO ideas (poll_id, user_id, response, created_at)
               VALUES (?, ?, ?, ?)''',
            (poll_id, user_id, response, now_msk_str()),
        )
        idea_id = c.lastrowid
    conn.commit()
    conn.close()
    return idea_id


def _idea_finalize_text(idea_id: int, text: str):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''UPDATE ideas SET text = ?, response = 'submitted', status = 'submitted',
           created_at = ? WHERE id = ?''',
        (text, now_msk_str(), idea_id),
    )
    conn.commit()
    conn.close()


def _idea_set_decision(idea_id: int, status: str, decided_by: int, comment: str):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''UPDATE ideas SET status = ?, decided_by = ?, decision_comment = ?, decided_at = ?
           WHERE id = ?''',
        (status, decided_by, comment, now_msk_str(), idea_id),
    )
    conn.commit()
    conn.close()


def _idea_create_submission(user_id: int, text: str) -> int:
    """Создание идеи без привязки к опросу (через /aidea_submit)."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        '''INSERT INTO ideas (poll_id, user_id, response, text, status, created_at)
           VALUES (NULL, ?, 'submitted', ?, 'submitted', ?)''',
        (user_id, text, now_msk_str()),
    )
    idea_id = c.lastrowid
    conn.commit()
    conn.close()
    return idea_id


def _format_idea_card(idea: dict, *, for_admin: bool) -> str:
    """Карточка идеи: для админа полная, для автора без чувствительных деталей."""
    author = get_user_data(idea['user_id'])
    author_name = author['nick'] if author else f"id {idea['user_id']}"
    head = f"💡 ИДЕЯ #{idea['id']}"
    status = idea.get('status') or '—'
    status_emoji = {
        'submitted': '⏳ ожидает',
        'approved': '✅ принята',
        'rejected': '❌ отклонена',
        'implemented': '🚧 в работе',
    }.get(status, status)
    head += f" — {status_emoji}"
    
    body = f"{head}\n━━━━━━━━━━━━━━━━━\n"
    body += f"👤 Автор: {author_name}"
    if for_admin and author and author.get('callsign'):
        body += f" ({author['callsign']})"
    body += f"\n📅 Подано: {idea.get('created_at') or '—'}\n"
    if idea.get('poll_id'):
        body += f"📋 Опрос: #{idea['poll_id']}\n"
    body += "━━━━━━━━━━━━━━━━━\n"
    body += idea.get('text') or "(пусто)"
    if idea.get('status') and idea['status'] != 'submitted':
        decider = get_user_data(idea['decided_by']) if idea.get('decided_by') else None
        decider_name = decider['nick'] if decider else (f"id {idea['decided_by']}" if idea.get('decided_by') else "—")
        body += f"\n━━━━━━━━━━━━━━━━━\n"
        body += f"👮 Решил: {decider_name}\n"
        body += f"📅 {idea.get('decided_at') or '—'}\n"
        if idea.get('decision_comment'):
            body += f"💬 {idea['decision_comment']}"
    return body.rstrip()


async def aideas_start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Запустить новый опрос «есть ли у тебя идеи». Рассылка в ЛС всем зарегистрированным.
    /aideas_start             — стандартный текст
    /aideas_start <кастомный текст>
    """
    user_id = update.effective_user.id
    if not has_permission(user_id, 'gban', 'aideas_start'):
        await update.message.reply_text("❌ Команда доступна со спецдоступом или индивидуальным грантом.")
        return
    
    # Кастомный текст после команды
    raw = update.message.text or ""
    space_idx = raw.find(' ')
    nl_idx = raw.find('\n')
    cut = -1
    for idx in (space_idx, nl_idx):
        if idx >= 0 and (cut < 0 or idx < cut):
            cut = idx
    prompt = raw[cut:].strip() if cut > 0 else ""
    
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute(
        'INSERT INTO idea_polls (started_by, prompt, status, started_at) VALUES (?, ?, "active", ?)',
        (user_id, prompt or None, now_msk_str()),
    )
    poll_id = c.lastrowid
    c.execute(
        'SELECT user_id FROM users WHERE bot_blocked = "Нет"'
    )
    targets = [r[0] for r in c.fetchall()]
    conn.close()
    
    prompt_text = prompt if prompt else DEFAULT_IDEA_PROMPT
    if not prompt_text.startswith("💡"):
        prompt_text = "💡 ПРЕДЛОЖЕНИЯ ПО УЛУЧШЕНИЮ БОТА\n━━━━━━━━━━━━━━━━━\n" + prompt_text
    
    kb = _idea_kb_prompt(poll_id)
    sent = 0
    failed = 0
    for uid in targets:
        try:
            await context.bot.send_message(chat_id=uid, text=prompt_text, reply_markup=kb)
            sent += 1
        except Exception as e:
            failed += 1
            logger.debug(f"aideas_start DM to {uid}: {e}")
        await asyncio.sleep(0.05)
    
    log_action(user_id, 'ideas_poll_started', None, f"#{poll_id}: sent={sent}, failed={failed}")
    await update.message.reply_text(
        f"💡 ОПРОС #{poll_id} ЗАПУЩЕН\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"📤 Доставлено: {sent}\n"
        f"❌ Не дошло: {failed} (заблокировали бота)\n\n"
        f"Ответы будут приходить вам в ЛС по мере поступления.\n"
        f"Сводка: /aideas"
    )


async def idea_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработка кнопок: idea:yes/no/approve/reject/implement:<id>"""
    query = update.callback_query
    parts = (query.data or "").split(":")
    if len(parts) != 3:
        await query.answer()
        return
    action = parts[1]
    try:
        target_id = int(parts[2])
    except ValueError:
        await query.answer()
        return
    
    user_id = query.from_user.id
    user_data = get_user_data(user_id)
    if not user_data and action in ('yes', 'no'):
        await query.answer("Вы не зарегистрированы.", show_alert=True)
        return
    
    # ===== Ответы юзера на опрос =====
    if action == 'no':
        # target_id = poll_id
        idea_id = _idea_create_response(target_id, user_id, 'no_idea')
        await query.answer("Спасибо! Хорошего дня.")
        try:
            await query.edit_message_text(
                "💡 СПАСИБО!\n"
                "━━━━━━━━━━━━━━━━━\n"
                "Если идеи появятся — можешь в любой момент написать\n"
                "/aidea_submit <текст>"
            )
        except Exception:
            pass
        # DM админам
        for admin_id in _idea_get_main_admins():
            try:
                await context.bot.send_message(
                    chat_id=admin_id,
                    text=(
                        f"💡 ОПРОС #{target_id}: ответ\n"
                        f"👤 {user_data['nick']} ({user_data['callsign']}) — ✋ нет идей"
                    ),
                )
            except Exception:
                pass
        return
    
    if action == 'yes':
        # target_id = poll_id
        idea_id = _idea_create_response(target_id, user_id, 'pending_input')
        # Ставим state для приёма текста
        context.user_data['pending_idea_input'] = idea_id
        await query.answer("Опиши идею следующим сообщением.")
        try:
            await query.edit_message_text(
                "💡 РАССКАЖИ ПОДРОБНЕЕ\n"
                "━━━━━━━━━━━━━━━━━\n"
                "Опиши свою идею следующим сообщением.\n"
                "Можно в свободной форме — чем подробнее, тем лучше.\n\n"
                "✖️ Для отмены — /cancel"
            )
        except Exception:
            pass
        return
    
    # ===== Решения админа =====
    if action in ('approve', 'reject', 'implement'):
        if not has_permission(user_id, 'gban', 'aidea_decide'):
            await query.answer("Только со спецдоступом.", show_alert=True)
            return
        idea = _idea_get(target_id)
        if not idea:
            await query.answer("Идея не найдена.", show_alert=True)
            return
        if idea.get('status') and idea['status'] != 'submitted':
            await query.answer("Уже решена.", show_alert=True)
            return
        # Ставим state ожидания комментария от админа
        context.user_data['pending_idea_decision'] = {
            'idea_id': target_id,
            'action': action,
        }
        action_label = {'approve': 'ПРИНЯТЬ', 'reject': 'ОТКЛОНИТЬ', 'implement': 'В РАБОТУ'}[action]
        await query.answer(f"Идея #{target_id}: {action_label}")
        try:
            await query.edit_message_text(
                _format_idea_card(idea, for_admin=True) + 
                f"\n\n📌 Решение: {action_label}\n"
                f"💬 Напишите комментарий для автора следующим сообщением (или '-' без комментария):"
            )
        except Exception:
            pass
        return


async def handle_idea_input(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Получение текста идеи от юзера (после нажатия «Есть идеи»).
    Срабатывает только в личке и только если есть pending_idea_input.
    """
    if not update.message or not update.message.text:
        return
    if 'pending_idea_input' not in context.user_data:
        return
    # Только в ЛС
    if update.effective_chat.type != 'private':
        return
    
    text = update.message.text.strip()
    if text.lower() in ('/cancel', 'cancel', 'отмена'):
        context.user_data.pop('pending_idea_input', None)
        await update.message.reply_text("✖️ Идея не отправлена.")
        return
    if len(text) < 5:
        await update.message.reply_text("❌ Слишком коротко. Опишите подробнее или /cancel.")
        return
    
    idea_id = context.user_data.pop('pending_idea_input')
    _idea_finalize_text(idea_id, text)
    log_action(update.effective_user.id, 'idea_submitted', None, f"#{idea_id}")
    
    idea = _idea_get(idea_id)
    
    await update.message.reply_text(
        f"✅ ИДЕЯ #{idea_id} ПРИНЯТА К РАССМОТРЕНИЮ\n"
        "━━━━━━━━━━━━━━━━━\n"
        "Спасибо за предложение! Я уведомлю, когда решение будет принято."
    )
    
    # DM админам с карточкой и кнопками
    card = _format_idea_card(idea, for_admin=True)
    kb = _idea_kb_decision(idea_id)
    for admin_id in _idea_get_main_admins():
        try:
            await context.bot.send_message(chat_id=admin_id, text=card, reply_markup=kb)
        except Exception as e:
            logger.debug(f"idea card DM to {admin_id}: {e}")


async def handle_idea_decision_comment(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    Принимает комментарий от админа после клика «Принять/Отклонить/В работу».
    Срабатывает только при pending_idea_decision.
    """
    if 'pending_idea_decision' not in context.user_data:
        return
    if not update.message or not update.message.text:
        return
    
    state = context.user_data.pop('pending_idea_decision')
    idea_id = state['idea_id']
    action = state['action']
    comment = (update.message.text or "").strip() or "—"
    
    status_map = {'approve': 'approved', 'reject': 'rejected', 'implement': 'implemented'}
    status = status_map[action]
    
    _idea_set_decision(idea_id, status, update.effective_user.id, comment)
    log_action(update.effective_user.id, f'idea_{status}', None, f"#{idea_id}: {comment[:120]}")
    
    idea = _idea_get(idea_id)
    
    # Уведомляем автора
    label = {'approved': '✅ ПРИНЯТА', 'rejected': '❌ ОТКЛОНЕНА', 'implemented': '🚧 В РАБОТУ'}[status]
    try:
        await context.bot.send_message(
            chat_id=idea['user_id'],
            text=(
                f"💡 РЕШЕНИЕ ПО ИДЕЕ #{idea_id}\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"📊 Статус: {label}\n"
                f"💬 {comment}"
            ),
        )
    except Exception:
        pass
    
    await update.message.reply_text(
        f"✅ Идея #{idea_id} → {label}. Автор уведомлён."
    )


