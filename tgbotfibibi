def add_warning(user_id: int, issuer_id: int, reason: str) -> tuple:
    """Добавление предупреждения"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT warns, game_nick FROM users WHERE user_id = ?', (user_id,))
    row = c.fetchone()
    if not row:
        conn.close()
        return False, "Пользователь не найден", None
    
    current_warns = row[0]
    user_nick = row[1]
    parts = current_warns.split('/')
    verbal = int(parts[0]) if len(parts) == 2 else 0
    written = int(parts[1]) if len(parts) == 2 else 0
    kicked = False
    
    if verbal < 2:
        verbal += 1
        warn_type = "Устное"
    elif written < 3:
        written += 1
        warn_type = "Письменное"
        if written == 3:
            kicked = True
    else:
        conn.close()
        return False, "Достигнут лимит предупреждений", None
    
    new_warns = f"{verbal}/{written}"
    c.execute('UPDATE users SET warns = ? WHERE user_id = ?', (new_warns, user_id))
    c.execute('''INSERT INTO warnings (user_id, nick, warn_type, counter, reason, date, issued_by) 
                 VALUES (?, ?, ?, ?, ?, ?, ?)''',
              (user_id, user_nick, warn_type, new_warns, reason,
               datetime.now().strftime("%Y-%m-%d %H:%M:%S"), issuer_id))
    conn.commit()
    conn.close()
    return True, f"Выдано {warn_type.lower()} предупреждение ({new_warns})", kicked

