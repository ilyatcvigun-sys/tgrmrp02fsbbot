def _report_progress_bar(step: int, total: int = 5) -> str:
    """Прогресс-бар: ▰▰▱▱▱  2/5"""
    filled = max(0, min(total, step))
    return "▰" * filled + "▱" * (total - filled) + f"  {step}/{total}"


def _format_verdict_history(report: dict, *, include_current: bool = False) -> str:
    """
    Возвращает форматированную историю проверок жалобы — кто, какой вердикт, когда,
    с комментарием. Используется и в карточке, и в финальных уведомлениях, и в сводке.
    
    include_current=True — добавить в конец строку про текущий финальный вердикт
                           (используется в уведомлениях, где сам вердикт идёт отдельно сверху).
    """
    prev = report.get('previous_verdicts') or []
    if not prev and not (include_current and report.get('verdict')):
        return ""
    
    lines = []
    for i, snap in enumerate(prev, 1):
        old_mod = get_admin_nick(snap.get('moderator_id')) if snap.get('moderator_id') else "—"
        reop_by = get_admin_nick(snap.get('reopened_by')) if snap.get('reopened_by') else "—"
        lines.append(
            f"  {i}. {snap.get('verdict') or '—'} — {old_mod} "
            f"({snap.get('resolved_at') or '—'})"
        )
        if snap.get('comment'):
            comment_preview = snap['comment'][:120] + ("…" if len(snap['comment']) > 120 else "")
            lines.append(f"     💬 {comment_preview}")
        lines.append(f"     🔄 перепроверку запросил: {reop_by} ({snap.get('reopened_at') or '—'})")
    
    if include_current and report.get('verdict') and report['status'] not in ('pending', 'review'):
        n = len(prev) + 1
        cur_mod = get_admin_nick(report['moderator_id']) if report.get('moderator_id') else "—"
        lines.append(
            f"  {n}. {report['verdict']} — {cur_mod} "
            f"({report.get('resolved_at') or '—'})  ← текущий"
        )
        if report.get('moderator_comment'):
            comment_preview = report['moderator_comment'][:120] + ("…" if len(report['moderator_comment']) > 120 else "")
            lines.append(f"     💬 {comment_preview}")
    
    return "\n".join(lines)


def _format_report_card(report: dict, *, for_moderator: bool = False) -> str:
    """Единое оформление карточки жалобы для всех мест (DM, /areport_info, /areports)."""
    nick = report['reporter_nick'] or "—"
    head = f"📋 ЖАЛОБА #{report['id']}"
    if report['status'] == 'pending':
        head += " — ⏳ ожидает"
    elif report['status'] in ('approve', 'approved'):
        head += " — ✅ одобрена"
    elif report['status'] in ('reject', 'rejected'):
        head += " — ❌ отказ"
    elif report['status'] == 'review':
        head += " — 👀 на рассмотрении"
    
    reopened_count = report.get('reopened_count') or 0
    if reopened_count > 0:
        head += f" 🔄×{reopened_count}"
    
    body = (
        f"{head}\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"👤 Подал: {nick}\n"
        f"🎮 Нарушитель: {report['violator_nick']}\n"
        f"🏢 Фракция: {report['faction'] or '—'}\n"
        f"⚠️ Нарушение: {report['violation']}\n"
        f"📎 Доказательства: {report['evidence'] or '—'}\n"
    )
    if report.get('media_files'):
        body += f"📁 Прикреплено медиа: {len(report['media_files'])}\n"
    body += (
        f"💻 Команда: {report['command'] or '—'}\n"
        f"📅 Подана: {report['created_at']}\n"
    )
    if report['status'] not in ('pending', 'review'):
        mod_name = get_admin_nick(report['moderator_id']) if report['moderator_id'] else "—"
        body += (
            "━━━━━━━━━━━━━━━━━\n"
            f"📊 Вердикт: {report['verdict'] or '—'}"
        )
        if reopened_count > 0:
            body += " (после перепроверки)"
        body += "\n"
        body += f"👮 Модератор: {mod_name}\n"
        if report['moderator_comment']:
            body += f"💬 Комментарий: {report['moderator_comment']}\n"
        if report['resolved_at']:
            body += f"📅 Решено: {report['resolved_at']}\n"
    
    # История прошлых проверок (если были перепроверки)
    history = _format_verdict_history(report)
    if history:
        body += "━━━━━━━━━━━━━━━━━\n"
        body += f"🔄 ИСТОРИЯ ПЕРЕПРОВЕРОК ({reopened_count})\n"
        body += history + "\n"
    return body.rstrip()


def _report_action_keyboard(report_id: int, status: str, is_mod_5plus: bool) -> InlineKeyboardMarkup:
    """Кнопки под карточкой жалобы.
    - pending → Одобрить / Отказать (для 4+, обрабатывается handle_report_callback)
    - решена + 5+ → Перепроверить / Удалить
    """
    if status == 'pending':
        return InlineKeyboardMarkup([[
            InlineKeyboardButton("✅ Одобрить", callback_data=f"approve_{report_id}"),
            InlineKeyboardButton("❌ Отказать", callback_data=f"reject_{report_id}"),
        ]])
    if status != 'pending' and is_mod_5plus:
        return InlineKeyboardMarkup([
            [
                InlineKeyboardButton("🔄 Перепроверить", callback_data=f"rep:reopen:{report_id}"),
                InlineKeyboardButton("🗑 Удалить", callback_data=f"rep:del:{report_id}"),
            ],
        ])
    return None


