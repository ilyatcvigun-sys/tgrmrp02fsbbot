def is_private_chat(update: Update) -> bool:
    return update.effective_chat.type == 'private'

def extract_user_id(update: Update, context: ContextTypes.DEFAULT_TYPE, text: str):
    """Извлечение user_id из разных форматов"""
    text = text.strip()
    
    # Числовой ID
    if text.isdigit():
        return int(text)
    
    # @username или username без @
    username = text.replace('@', '').strip()
    
    # Ссылка https://t.me/username
    if 't.me/' in username:
        username = username.split('t.me/')[-1].split()[0].strip()
    
    # Ищем в базе
    if username:
        result = find_user_by_username(username)
        if result:
            return result
        return None
    
    # Ответ на сообщение
    if update.message and update.message.reply_to_message:
        return update.message.reply_to_message.from_user.id
    
    return None

def find_user_by_username(username):
    """Поиск пользователя в базе по нику или позывному"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    # Пробуем точное совпадение
    cursor.execute('SELECT user_id FROM users WHERE game_nick = ? OR callsign = ?', (username, username))
    result = cursor.fetchone()
    
    if result:
        conn.close()
        return result[0]
    
    # Пробуем частичное совпадение
    cursor.execute('SELECT user_id FROM users WHERE game_nick LIKE ? OR callsign LIKE ?', (f'%{username}%', f'%{username}%'))
    results = cursor.fetchall()
    conn.close()
    
    if len(results) == 1:
        return results[0][0]
    elif len(results) > 1:
        return -1  # Несколько пользователей
    return None

def find_users_by_username(username):
    """Поиск всех пользователей"""
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('SELECT user_id, game_nick, callsign, token, rank FROM users WHERE game_nick LIKE ? OR callsign LIKE ?', 
                   (f'%{username}%', f'%{username}%'))
    results = cursor.fetchall()
    conn.close()
    return results

