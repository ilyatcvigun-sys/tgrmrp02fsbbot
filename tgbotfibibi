async def areports(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Список всех жалоб (доступно всем)"""
    user_id = update.effective_user.id
    user_data = get_user_data(user_id)
    if not user_data:
        await update.message.reply_text("❌ Вы не зарегистрированы.")
        return
    
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('''
        SELECT id, reporter_nick, violator_nick, violation, status, verdict, moderator_comment, created_at, resolved_at
        FROM reports 
        ORDER BY id DESC 
        LIMIT 20
    ''')
    reports = cursor.fetchall()
    conn.close()
    
    if not reports:
        await update.message.reply_text("📋 Жалоб пока нет.")
        return
    
    text = "📋 ПОСЛЕДНИЕ ЖАЛОБЫ:\n\n"
    
    for r in reports:
        report_id = r[0]
        reporter = r[1]
        violator = r[2]
        violation = r[3]
        status = r[4]
        verdict = r[5] or "—"
        comment = r[6] or "—"
        created = r[7]
        resolved = r[8] or "—"
        
        # Эмодзи статуса
        if status == 'pending':
            status_emoji = "⏳"
            status_text = "На рассмотрении"
        elif status == 'approve':
            status_emoji = "✅"
            status_text = "Одобрено"
        elif status == 'reject':
            status_emoji = "❌"
            status_text = "Отказано"
        else:
            status_emoji = "❓"
            status_text = status
        
        text += f"{status_emoji} #{report_id} | {status_text}\n"
        text += f"👤 Подал: {reporter}\n"
        text += f"🎮 Нарушитель: {violator}\n"
        text += f"⚠️ {violation[:50]}...\n" if len(violation) > 50 else f"⚠️ {violation}\n"
        text += f"📅 Создана: {created}\n"
        
        if status != 'pending':
            text += f"📊 Вердикт: {verdict}\n"
            text += f"💬 Комментарий: {comment}\n"
            text += f"📅 Рассмотрена: {resolved}\n"
        
        text += "\n"
    
    # Добавляем статистику
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('SELECT COUNT(*) FROM reports')
    total = cursor.fetchone()[0]
    cursor.execute('SELECT COUNT(*) FROM reports WHERE status = "pending"')
    pending = cursor.fetchone()[0]
    cursor.execute('SELECT COUNT(*) FROM reports WHERE status = "approve"')
    approved = cursor.fetchone()[0]
    cursor.execute('SELECT COUNT(*) FROM reports WHERE status = "reject"')
    rejected = cursor.fetchone()[0]
    conn.close()
    
    text += "━━━━━━━━━━━━━━━\n"
    text += f"📊 Статистика:\n"
    text += f"Всего: {total} | ⏳ {pending} | ✅ {approved} | ❌ {rejected}"
    
    await update.message.reply_text(text)


