def _extract_json_block(raw: str) -> dict:
    """
    Аккуратно вытаскиваем JSON из ответа модели.
    Gemma и другие free-модели часто оборачивают JSON в ```json ... ```
    либо добавляют текст до/после. Берём первую сбалансированную {...}.
    """
    if not raw:
        return None
    s = raw.strip()
    # Снимаем markdown-обёртку, если есть
    s = re.sub(r"^```(?:json)?\s*", "", s, flags=re.IGNORECASE)
    s = re.sub(r"\s*```$", "", s)
    # Пытаемся распарсить как есть
    try:
        return json.loads(s)
    except Exception:
        pass
    # Ищем первый сбалансированный JSON-объект
    start = s.find('{')
    if start == -1:
        return None
    depth = 0
    for i in range(start, len(s)):
        ch = s[i]
        if ch == '{':
            depth += 1
        elif ch == '}':
            depth -= 1
            if depth == 0:
                candidate = s[start:i + 1]
                try:
                    return json.loads(candidate)
                except Exception:
                    return None
    return None


def _normalize_mood(parsed: dict) -> dict:
    """Приводим результат от модели к единой схеме."""
    if not isinstance(parsed, dict):
        return {"mood_score": 0, "mood_label": "Не определено", "summary": ""}
    # score
    score = parsed.get("mood_score", parsed.get("score", 0))
    try:
        score = int(float(score))
    except Exception:
        score = 0
    score = max(0, min(100, score))
    # label
    label = parsed.get("mood_label") or parsed.get("label") or parsed.get("mood") or "Не определено"
    label = str(label).strip() or "Не определено"
    # summary
    summary = parsed.get("summary") or parsed.get("comment") or parsed.get("mood_text") or ""
    summary = str(summary).strip()
    return {"mood_score": score, "mood_label": label, "summary": summary}


def _call_openrouter_sync(combined_text: str, model: str) -> str:
    """Синхронный вызов OpenRouter с конкретной моделью. Возвращает сырой текст ответа."""
    client = openai.OpenAI(
        base_url="https://openrouter.ai/api/v1",
        api_key=OPENROUTER_API_KEY,
        timeout=30.0,
    )
    completion = client.chat.completions.create(
        model=model,
        messages=[
            {
                "role": "system",
                "content": (
                    "Ты — анализатор настроения русскоязычного чата. "
                    "Прочитай сообщения и оцени общую атмосферу. "
                    "Верни СТРОГО один JSON-объект без markdown, без пояснений, без префиксов. "
                    "Формат: "
                    '{"mood_score": <целое 0-100>, '
                    '"mood_label": "Позитивное" | "Нейтральное" | "Негативное" | "Токсичное", '
                    '"summary": "одно короткое предложение на русском о происходящем"}'
                ),
            },
            {"role": "user", "content": f"Сообщения чата:\n{combined_text}"},
        ],
        temperature=0.3,
        max_tokens=300,
    )
    return completion.choices[0].message.content or ""


# Диагностика — заполняется при каждом запуске анализа, доступна через /amooddebug
_last_mood_diagnostics = {
    "ran_at": None,
    "model_used": None,
    "raw_response": "",
    "error": "",
    "messages_count": 0,
}


async def analyze_mood_with_ai(messages: list) -> dict:
    """
    Анализ настроения через OpenRouter с fallback-цепочкой моделей.
    Никогда не бросает; всегда возвращает нормализованный dict.
    Заполняет _last_mood_diagnostics для отладки.
    """
    global _last_mood_diagnostics
    _last_mood_diagnostics = {
        "ran_at": now_msk_str(),
        "model_used": None,
        "raw_response": "",
        "error": "",
        "messages_count": len(messages) if messages else 0,
    }
    
    if not messages:
        _last_mood_diagnostics["error"] = "Сообщений ещё не было."
        return {"mood_score": 0, "mood_label": "Нет данных", "summary": "Сообщений ещё не было."}

    combined_text = "\n".join(messages[-100:])
    if len(combined_text) < 10:
        _last_mood_diagnostics["error"] = "Слишком мало сообщений для анализа."
        return {"mood_score": 0, "mood_label": "Недостаточно данных", "summary": "Слишком мало сообщений для анализа."}

    last_error = ""
    for model in OPENROUTER_FALLBACK_MODELS:
        try:
            raw = await asyncio.to_thread(_call_openrouter_sync, combined_text, model)
            _last_mood_diagnostics["model_used"] = model
            _last_mood_diagnostics["raw_response"] = (raw or "")[:500]
            logger.info(f"AI mood ({model}): {(raw or '')[:200]!r}")
            parsed = _extract_json_block(raw)
            if parsed is None:
                last_error = f"{model}: модель не вернула валидный JSON"
                logger.warning(f"AI mood: cannot parse JSON from {model}: {(raw or '')[:300]!r}")
                continue
            _last_mood_diagnostics["error"] = ""
            return _normalize_mood(parsed)
        except Exception as e:
            last_error = f"{model}: {type(e).__name__}: {e}"
            logger.error(f"AI mood error on {model}: {e}", exc_info=False)
            continue
    
    _last_mood_diagnostics["error"] = last_error or "Все модели недоступны"
    return {
        "mood_score": 0,
        "mood_label": "Ошибка анализа",
        "summary": f"Не удалось получить ответ от моделей. {last_error[:200]}",
    }


def _mood_emoji(score: int) -> str:
    if score >= 75:
        return "😄"
    if score >= 55:
        return "🙂"
    if score >= 40:
        return "😐"
    if score >= 20:
        return "😟"
    return "😡"


def _mood_bar(score: int, width: int = 10) -> str:
    filled = max(0, min(width, round(score / 100 * width)))
    return "█" * filled + "░" * (width - filled)


