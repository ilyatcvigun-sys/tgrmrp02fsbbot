def init_database():
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER UNIQUE NOT NULL,
            game_nick TEXT NOT NULL,
            callsign TEXT NOT NULL,
            token TEXT UNIQUE NOT NULL,
            rank INTEGER DEFAULT 0,
            department TEXT DEFAULT 'Не назначен',
            warns TEXT DEFAULT '0/0',
            ban_status TEXT DEFAULT 'Нет',
            ban_reason TEXT DEFAULT '',
            ban_date TEXT DEFAULT '',
            created_at TEXT DEFAULT ''
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS gban (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            nick TEXT,
            reason TEXT,
            date TEXT,
            banned_by INTEGER
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS awards (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            nick TEXT,
            award_name TEXT,
            award_type TEXT,
            date TEXT,
            issued_by INTEGER
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS warnings (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            nick TEXT,
            warn_type TEXT,
            counter TEXT,
            reason TEXT,
            date TEXT,
            issued_by INTEGER
        )
    ''')
    
    conn.commit()
    conn.close()

def generate_unique_token():
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    while True:
        random_digits = ''.join([str(random.randint(0, 9)) for _ in range(4)])
        token = f"52{random_digits}"
        cursor.execute('SELECT token FROM users WHERE token = ?', (token,))
        if not cursor.fetchone():
            conn.close()
            return token

def add_user(user_id, game_nick, callsign, token=None):
    if token is None:
        token = generate_unique_token()
    
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    try:
        cursor.execute('''
            INSERT INTO users (user_id, game_nick, callsign, token, created_at)
            VALUES (?, ?, ?, ?, ?)
        ''', (user_id, game_nick, callsign, token, datetime.now().strftime("%Y-%m-%d %H:%M:%S")))
        conn.commit()
        conn.close()
        return token
    except sqlite3.IntegrityError:
        conn.close()
        return None

def set_user_token(user_id, new_token):
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('SELECT user_id FROM users WHERE token = ?', (new_token,))
    if cursor.fetchone():
        conn.close()
        return False, "Жетон уже занят"
    
    cursor.execute('UPDATE users SET token = ? WHERE user_id = ?', (new_token, user_id))
    conn.commit()
    success = cursor.rowcount > 0
    conn.close()
    return success, "Жетон обновлен" if success else "Пользователь не найден"

