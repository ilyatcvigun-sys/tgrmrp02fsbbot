async def report_complete(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Финал: сохраняем и рассылаем модераторам."""
    user_id = update.effective_user.id
    user_data = get_user_data(user_id)
    command_text = (update.message.text or "").strip() or "нет"
    
    media = context.user_data.get('report_media') or []
    report_id = save_report(
        user_id,
        user_data['callsign'],
        context.user_data.get('report_violator', '—'),
        context.user_data.get('report_faction', '—'),
        context.user_data.get('report_violation', '—'),
        context.user_data.get('report_evidence', '—'),
        command_text,
        media_files=media,
    )
    
    # Карточка для модераторов
    report = get_report(report_id)
    card = _format_report_card(report)
    kb = _report_action_keyboard(report_id, 'pending', is_mod_5plus=False)
    
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT user_id FROM users WHERE rank >= 4 AND bot_blocked = "Нет"')
    mods = [r[0] for r in c.fetchall()]
    conn.close()
    
    delivered = 0
    for mid in mods:
        try:
            await context.bot.send_message(chat_id=mid, text=card, reply_markup=kb)
            # Пересылаем медиа после карточки
            await forward_report_media(context, mid, media)
            delivered += 1
        except Exception as e:
            logger.debug(f"report broadcast to {mid}: {e}")
        await asyncio.sleep(0.05)
    
    log_action(user_id, 'report_submitted', None, f"#{report_id}: {report['violator_nick']}")
    
    await update.message.reply_text(
        f"✅ ЖАЛОБА #{report_id} ОТПРАВЛЕНА\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"📨 Доставлена {delivered} модератор(ам).\n"
        "Спасибо! Решение придёт сюда же."
    )
    # Очищаем состояние
    for k in ('report_violator', 'report_faction', 'report_violation', 'report_evidence', 'report_media'):
        context.user_data.pop(k, None)
    return ConversationHandler.END


async def handle_report_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработка кнопок модерации жалоб: approve_<id>, reject_<id>."""
    query = update.callback_query
    await query.answer()
    
    user_id = query.from_user.id
    if not has_permission(user_id, 'search'):
        try:
            await query.edit_message_text("❌ Решения по жалобам — только с 4 ранга.")
        except Exception:
            pass
        return
    
    action, report_id = query.data.split('_')
    report_id = int(report_id)
    
    report = get_report(report_id)
    if not report:
        try:
            await query.edit_message_text("❌ Жалоба не найдена (возможно, удалена).")
        except Exception:
            pass
        return
    
    if report['status'] != 'pending':
        is_5plus = has_permission(user_id, 'warn')
        kb = _report_action_keyboard(report_id, report['status'], is_5plus)
        try:
            await query.edit_message_text(
                _format_report_card(report) + "\n\n⚠️ Уже обработано.",
                reply_markup=kb,
            )
        except Exception:
            pass
        return
    
    update_report(report_id, 'review', user_id, 'На рассмотрении...')
    
    if action == 'approve':
        context.user_data['pending_report'] = report_id
        context.user_data['pending_action'] = 'approve'
        await query.edit_message_text(
            _format_report_card(report) + "\n\n"
            f"✅ ОДОБРЕНО (ожидает комментария)\n"
            f"👮 Модератор: {get_admin_nick(user_id)}\n"
            f"Введите комментарий следующим сообщением (или '-' без комментария):"
        )
    elif action == 'reject':
        context.user_data['pending_report'] = report_id
        context.user_data['pending_action'] = 'reject'
        await query.edit_message_text(
            _format_report_card(report) + "\n\n"
            f"❌ ОТКАЗАНО (ожидает причины)\n"
            f"👮 Модератор: {get_admin_nick(user_id)}\n"
            f"Введите причину отказа следующим сообщением:"
        )


async def report_extra_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработка перепроверки/удаления уже закрытых жалоб. pattern='^rep:'."""
    query = update.callback_query
    await query.answer()
    user_id = query.from_user.id
    
    if not has_permission(user_id, 'warn'):
        await query.answer("Только с 5 ранга.", show_alert=True)
        return
    
    parts = (query.data or "").split(":")
    if len(parts) < 3:
        return
    action = parts[1]
    try:
        report_id = int(parts[2])
    except ValueError:
        return
    
    report = get_report(report_id)
    if not report:
        try:
            await query.edit_message_text("❌ Жалоба не найдена.")
        except Exception:
            pass
        return
    
    if action == 'reopen':
        if report['status'] == 'pending':
            try:
                await query.edit_message_text(_format_report_card(report) + "\n\nℹ️ Уже в статусе ожидания.")
            except Exception:
                pass
            return
        snapshot = reopen_report(report_id, user_id)
        log_action(
            user_id, 'report_reopened', report['reporter_id'],
            f"#{report_id}: было {snapshot.get('verdict','—')} от id={snapshot.get('moderator_id','—')} ({snapshot.get('resolved_at','')})",
        )
        fresh = get_report(report_id)
        kb = _report_action_keyboard(report_id, 'pending', is_mod_5plus=True)
        try:
            await query.edit_message_text(
                _format_report_card(fresh) + f"\n\n🔄 Перепроверка инициирована {get_admin_nick(user_id)}",
                reply_markup=kb,
            )
        except Exception:
            pass
        # Уведомим автора
        try:
            await context.bot.send_message(
                report['reporter_id'],
                f"🔄 Жалоба #{report_id} отправлена на перепроверку.\n"
                f"👮 Инициатор: {get_admin_nick(user_id)}",
            )
        except Exception:
            pass
        return
    
    if action == 'del':
        # Двухстадийное подтверждение
        kb = InlineKeyboardMarkup([
            [InlineKeyboardButton("🗑 Удалить окончательно", callback_data=f"rep:delconf:{report_id}")],
            [InlineKeyboardButton("◀️ Отмена", callback_data=f"rep:delcancel:{report_id}")],
        ])
        try:
            await query.edit_message_text(
                _format_report_card(report) +
                "\n\n❗ Подтвердите удаление — действие необратимо.",
                reply_markup=kb,
            )
        except Exception:
            pass
        return
    
    if action == 'delconf':
        snapshot = delete_report(report_id)
        if snapshot:
            log_action(
                user_id, 'report_deleted', snapshot['reporter_id'],
                f"#{report_id}: violator={snapshot['violator_nick']}, status={snapshot['status']}",
            )
        try:
            await query.edit_message_text(
                f"🗑 ЖАЛОБА #{report_id} УДАЛЕНА\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"👮 Удалил: {get_admin_nick(user_id)}\n"
                f"Запись запротоколирована в аудит-логе."
            )
        except Exception:
            pass
        return
    
    if action == 'delcancel':
        is_5plus = has_permission(user_id, 'warn')
        kb = _report_action_keyboard(report_id, report['status'], is_5plus)
        try:
            await query.edit_message_text(_format_report_card(report), reply_markup=kb)
        except Exception:
            pass
        return


async def handle_moderator_comment(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработка комментария модератора"""
    if 'pending_report' not in context.user_data:
        return
    
    report_id = context.user_data['pending_report']
    action = context.user_data['pending_action']
    comment = (update.message.text or "").strip() or "—"
    
    verdict = "ОДОБРЕНО" if action == 'approve' else "ОТКАЗАНО"
    update_report(report_id, action, update.effective_user.id, verdict, comment)
    log_action(update.effective_user.id, 'report_' + action, None, f"#{report_id}: {comment[:120]}")
    
    report = get_report(report_id)
    reopened = (report.get('reopened_count') or 0) > 0
    reopen_tag = " (после перепроверки)" if reopened else ""
    
    # Если жалоба прошла перепроверку — добавим полный список всех проверявших
    history_block = ""
    if reopened:
        history = _format_verdict_history(report)  # история ДО текущего вердикта
        if history:
            history_block = (
                f"\n━━━━━━━━━━━━━━━━━\n"
                f"🔄 ВСЕ ПРОВЕРКИ ЖАЛОБЫ ({report['reopened_count'] + 1}):\n"
                f"{history}\n"
                f"  {report['reopened_count'] + 1}. {verdict} — "
                f"{get_admin_nick(update.effective_user.id)} ({now_msk_str()})  ← текущий"
            )
            if comment and comment != "—":
                history_block += f"\n     💬 {comment[:120]}{'…' if len(comment) > 120 else ''}"
    
    # Уведомление автору жалобы
    try:
        await context.bot.send_message(
            chat_id=report['reporter_id'],
            text=(
                f"📋 ВЕРДИКТ ПО ЖАЛОБЕ #{report_id}{reopen_tag}\n"
                "━━━━━━━━━━━━━━━━━\n"
                f"📊 Статус: {verdict}\n"
                f"👮 Модератор: {get_admin_nick(update.effective_user.id)}\n"
                f"💬 {comment}"
                + history_block
            ),
        )
    except Exception:
        pass
    
    # Дублирование в топик «Вердикты»
    try:
        await context.bot.send_message(
            chat_id=CONFERENCE_CHAT_ID,
            text=(
                f"📋 ВЕРДИКТ #{report_id}{reopen_tag}\n"
                f"👤 Подал: {report['reporter_nick']}\n"
                f"🎮 Нарушитель: {report['violator_nick']}\n"
                f"⚠️ {report['violation']}\n"
                f"📊 {verdict}\n"
                f"👮 {get_admin_nick(update.effective_user.id)}\n"
                f"💬 {comment}"
                + history_block
            ),
            message_thread_id=VERDICT_TOPIC_ID,
        )
    except Exception:
        pass
    
    await update.message.reply_text(f"✅ Вердикт по жалобе #{report_id}{reopen_tag} отправлен.")
    context.user_data.pop('pending_report', None)
    context.user_data.pop('pending_action', None)

