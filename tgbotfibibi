    c.execute('SELECT user_id FROM users WHERE rank >= 5 AND bot_blocked = "Нет"')
    mods = [r[0] for r in c.fetchall()]
    conn.close()
    for mid in mods:
        # Не шлём самому автору заявки, даже если он 5+ (на всякий случай)
        if mid == req['user_id']:
            continue
        try:
            await context.bot.send_message(chat_id=mid, text=text, reply_markup=kb)
        except Exception as e:
            logger.debug(f"request broadcast to {mid} failed: {e}")
        await asyncio.sleep(0.05)


