        'SELECT id, actor_id, action, target_id, details, created_at FROM audit_log WHERE target_id = ? ORDER BY id DESC',
        (target_id,),
    )
    for row in c.fetchall():
        events.append((row[5], _format_audit_row(row, focus='on')))
    
    # 2) Награды
    c.execute(
        "SELECT award_name, award_type, date, issued_by FROM awards WHERE user_id = ? ORDER BY id DESC",
        (target_id,),
    )
    for award_name, award_type, date, issued_by in c.fetchall():
        by = get_admin_nick(issued_by) if issued_by else "—"
        events.append((date or "", f"🕐 {date} | 🏅 Награда: {award_name} ({award_type}) | от {by}"))
    
    # 3) Варны (включая истёкшие и снятые — для истории полная картина)
    c.execute(
        '''SELECT id, warn_type, counter, reason, date, issued_by, expires_at
           FROM warnings WHERE user_id = ? ORDER BY id DESC''',
        (target_id,),
    )
    for wid, wtype, counter, reason, date, issued_by, expires_at in c.fetchall():
        by = get_admin_nick(issued_by) if issued_by else "—"
        if counter == "0/0":
            tag = "(снят)"
        elif counter == "EXPIRED":
            tag = "(истёк)"
        else:
            tag = f"({counter})"
        events.append((date or "", f"🕐 {date} | ⚠️ {wtype} {tag} | {reason} | от {by}"))
    
    # 4) Заявки от него самого
    c.execute(
        '''SELECT id, request_type, current_value, requested_value, status, decided_at, created_at
           FROM change_requests WHERE user_id = ? ORDER BY id DESC''',
        (target_id,),
    )
    for rid, rtype, cur, new, status, decided_at, created_at in c.fetchall():
        tlabel = "ранг" if rtype == 'rank' else "отдел"
        slabel = {'pending': '⏳ ожидает', 'approved': '✅ одобрена', 'rejected': '❌ отказ'}.get(status, status)
        events.append((created_at or "", f"🕐 {created_at} | 📥 Заявка #{rid} ({tlabel}): {cur} → {new} — {slabel}"))
    
    # 5) Гбан, если есть
    c.execute('SELECT reason, banned_by, date FROM gban WHERE user_id = ?', (target_id,))
    row = c.fetchone()
    if row:
        events.append((row[2] or "", f"🕐 {row[2]} | 🚫 В чёрном списке (гбан): {row[0]} | от {get_admin_nick(row[1])}"))
    
    # 6) Гранты
    c.execute(
        'SELECT command, granted_by, granted_at FROM command_grants WHERE user_id = ? ORDER BY granted_at DESC',
        (target_id,),
    )
    for cmd, granted_by, granted_at in c.fetchall():
        by = get_admin_nick(granted_by) if granted_by else "—"
        events.append((granted_at or "", f"🕐 {granted_at} | 🔑 Грант на /{cmd} | от {by}"))
    
    conn.close()
    
    # Сортируем по времени убыванию
    events.sort(key=lambda x: x[0] or "", reverse=True)
    
    header = (
        "📜 ИСТОРИЯ ПОЛЬЗОВАТЕЛЯ\n"
        "━━━━━━━━━━━━━━━━━\n"
        f"👤 {target_data['nick']} ({target_data['callsign']})\n"
        f"🆔 {target_id}\n"
        f"⭐ Сейчас: {RANKS.get(target_data['rank'], RANKS[0])['name']}\n"
        f"📁 Сейчас: {target_data['department']}\n"
        f"📅 Регистрация: {target_data['reg_date']}\n"
        "━━━━━━━━━━━━━━━━━\n"
    )
    
    if not events:
        await update.message.reply_text(header + "Событий пока нет.")
        return
    
    # Аккуратно обрезаем под лимит Telegram
    body_parts = []
    body_len = 0
    LIMIT = 3800
    truncated = 0
    for _, line in events:
        chunk = line + "\n\n"
        if body_len + len(chunk) > LIMIT:
            truncated = len(events) - len(body_parts)
            break
        body_parts.append(chunk)
        body_len += len(chunk)
    
    text = header + "".join(body_parts)
    if truncated:
        text += f"…и ещё {truncated} событий (свернуто, открыть подробнее: /aaudit on {target_id})"
    await update.message.reply_text(text)


