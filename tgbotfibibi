async def apoll_info(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Информация о голосовании"""
    if not context.args: await update.message.reply_text("❌ /apoll_info ID"); return
    try: poll_id = int(context.args[0])
    except: await update.message.reply_text("❌ ID."); return
    
    poll = get_poll_by_id(poll_id)
    if not poll: await update.message.reply_text("❌ Не найдено."); return
    
    total = poll['yes'] + poll['no'] + poll['abstain']
    yes_pct = round(poll['yes'] / max(total, 1) * 100)
    no_pct = round(poll['no'] / max(total, 1) * 100)
    bar_len = 10
    yes_bar = '█' * int(yes_pct / 10) + '░' * (bar_len - int(yes_pct / 10))
    no_bar = '█' * int(no_pct / 10) + '░' * (bar_len - int(no_pct / 10))
    
    text = (
        f"📋 ГОЛОСОВАНИЕ #{poll['id']}\n\n"
        f"👤 Кандидат: {poll['candidate']}\n"
        f"📝 {poll['description']}\n"
    )
    if poll['additions']: text += f"📎 Дополнения:{poll['additions']}\n"
    text += (
        f"\n📊 РЕЗУЛЬТАТЫ:\n"
        f"✅ Да:  [{yes_bar}] {poll['yes']} ({yes_pct}%)\n"
        f"❌ Нет: [{no_bar}] {poll['no']} ({no_pct}%)\n"
        f"⚪ Воздерж: {poll['abstain']}\n"
        f"👥 Всего: {total}\n\n"
        f"👮 Создал: {poll['creator_nick']}\n📅 {poll['created_at']}\n"
        f"Статус: {'🟢 Активно' if poll['status'] == 'active' else '🔴 Закрыто'}\n"
    )
    
    votes = get_poll_votes(poll_id)
    if votes:
        text += "\n🗳 ГОЛОСА:\n"
        for v in votes:
            vd = get_user_data(v[2]); vn = vd['nick'] if vd else f"User {v[2]}"
            e = "✅" if v[3] == 'yes' else ("❌" if v[3] == 'no' else "⚪")
            text += f"{e} {vn}"; 
            if v[4]: text += f" — {v[4]}"
            text += f" | {v[5]}\n"
    
    await update.message.reply_text(text)


