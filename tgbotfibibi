        # Лист пользователей
        ws_users = wb.active
        ws_users.title = "Пользователи"
        headers_users = ["ID", "User ID", "Ник", "Позывной", "Жетон", "Ранг", "Отдел",
                        "Предупреждения", "Бан", "Причина бана", "Дата бана", "Дата регистрации"]
        ws_users.append(headers_users)
        
        # Стилизация заголовков
        for cell in ws_users[1]:
            cell.font = Font(bold=True, color="FFFFFF")
            cell.fill = PatternFill(start_color="4F81BD", end_color="4F81BD", fill_type="solid")
            cell.alignment = Alignment(horizontal="center")
        
        # Лист глобального бана
        ws_gban = wb.create_sheet("Глобальный бан")
        headers_gban = ["ID", "User ID", "Ник", "Причина", "Дата бана", "Кто забанил"]
        ws_gban.append(headers_gban)
        
        for cell in ws_gban[1]:
            cell.font = Font(bold=True, color="FFFFFF")
            cell.fill = PatternFill(start_color="FF0000", end_color="FF0000", fill_type="solid")
            cell.alignment = Alignment(horizontal="center")
        
        # Лист наград
        ws_awards = wb.create_sheet("Награды")
        headers_awards = ["ID", "User ID", "Ник", "Награда", "Тип награды", "Дата выдачи", "Кто выдал"]
        ws_awards.append(headers_awards)
        
        for cell in ws_awards[1]:
            cell.font = Font(bold=True, color="FFFFFF")
            cell.fill = PatternFill(start_color="FFD700", end_color="FFD700", fill_type="solid")
            cell.alignment = Alignment(horizontal="center")
        
        # Лист предупреждений
        ws_warns = wb.create_sheet("Предупреждения")
        headers_warns = ["ID", "User ID", "Ник", "Тип", "Счетчик", "Причина", "Дата", "Кто выдал"]
        ws_warns.append(headers_warns)
        
        for cell in ws_warns[1]:
            cell.font = Font(bold=True, color="FFFFFF")
            cell.fill = PatternFill(start_color="FFA500", end_color="FFA500", fill_type="solid")
            cell.alignment = Alignment(horizontal="center")
        
        # Устанавливаем ширину столбцов
        for ws in [ws_users, ws_gban, ws_awards, ws_warns]:
            for column in ws.columns:
                max_length = 0
                column_letter = column[0].column_letter
                for cell in column:
                    try:
                        if len(str(cell.value)) > max_length:
                            max_length = len(str(cell.value))
                    except:
                        pass
                adjusted_width = min(max_length + 2, 50)
                ws.column_dimensions[column_letter].width = adjusted_width
        
        wb.save(EXCEL_FILE)

# Генерация уникального жетона
def generate_unique_token():
    wb = openpyxl.load_workbook(EXCEL_FILE)
    ws = wb["Пользователи"]
    
    while True:
        random_digits = ''.join([str(random.randint(0, 9)) for _ in range(4)])
        token = f"52{random_digits}"
        
        # Проверка уникальности
        token_exists = False
        for row in ws.iter_rows(min_row=2, values_only=True):
            if row[4] == token:
                token_exists = True
                break
        
        if not token_exists:
            wb.close()
            return token

