def _get_article_top(since: datetime = None, limit: int = 10) -> list:
    """
    Возвращает топ юзеров по числу полученных статей с момента since.
    since=None → за всё время.
    Каждый элемент: {user_id, total, top_articles: [(num, name, count), ...]}
    """
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    if since:
        since_str = since.strftime("%Y-%m-%d %H:%M:%S")
        c.execute(
            '''SELECT user_id, COUNT(*) as total
               FROM article_history
               WHERE given_at >= ?
               GROUP BY user_id
               ORDER BY total DESC
               LIMIT ?''',
            (since_str, limit),
        )
    else:
        c.execute(
            '''SELECT user_id, COUNT(*) as total
               FROM article_history
               GROUP BY user_id
               ORDER BY total DESC
               LIMIT ?''',
            (limit,),
        )
    rows = c.fetchall()
    result = []
    for uid, total in rows:
        # Топ-3 статей у этого юзера
        if since:
            c.execute(
                '''SELECT article_num, article_name, COUNT(*) as cnt
                   FROM article_history
                   WHERE user_id = ? AND given_at >= ?
                   GROUP BY article_num
                   ORDER BY cnt DESC
                   LIMIT 3''',
                (uid, since_str),
            )
        else:
            c.execute(
                '''SELECT article_num, article_name, COUNT(*) as cnt
                   FROM article_history
                   WHERE user_id = ?
                   GROUP BY article_num
                   ORDER BY cnt DESC
                   LIMIT 3''',
                (uid,),
            )
        top_articles = c.fetchall()
        result.append({
            'user_id': uid,
            'total': total,
            'top_articles': top_articles,
        })
    conn.close()
    return result


def _format_top_list(top: list, *, with_articles: bool = True) -> str:
    """Форматирует топ-список в текст."""
    if not top:
        return "Пока никто не получал статью."
    medals = ["🥇", "🥈", "🥉"]
    lines = []
    for i, entry in enumerate(top):
        ud = get_user_data(entry['user_id'])
        name = ud['callsign'] if ud else f"id {entry['user_id']}"
        medal = medals[i] if i < 3 else f"{i + 1}."
        lines.append(f"{medal} {name} — {entry['total']} ст.")
        if with_articles and entry['top_articles'] and i < 3:
            for num, art_name, cnt in entry['top_articles']:
                lines.append(f"    • ст.{num} «{art_name}» ×{cnt}")
    return "\n".join(lines)


