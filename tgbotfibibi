def set_user_token(user_id: int, new_token: str) -> tuple:
    """Установка нового жетона"""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('SELECT user_id FROM users WHERE token = ?', (new_token,))
    if c.fetchone():
        conn.close()
        return False, "Жетон уже занят"
    c.execute('UPDATE users SET token = ? WHERE user_id = ?', (new_token, user_id))
    conn.commit()
    ok = c.rowcount > 0
    conn.close()
    return ok, "Жетон обновлен" if ok else "Пользователь не найден"

