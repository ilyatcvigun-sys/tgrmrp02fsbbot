    await update.message.reply_text(f"🔍 ПОЛНАЯ ИНФОРМАЦИЯ\n\n🎮 {user_data['nick']}\n📻 {user_data['callsign']}\n🎫 {user_data['token']}\n⭐ {RANKS[user_data['rank']]['name']}\n📁 {user_data['department']}\n⚠️ {user_data['warns']}\n🔐 Спецдопуск: {'Да' if has_special_access(target_id) else 'Нет'}\n🚫 ЧС: {'Да' if gban['is_banned'] else 'Нет'}\n🆔 {user_data['user_id']}")

# ============ РЕГИСТРАЦИЯ ============

async def start_registration(update, context):
    if get_user_data(update.effective_user.id):
        await update.message.reply_text("❌ Уже зарегистрированы!")
        return ConversationHandler.END
    await update.message.reply_text("📝 Шаг 1/2 — Игровой ник:")
    return GAME_NICK

async def get_game_nick(update, context): context.user_data['game_nick'] = update.message.text; await update.message.reply_text("Шаг 2/2 — Позывной:"); return CALLSIGN

async def complete_registration(update, context):
    callsign = update.message.text
    user_id = update.effective_user.id
    token = add_user(user_id, context.user_data['game_nick'], callsign)
    await update.message.reply_text(f"✅ Готово!\n\n🎮 {context.user_data['game_nick']}\n📻 {callsign}\n🎫 {token}\n⭐ {RANKS[0]['name']}")
    await start(update, context)
    return ConversationHandler.END

async def cancel(update, context): await update.message.reply_text("❌ Отменено."); return ConversationHandler.END

async def atest(update, context): await update.message.reply_text(f"Chat ID: {update.effective_chat.id}\nChat type: {update.effective_chat.type}")

# ============ ОБРАБОТЧИК КНОПОК ============

async def handle_message(update, context):
    text = update.message.text
    user_id = update.effective_user.id
    if check_gban(user_id)['is_banned']:
        await update.message.reply_text("🚫 Вы в ЧС!")
        return
    handlers = {"📝 Регистрация": start_registration, "👤 Информация": ainfo, "🔍 Проверить ЧС": check_gban_command, "ℹ️ Помощь": ahelp, "📋 Список участников": auserlist, "📝 Подать жалобу": areport_start}
    if text in handlers:
        return await handlers[text](update, context)

# ============ ЗАПУСК ============

def main():
    init_database()
    application = Application.builder().token(BOT_TOKEN).build()
    application.add_handler(ConversationHandler(entry_points=[MessageHandler(filters.Regex('^📝 Регистрация$'), start_registration)], states={GAME_NICK: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_game_nick)], CALLSIGN: [MessageHandler(filters.TEXT & ~filters.COMMAND, complete_registration)]}, fallbacks=[CommandHandler('cancel', cancel)]))
    for cmd, func in {'start':start,'ainfo':ainfo,'ahelp':ahelp,'aprofile':aprofile,'astats':astats,'aawards':aawards,'anick':anick,'asearch':asearch,'akick':akick,'aban':aban,'aunban':aunban,'awarn':awarn,'awarns':awarns,'awarnlist':awarns,'aunwarn':aunwarn,'aunwarnall':aunwarnall,'asetrank':asetrank,'asetdept':asetdept,'asettoken':asettoken,'aadmins':aadmins,'auserlist':auserlist,'awho':awhoprofile,'areports':areports,'achangelog':achangelog,'acallsign':acallsign,'ablock':ablock,'aunblock':aunblock,'amood':amood,'aspecial':aspecial,'awhois':awhois,'abroadcast':abroadcast,'atest':atest,'find':find}.items():
        application.add_handler(CommandHandler(cmd, func))
    for cmd, func in {'gban':gban_command,'ungban':ungban_command,'check_gban':check_gban_command,'gban_list':gban_list_command,'areport':areport_start}.items():
        application.add_handler(CommandHandler(cmd, func))
    application.add_handler(ConversationHandler(entry_points=[CommandHandler('areport', areport_start), MessageHandler(filters.Regex('^📝 Подать жалобу$'), areport_start)], states={REPORT_VIOLATOR:[MessageHandler(filters.TEXT & ~filters.COMMAND, report_violator)], REPORT_FACTION:[MessageHandler(filters.TEXT & ~filters.COMMAND, report_faction)], REPORT_VIOLATION:[MessageHandler(filters.TEXT & ~filters.COMMAND, report_violation)], REPORT_EVIDENCE:[MessageHandler(filters.TEXT & ~filters.COMMAND, report_evidence)], REPORT_COMMAND:[MessageHandler(filters.TEXT & ~filters.COMMAND, report_complete)]}, fallbacks=[CommandHandler('cancel', cancel)]))
    application.add_handler(ChatMemberHandler(welcome_new_member))
    application.add_handler(CallbackQueryHandler(handle_report_callback))
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND & filters.ChatType.PRIVATE, handle_message))
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND & filters.ChatType.PRIVATE, handle_moderator_comment), group=1)
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, track_message), group=2)
    application.job_queue.run_repeating(auto_mood, interval=3600, first=10)
    print("🤖 Бот запущен!")
    application.run_polling()

if __name__ == '__main__':
    main()
