def _load_uk_articles() -> list:
    """
    Загружает базу статей из uk_articles.json (рядом с bot.py).
    Если файл недоступен/повреждён — возвращает встроенный fallback.
    """
    path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "uk_articles.json")
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
        if not isinstance(data, list) or not data:
            raise ValueError("JSON пустой или не список")
        # Минимальная валидация: каждая запись должна иметь num + name + joke
        cleaned = [a for a in data
                   if isinstance(a, dict) and a.get("num") and a.get("name") and a.get("joke")]
        if not cleaned:
            raise ValueError("Нет валидных записей в JSON")
        logger.info(f"UK_ARTICLES: загружено {len(cleaned)} статей из {path}")
        return cleaned
    except FileNotFoundError:
        logger.warning(f"UK_ARTICLES: файл {path} не найден, используется fallback ({len(_UK_ARTICLES_FALLBACK)} статей)")
    except Exception as e:
        logger.error(f"UK_ARTICLES: ошибка загрузки {path}: {e}. Используется fallback.")
    return list(_UK_ARTICLES_FALLBACK)


